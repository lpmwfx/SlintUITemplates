{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "rulestools-mcp hook",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "rulestools hook",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rulestools-mcp pre-commit-check",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}
