import { Colors, Spacing, Sizes } from "../tokens/theme.slint";

// Drag handle between panels.
// vertical=false → column handle (col-resize cursor, reports dx)
// vertical=true  → row handle    (row-resize cursor, reports dy)
// Sizing is fully controlled by the parent — no preferred-width/height defaults.
//
// dragged(dx, dy)  — cumulative offset from press point (logical px).
// drag-started()   — fires on BOTH mouse-press AND release so callers can
//                    capture and re-anchor their drag-base value each time.
export component DragHandle inherits Rectangle {
    in property <bool> vertical: false;
    callback dragged(float, float);  // cumulative dx, dy from press point (logical px)
    callback drag-started();         // fires on press and on release

    background: touch.has-hover ? Colors.accent : Colors.border;

    touch := TouchArea {
        mouse-cursor: vertical ? row-resize : col-resize;
        moved => { root.dragged(vertical ? Sizes.no-fill : (self.mouse-x - self.pressed-x) / Spacing.border, vertical ? (self.mouse-y - self.pressed-y) / Spacing.border : Sizes.no-fill); }
        // Fires on press and on release — parent uses this to re-anchor drag-base-width.
        changed pressed => { root.drag-started(); }
    }
}
