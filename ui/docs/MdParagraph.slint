import { Colors, Spacing, Type } from "../globals/theme.slint";

// MdParagraph — renders a paragraph block.
/// M dp ar ag ra ph component.
/// component `MdParagraph`.
export component MdParagraph inherits VerticalLayout {
    /// Input property "text".
    /// property `text`.
    in property <string> text;

    padding-top: Spacing.xs;
    padding-bottom: Spacing.xs;

    Text {
        width: parent.width;
        text: root.text;
        font-size: Type.body-size;
        color: Colors.text-primary;
        wrap: word-wrap;
    }
}
