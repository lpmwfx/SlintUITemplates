import { Colors, Spacing, Type } from "tokens/theme.slint";
import { NavBar } from "views/nav-bar.slint";

export { Colors }

export component AppWindow inherits Window {
    title: "SlintUI Templates";
    preferred-width: 900px;
    preferred-height: 600px;
    background: Colors.bg-primary;

    // --- State (mother owns all) ---
    in-out property <string> active-view: "home";
    in-out property <bool> sidebar-open: true;

    // --- Callbacks ---
    callback navigate(string);

    navigate(view) => { self.active-view = view; }

    VerticalLayout {
        // NavBar — child view, receives state, emits events
        NavBar {
            height: 48px;
            breadcrumb: root.active-view;
            can-go-back: root.active-view != "home";
            go-back => { root.active-view = "home"; }
        }

        // Content area — placeholder for phase 2 views
        Rectangle {
            background: Colors.bg-primary;

            VerticalLayout {
                alignment: center;

                Text {
                    text: "View: " + root.active-view;
                    font-size: Type.heading-size;
                    color: Colors.text-primary;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Phase 1 — Foundation scaffold";
                    font-size: Type.body-size;
                    color: Colors.text-secondary;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
