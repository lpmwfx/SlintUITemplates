// page-feedback — Toast, Dialog, Spinner (all sizes), Alert (all variants), Tooltip demo

import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";
import { Variants } from "../state/variants.slint";
import { Toast }    from "../widgets/toast.slint";
import { Dialog }   from "../widgets/dialog.slint";
import { Spinner }  from "../widgets/spinner.slint";
import { Alert }    from "../widgets/alert.slint";
import { Tooltip }  from "../widgets/tooltip.slint";
import { Button }   from "../widgets/button.slint";
import { ViewerSection } from "viewer-section.slint";

/// Viewer page showcasing transient feedback components such as alerts, toasts, and progress indicators.
/// component `PageFeedback`.
export component PageFeedback inherits VerticalLayout {
    spacing: Spacing.md;

    // ── private variant strings ─────────────────────────────────────────
    /// Private property "var-info" used internally.
    /// property `var-info`.
    private property <string> var-info: "info";
    /// Private property "var-sm" used internally.
    /// property `var-sm`.
    private property <string> var-sm: "sm";
    /// Private property "var-md" used internally.
    /// property `var-md`.
    private property <string> var-md: "md";
    /// Private property "var-lg" used internally.
    /// property `var-lg`.
    private property <string> var-lg: "lg";

    // ── demo labels ─────────────────────────────────────────────────────
    /// Private property "section-toast" used internally.
    /// property `section-toast`.
    private property <string> section-toast: "Toast";
    /// Private property "section-dialog" used internally.
    /// property `section-dialog`.
    private property <string> section-dialog: "Dialog";
    /// Private property "section-spinner" used internally.
    /// property `section-spinner`.
    private property <string> section-spinner: "Spinner";
    /// Private property "section-alert" used internally.
    /// property `section-alert`.
    private property <string> section-alert: "Alert";
    /// Private property "section-tooltip" used internally.
    /// property `section-tooltip`.
    private property <string> section-tooltip: "Tooltip";
    /// Private property "toast-info-msg" used internally.
    /// property `toast-info-msg`.
    private property <string> toast-info-msg: "Information message";
    /// Private property "toast-success-msg" used internally.
    /// property `toast-success-msg`.
    private property <string> toast-success-msg: "Success! Operation complete";
    /// Private property "toast-warning-msg" used internally.
    /// property `toast-warning-msg`.
    private property <string> toast-warning-msg: "Warning: please check input";
    /// Private property "toast-error-msg" used internally.
    /// property `toast-error-msg`.
    private property <string> toast-error-msg: "Error: action failed";
    /// Private property "dialog-title" used internally.
    /// property `dialog-title`.
    private property <string> dialog-title: "Confirm Action";
    /// Private property "alert-info-msg" used internally.
    /// property `alert-info-msg`.
    private property <string> alert-info-msg: "This is an informational alert.";
    /// Private property "alert-success-title" used internally.
    /// property `alert-success-title`.
    private property <string> alert-success-title: "Success!";
    /// Private property "alert-success-msg" used internally.
    /// property `alert-success-msg`.
    private property <string> alert-success-msg: "Your changes have been saved.";
    /// Private property "alert-warning-title" used internally.
    /// property `alert-warning-title`.
    private property <string> alert-warning-title: "Warning";
    /// Private property "alert-warning-msg" used internally.
    /// property `alert-warning-msg`.
    private property <string> alert-warning-msg: "Please review before continuing.";
    /// Private property "alert-error-title" used internally.
    /// property `alert-error-title`.
    private property <string> alert-error-title: "Error";
    /// Private property "alert-error-msg" used internally.
    /// property `alert-error-msg`.
    private property <string> alert-error-msg: "Something went wrong. Please try again.";
    /// Private property "tooltip-top-text" used internally.
    /// property `tooltip-top-text`.
    private property <string> tooltip-top-text: "Top tooltip (default)";
    /// Private property "tooltip-bottom-text" used internally.
    /// property `tooltip-bottom-text`.
    private property <string> tooltip-bottom-text: "Bottom tooltip";
    /// Private property "tooltip-right-text" used internally.
    /// property `tooltip-right-text`.
    private property <string> tooltip-right-text: "Right tooltip";
    /// Private property "btn-hover" used internally.
    /// property `btn-hover`.
    private property <string> btn-hover: "Hover me";
    /// Private property "btn-bottom" used internally.
    /// property `btn-bottom`.
    private property <string> btn-bottom: "Bottom";
    /// Private property "btn-right" used internally.
    /// property `btn-right`.
    private property <string> btn-right: "Right";
    /// Private property "dialog-w" used internally.
    /// property `dialog-w`.
    private property <length> dialog-w: Sizes.comp-480;

    ViewerSection {
        title: root.section-toast;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xxxl;
            Toast { message: root.toast-info-msg;         variant: root.var-info;    visible: true; }
            Toast { message: root.toast-success-msg;      variant: Variants.success; visible: true; }
            Toast { message: root.toast-warning-msg;      variant: Variants.warning; visible: true; }
            Toast { message: root.toast-error-msg;        variant: Variants.error;   visible: true; }
        }
    }

    ViewerSection {
        title: root.section-dialog;
        Rectangle {
            width: root.dialog-w;
            height: Sizes.panel-md;
            border-width: Sizes.border-w;
            border-color: Colors.border;
            background: Colors.bg-primary;
            clip: true;

            Dialog {
                title: root.dialog-title;
                visible: true;
                width: parent.width;
                height: parent.height;
            }
        }
    }

    ViewerSection {
        title: root.section-spinner;
        HorizontalLayout {
            alignment: start;
            spacing: Spacing.lg;

            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-sm; }
                Text { text: root.var-sm; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-md; }
                Text { text: root.var-md; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-lg; }
                Text { text: root.var-lg; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            Spinner { size: root.var-md; active: false; }
        }
    }

    ViewerSection {
        title: root.section-alert;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-max;
            Alert { message: root.alert-info-msg; variant: root.var-info; }
            Alert { title: root.alert-success-title; message: root.alert-success-msg; variant: Variants.success; }
            Alert { title: root.alert-warning-title; message: root.alert-warning-msg; variant: Variants.warning; closable: true; }
            Alert { title: root.alert-error-title; message: root.alert-error-msg; variant: Variants.error; closable: true; }
        }
    }

    ViewerSection {
        title: root.section-tooltip;
        HorizontalLayout {
            alignment: start;
            spacing: Spacing.lg;

            Tooltip { text: root.tooltip-top-text; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-hover; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
            Tooltip { text: root.tooltip-bottom-text; placement: Variants.bottom; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-bottom; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
            Tooltip { text: root.tooltip-right-text; placement: Variants.right; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-right; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
        }
    }
}
