// page-feedback — Toast, Dialog, Spinner (all sizes), Alert (all variants), Tooltip demo

import { Colors, Spacing, Type } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { Strings } from "../../globals/strings.slint";
import { Variants } from "../../globals/variants.slint";
import { Toast }    from "../../widgets/toast.slint";
import { Dialog }   from "../../widgets/dialog.slint";
import { Spinner }  from "../../widgets/spinner.slint";
import { Alert }    from "../../widgets/alert.slint";
import { Tooltip }  from "../../widgets/tooltip.slint";
import { Button }   from "../../widgets/button.slint";
import { ViewerSection } from "../shared/viewer-section.slint";

/// Viewer page showcasing transient feedback components such as alerts, toasts, and progress indicators.
/// component `PageFeedback`.
export component PageFeedback inherits VerticalLayout {
    spacing: Spacing.md;

    // ── private variant strings ─────────────────────────────────────────
    /// Info variant discriminator.
    /// property `var-info`.
    private property <string> var-info: Variants.info;
    /// Small size variant.
    /// property `var-sm`.
    private property <string> var-sm: Variants.sm;
    /// Medium size variant.
    /// property `var-md`.
    private property <string> var-md: Variants.md;
    /// Large size variant.
    /// property `var-lg`.
    private property <string> var-lg: Variants.lg;

    // ── demo labels ─────────────────────────────────────────────────────
    /// Toast section title.
    /// property `section-toast`.
    private property <string> section-toast: Strings.demo-section-toast;
    /// Dialog section title.
    /// property `section-dialog`.
    private property <string> section-dialog: Strings.demo-section-dialog;
    /// Spinner section title.
    /// property `section-spinner`.
    private property <string> section-spinner: Strings.demo-section-spinner;
    /// Alert section title.
    /// property `section-alert`.
    private property <string> section-alert: Strings.demo-section-alert;
    /// Tooltip section title.
    /// property `section-tooltip`.
    private property <string> section-tooltip: Strings.demo-section-tooltip;
    /// Toast info message text.
    /// property `toast-info-msg`.
    private property <string> toast-info-msg: Strings.demo-toast-info;
    /// Toast success message text.
    /// property `toast-success-msg`.
    private property <string> toast-success-msg: Strings.demo-toast-success;
    /// Toast warning message text.
    /// property `toast-warning-msg`.
    private property <string> toast-warning-msg: Strings.demo-toast-warning;
    /// Toast error message text.
    /// property `toast-error-msg`.
    private property <string> toast-error-msg: Strings.demo-toast-error;
    /// Dialog title text.
    /// property `dialog-title`.
    private property <string> dialog-title: Strings.demo-dialog-title;
    /// Alert info message text.
    /// property `alert-info-msg`.
    private property <string> alert-info-msg: Strings.demo-alert-info-msg;
    /// Alert success title text.
    /// property `alert-success-title`.
    private property <string> alert-success-title: Strings.demo-alert-success-title;
    /// Alert success message text.
    /// property `alert-success-msg`.
    private property <string> alert-success-msg: Strings.demo-alert-success-msg;
    /// Alert warning title text.
    /// property `alert-warning-title`.
    private property <string> alert-warning-title: Strings.demo-alert-warning-title;
    /// Alert warning message text.
    /// property `alert-warning-msg`.
    private property <string> alert-warning-msg: Strings.demo-alert-warning-msg;
    /// Alert error title text.
    /// property `alert-error-title`.
    private property <string> alert-error-title: Strings.demo-alert-error-title;
    /// Alert error message text.
    /// property `alert-error-msg`.
    private property <string> alert-error-msg: Strings.demo-alert-error-msg;
    /// Top tooltip text.
    /// property `tooltip-top-text`.
    private property <string> tooltip-top-text: Strings.demo-tooltip-top;
    /// Bottom tooltip text.
    /// property `tooltip-bottom-text`.
    private property <string> tooltip-bottom-text: Strings.demo-tooltip-bottom;
    /// Right tooltip text.
    /// property `tooltip-right-text`.
    private property <string> tooltip-right-text: Strings.demo-tooltip-right;
    /// Hover button label.
    /// property `btn-hover`.
    private property <string> btn-hover: Strings.demo-btn-hover;
    /// Bottom button label.
    /// property `btn-bottom`.
    private property <string> btn-bottom: Strings.demo-btn-bottom;
    /// Right button label.
    /// property `btn-right`.
    private property <string> btn-right: Strings.demo-btn-right;
    /// Dialog container width.
    /// property `dialog-w`.
    private property <length> dialog-w: Sizes.comp-480;

    ViewerSection {
        title: root.section-toast;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xxxl;
            Toast { message: root.toast-info-msg;         variant: root.var-info;    visible: true; }
            Toast { message: root.toast-success-msg;      variant: Variants.success; visible: true; }
            Toast { message: root.toast-warning-msg;      variant: Variants.warning; visible: true; }
            Toast { message: root.toast-error-msg;        variant: Variants.error;   visible: true; }
        }
    }

    ViewerSection {
        title: root.section-dialog;
        Rectangle {
            width: root.dialog-w;
            height: Sizes.panel-md;
            border-width: Sizes.border-w;
            border-color: Colors.border;
            background: Colors.bg-primary;
            clip: true;

            Dialog {
                title: root.dialog-title;
                visible: true;
                width: parent.width;
                height: parent.height;
            }
        }
    }

    ViewerSection {
        title: root.section-spinner;
        HorizontalLayout {
            alignment: start;
            spacing: Spacing.lg;

            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-sm; }
                Text { text: root.var-sm; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-md; }
                Text { text: root.var-md; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            VerticalLayout {
                spacing: Spacing.xs;
                alignment: center;
                Spinner { size: root.var-lg; }
                Text { text: root.var-lg; font-size: Type.caption-size; color: Colors.text-secondary; horizontal-alignment: center; }
            }
            Spinner { size: root.var-md; active: false; }
        }
    }

    ViewerSection {
        title: root.section-alert;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-max;
            Alert { message: root.alert-info-msg; variant: root.var-info; }
            Alert { title: root.alert-success-title; message: root.alert-success-msg; variant: Variants.success; }
            Alert { title: root.alert-warning-title; message: root.alert-warning-msg; variant: Variants.warning; closable: true; }
            Alert { title: root.alert-error-title; message: root.alert-error-msg; variant: Variants.error; closable: true; }
        }
    }

    ViewerSection {
        title: root.section-tooltip;
        HorizontalLayout {
            alignment: start;
            spacing: Spacing.lg;

            Tooltip { text: root.tooltip-top-text; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-hover; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
            Tooltip { text: root.tooltip-bottom-text; placement: Variants.bottom; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-bottom; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
            Tooltip { text: root.tooltip-right-text; placement: Variants.right; width: Sizes.thumb-lg; height: Spacing.xl;
                Button { label: root.btn-right; width: parent.width; height: parent.height; variant: Variants.secondary; }
            }
        }
    }
}
