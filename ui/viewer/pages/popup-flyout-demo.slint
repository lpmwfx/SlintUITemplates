    /// property `border-px`.
    private property <length> border-px: Sizes.border-w;

    height: Spacing.control-lg;
    width: root.demo-w;

    flyout := Flyout { window-height: root.window-height; popup-width: root.fly-w; popup-height: root.fly-h;
        title:
            Strings.demo-flyout-title;
        body:
            Strings.demo-flyout-body;

        Rectangle {
            width: root.demo-w;
            height: Spacing.control-lg;
            border-radius: Spacing.xs;
            border-width: root.border-px;
            border-color: Colors.border;
            background: btn-ta.has-hover ? Colors.bg-elevated : Colors.bg-surface;

            Text { text: Strings.demo-flyout-open;
                font-size: Type.body-size;
                color: Colors.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            btn-ta := TouchArea {
                clicked => { flyout.show-at(self.mouse-x, self.mouse-y); }
            }
