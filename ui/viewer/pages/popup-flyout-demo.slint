export component PopupFlyoutDemo inherits Rectangle {
    /// Input property "window-height".
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    in property <length> window-height;

    /// Private property "demo-w" used internally.
    /// property `demo-w`.
    /// property `demo-w`.
    /// property `demo-w`.
    /// property `demo-w`.
    /// property `demo-w`.
    /// property `demo-w`.
    /// property `demo-w`.
    private property <length> demo-w:   Sizes.comp-160;
    /// Private property "fly-w" used internally.
    /// property `fly-w`.
    /// property `fly-w`.
    /// property `fly-w`.
    /// property `fly-w`.
    /// property `fly-w`.
    /// property `fly-w`.
    /// property `fly-w`.
    private property <length> fly-w:    Sizes.comp-240;
    /// Private property "fly-h" used internally.
    /// property `fly-h`.
    /// property `fly-h`.
    /// property `fly-h`.
    /// property `fly-h`.
    /// property `fly-h`.
    /// property `fly-h`.
    /// property `fly-h`.
    private property <length> fly-h:    Sizes.comp-130;
    /// Private property "border-px" used internally.
