import { Colors, Spacing, Type } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { Strings } from "../../globals/strings.slint";
import { Variants }              from "../../globals/variants.slint";
import { ViewSlot }              from "../../modules/ViewSlot.slint";
import { Button }                from "../../widgets/button.slint";

// ViewSlotDemo — demonstrates ViewSlot slot-id routing with nav buttons.
/// V ie ws lo td em o component.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
/// component `ViewSlotDemo`.
export component ViewSlotDemo inherits VerticalLayout {
    /// Private property "active-slot" used internally.
    /// property `active-slot`.
    /// property `active-slot`.
    /// property `active-slot`.
    /// property `active-slot`.
    /// property `active-slot`.
    /// property `active-slot`.
    /// property `active-slot`.
    private property <string> active-slot: Variants.alpha;
    /// Private property "alpha-subtle" used internally.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    /// property `alpha-subtle`.
    private property <float>  alpha-subtle: Sizes.alpha-10;

    /// Private property "lbl-alpha" used internally.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    /// property `lbl-alpha`.
    private property <string> lbl-alpha: "Alpha";
    /// Private property "lbl-beta" used internally.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    /// property `lbl-beta`.
    private property <string> lbl-beta: "Beta";
    /// Private property "lbl-gamma" used internally.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    /// property `lbl-gamma`.
    private property <string> lbl-gamma: Strings.demo-viewslot-label-gamma;
    /// Private property "slot-alpha-text" used internally.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    /// property `slot-alpha-text`.
    private property <string> slot-alpha-text: Strings.demo-viewslot-alpha-text;
    /// Private property "slot-beta-text" used internally.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    /// property `slot-beta-text`.
    private property <string> slot-beta-text: Strings.demo-viewslot-beta-text;
    /// Private property "slot-gamma-text" used internally.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    /// property `slot-gamma-text`.
    private property <string> slot-gamma-text: Strings.demo-viewslot-gamma-text;

    spacing: Spacing.sm;
    width: Sizes.panel-xxxl;

    // Nav buttons
    HorizontalLayout {
        spacing: Spacing.sm;
        alignment: start;
        Button {
            label: root.lbl-alpha;
            variant: root.active-slot == Variants.alpha ? Variants.primary : Variants.secondary;
            clicked => { root.active-slot = Variants.alpha; }
        }
        Button {
            label: root.lbl-beta;
            variant: root.active-slot == Variants.beta ? Variants.primary : Variants.secondary;
            clicked => { root.active-slot = Variants.beta; }
        }
        Button {
            label: root.lbl-gamma;
            variant: root.active-slot == Variants.gamma ? Variants.primary : Variants.secondary;
            clicked => { root.active-slot = Variants.gamma; }
        }
    }

    // Slot content area
    Rectangle {
        height: Sizes.thumb-sm;
        border-width: Sizes.border-w;
        border-color: Colors.border;
        background: Colors.bg-surface;
        clip: true;

        ViewSlot {
            slot-id: Variants.alpha;
            active: root.active-slot;
            width: parent.width; height: parent.height;
            Text {
                text: root.slot-alpha-text;
                color: Colors.text-primary;
                font-size: Type.body-size;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        ViewSlot {
            slot-id: Variants.beta;
            active: root.active-slot;
            width: parent.width; height: parent.height;
            background: Colors.accent.with-alpha(root.alpha-subtle);
            Text {
                text: root.slot-beta-text;
                color: Colors.accent;
                font-size: Type.body-size;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        ViewSlot {
            slot-id: Variants.gamma;
            active: root.active-slot;
            width: parent.width; height: parent.height;
            background: Colors.bg-elevated;
            Text {
                text: root.slot-gamma-text;
                color: Colors.text-secondary;
                font-size: Type.body-size;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
