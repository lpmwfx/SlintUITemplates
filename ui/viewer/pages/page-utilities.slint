// page-utilities — Label, Toolbar, MessageBar, EmptyState, Segmented, FormField

import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { Strings } from "../../globals/strings.slint";
import { Label }       from "../../widgets/label.slint";
import { Toolbar, ToolbarItem } from "../../widgets/toolbar/toolbar.slint";
import { MessageBar }  from "../../widgets/message-bar.slint";
import { EmptyState }  from "../../widgets/empty-state/empty-state.slint";
import { Segmented, SegmentItem } from "../../widgets/segmented/segmented.slint";
import { FormField }   from "../../widgets/form-field/form-field.slint";
import { TextInput }   from "../../widgets/text-input.slint";
import { ViewerSection } from "../shared/viewer-section.slint";

/// Viewer page showcasing utility components such as tooltips, labels, skeletons, and empty states.
/// component `PageUtilities`.
export component PageUtilities inherits VerticalLayout {
    spacing: Spacing.md;

    /// Toolbar container width.
    /// property `tb-w`.
    private property <length> tb-w:     Sizes.panel-max;
    /// MessageBar container width.
    /// property `mb-w`.
    private property <length> mb-w:     Sizes.panel-wide;
    /// EmptyState container width.
    /// property `es-w`.
    private property <length> es-w:     Sizes.comp-340;
    /// EmptyState container height.
    /// property `es-h`.
    private property <length> es-h:     Sizes.panel-sm;
    /// Segmented three-tab width.
    /// property `seg1-w`.
    private property <length> seg1-w:   Sizes.comp-240;
    /// Segmented two-tab width.
    /// property `seg2-w`.
    private property <length> seg2-w:   Sizes.comp-120;
    /// FormField container width.
    /// property `ff-w`.
    private property <length> ff-w:     Sizes.panel-xl;
    /// Border pixel width.
    /// property `border-px`.
    private property <length> border-px: Sizes.border-w;
    /// Selected segment value.
    /// property `seg-val`.
    private property <string> seg-val:   "day";
    /// Second segment selected value.
    /// property `seg2-val`.
    private property <string> seg2-val:  "list";
    /// MessageBar info message text.
    /// property `mb-info-msg`.
    private property <string> mb-info-msg: Strings.demo-messagebar-info;

    ViewerSection { title: Strings.demo-section-label;
        HorizontalLayout {
            spacing: Spacing.lg;
            alignment: start;
            VerticalLayout {
                spacing: Spacing.sm;
                Label { text: Strings.demo-label-normal; }
                Label { text: Strings.demo-label-required; required: true; }
                Label { text: Strings.demo-label-disabled; disabled: true; }
            }
        }
    }

    ViewerSection { title: Strings.demo-section-toolbar;
        VerticalLayout {
            spacing: Spacing.sm;

            Toolbar {
                width: root.tb-w;
                items: [
                    { id: "new",    icon: FluentIcons.file-new,    tooltip: Strings.demo-toolbar-new,  enabled: true  },
                    { id: "open",   icon: FluentIcons.folder-open, tooltip: Strings.demo-toolbar-open, enabled: true  },
                    { id: "save",   icon: FluentIcons.save,        tooltip: Strings.action-save,       enabled: true  },
                    { id: "sep1",   icon: "",                      tooltip: "",                        enabled: false },
                    { id: "cut",    icon: FluentIcons.cut,         tooltip: Strings.demo-toolbar-cut,  enabled: true  },
                    { id: "copy",   icon: FluentIcons.copy,        tooltip: Strings.tooltip-copy,      enabled: true  },
                    { id: "paste",  icon: FluentIcons.paste,       tooltip: Strings.tooltip-paste,     enabled: false },
                ];
                clicked(id) => { debug("toolbar: " + id); }
            }

            Text { text: Strings.demo-toolbar-hint;
                font-size: Type.caption-size;
                color: Colors.text-disabled;
            }
        }
    }

    ViewerSection { title: Strings.demo-section-messagebar;
        VerticalLayout {
            spacing: Spacing.sm;
            width: root.mb-w;
            MessageBar { variant: "info";    message: root.mb-info-msg; action-label: Strings.demo-messagebar-renew; }
            MessageBar { variant: "warning"; message: Strings.demo-messagebar-warning; }
            MessageBar { variant: "error";   message: Strings.demo-messagebar-error; action-label: Strings.demo-messagebar-retry; }
            MessageBar { variant: "success"; message: Strings.demo-messagebar-success; closable: true;
                closed => { debug("mb closed"); }
            }
        }
    }

    ViewerSection { title: Strings.demo-section-emptystate;
        Rectangle {
            width: root.es-w;
            height: root.es-h;
            border-width: root.border-px;
            border-color: Colors.border;
            border-radius: Spacing.sm;

            EmptyState { icon: FluentIcons.folder;
                title:
                    Strings.demo-empty-title;
                description:
                    Strings.demo-empty-desc;
                action-label:
                    Strings.demo-empty-action;
            }
        }
    }

    ViewerSection { title: Strings.demo-section-segmented;
        VerticalLayout {
            spacing: Spacing.sm;

            Segmented {
                width: root.seg1-w;
                selected: root.seg-val;
                items: [
                    { id: "day",   label: Strings.demo-segment-day,   icon: "" },
                    { id: "week",  label: Strings.demo-segment-week,  icon: "" },
                    { id: "month", label: Strings.demo-segment-month, icon: "" },
                ];
                changed(id) => { root.seg-val = id; }
            }

            Segmented {
                width: root.seg2-w;
                selected: root.seg2-val;
                items: [
                    { id: "list", label: "", icon: FluentIcons.list },
                    { id: "grid", label: "", icon: FluentIcons.grid },
                ];
                changed(id) => { root.seg2-val = id; }
            }

            Text { text: Strings.demo-seg-selected-prefix + root.seg-val + Strings.demo-seg-separator + root.seg2-val;
                font-size: Type.caption-size;
                color: Colors.text-secondary;
            }
        }
    }

    ViewerSection { title: Strings.demo-section-formfield;
        VerticalLayout {
            spacing: Spacing.md;
            width: root.ff-w;

            FormField { label: Strings.demo-ff-username-label; required: true; hint: Strings.demo-ff-username-hint;
                TextInput { placeholder: Strings.demo-ff-username-placeholder; }
            }

            FormField { label: Strings.demo-ff-email-label; error: Strings.demo-ff-email-error;
                TextInput { placeholder: Strings.demo-ff-email-placeholder; }
            }

            FormField { label: Strings.demo-ff-optional-label; hint: Strings.demo-ff-optional-hint;
                TextInput { placeholder: Strings.demo-ff-optional-placeholder; }
            }
        }
    }
}
