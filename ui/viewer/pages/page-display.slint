// page-display — Badge, Avatar, Card, ListItem, ProgressBar, Chip, Skeleton

import { Spacing } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { Strings } from "../globals/strings.slint";
import { Variants } from "../globals/variants.slint";
import { Badge }       from "../widgets/badge.slint";
import { Avatar }      from "../widgets/avatar.slint";
import { Card }        from "../widgets/card.slint";
import { ListItem }    from "../widgets/list-item.slint";
import { ProgressBar } from "../widgets/progress-bar.slint";
import { Chip }        from "../widgets/chip.slint";
import { Skeleton }    from "../widgets/skeleton.slint";
import { ViewerSection } from "viewer-section.slint";

/// Viewer page showcasing passive display components such as cards, badges, and avatars.
/// component `PageDisplay`.
export component PageDisplay inherits VerticalLayout {
    spacing: Spacing.md;

    // ── private variant strings ─────────────────────────────────────────
    /// Info variant discriminator.
    /// property `var-info`.
    private property <string> var-info: Variants.info;
    /// Small size variant.
    /// property `var-sm`.
    private property <string> var-sm: Variants.sm;
    /// Medium size variant.
    /// property `var-md`.
    private property <string> var-md: Variants.md;
    /// Large size variant.
    /// property `var-lg`.
    private property <string> var-lg: Variants.lg;
    /// Rectangle shape variant.
    /// property `var-rect`.
    private property <string> var-rect: "rect";

    // ── private size tokens ─────────────────────────────────────────────
    /// Skeleton circle size.
    /// property `skel-circle-size`.
    private property <length> skel-circle-size: Sizes.comp-40;
    /// Progress two-thirds value.
    /// property `progress-two-thirds`.
    private property <float> progress-two-thirds: 0.66;
    /// Skeleton full width ratio.
    /// property `skel-full`.
    private property <float> skel-full: Sizes.full;
    /// Skeleton eighty percent ratio.
    /// property `skel-eighty`.
    private property <float> skel-eighty: Sizes.percent-80;
    /// Skeleton sixty percent ratio.
    /// property `skel-sixty`.
    private property <float> skel-sixty: Sizes.percent-60;

    // ── demo labels ─────────────────────────────────────────────────────
    /// Badge section title.
    /// property `section-badge`.
    private property <string> section-badge: Strings.demo-section-badge;
    /// Avatar section title.
    /// property `section-avatar`.
    private property <string> section-avatar: Strings.demo-section-avatar;
    /// Card section title.
    /// property `section-card`.
    private property <string> section-card: Strings.demo-section-card;
    /// ListItem section title.
    /// property `section-listitem`.
    private property <string> section-listitem: Strings.demo-section-listitem;
    /// ProgressBar section title.
    /// property `section-progress`.
    private property <string> section-progress: Strings.demo-section-progress;
    /// Chip section title.
    /// property `section-chip`.
    private property <string> section-chip: Strings.demo-section-chip;
    /// Skeleton section title.
    /// property `section-skeleton`.
    private property <string> section-skeleton: Strings.demo-section-skeleton;
    /// Badge info label.
    /// property `badge-info`.
    private property <string> badge-info: Strings.demo-badge-info;
    /// Badge success label.
    /// property `badge-success`.
    private property <string> badge-success: Strings.demo-badge-success;
    /// Badge warning label.
    /// property `badge-warning`.
    private property <string> badge-warning: Strings.demo-badge-warning;
    /// Badge error label.
    /// property `badge-error`.
    private property <string> badge-error: Strings.demo-badge-error;
    /// Card title-only label.
    /// property `card-title-only`.
    private property <string> card-title-only: Strings.demo-card-title-only;
    /// Card title label.
    /// property `card-title`.
    private property <string> card-title: Strings.demo-card-title;
    /// Card subtitle text.
    /// property `card-subtitle`.
    private property <string> card-subtitle: Strings.demo-card-subtitle;
    /// Normal list item label.
    /// property `li-normal`.
    private property <string> li-normal: Strings.demo-li-normal;
    /// Selected list item label.
    /// property `li-selected`.
    private property <string> li-selected: Strings.demo-li-selected;
    /// List item with subtitle title.
    /// property `li-subtitle-title`.
    private property <string> li-subtitle-title: Strings.demo-li-subtitle-title;
    /// List item subtitle text.
    /// property `li-subtitle-text`.
    private property <string> li-subtitle-text: Strings.demo-li-subtitle-text;
    /// Default chip label.
    /// property `chip-default`.
    private property <string> chip-default: Strings.demo-chip-default;
    /// Selected chip label.
    /// property `chip-selected`.
    private property <string> chip-selected: Strings.demo-chip-selected;
    /// No-close chip label.
    /// property `chip-noclose`.
    private property <string> chip-noclose: Strings.demo-chip-noclose;
    /// Disabled chip label.
    /// property `chip-disabled`.
    private property <string> chip-disabled: Strings.demo-chip-disabled;
    /// Version chip label.
    /// property `chip-version`.
    private property <string> chip-version: Strings.demo-chip-version;
    /// Small avatar initials.
    /// property `avatar-sm-initials`.
    private property <string> avatar-sm-initials: Strings.demo-avatar-sm;
    /// Medium avatar initials.
    /// property `avatar-md-initials`.
    private property <string> avatar-md-initials: Strings.demo-avatar-md;
    /// Large avatar initials.
    /// property `avatar-lg-initials`.
    private property <string> avatar-lg-initials: Strings.demo-avatar-lg;

    ViewerSection {
        title: root.section-badge;
        HorizontalLayout {
            spacing: Spacing.sm;
            alignment: start;
            Badge { text: root.badge-info;    variant: root.var-info; }
            Badge { text: root.badge-success; variant: Variants.success; }
            Badge { text: root.badge-warning; variant: Variants.warning; }
            Badge { text: root.badge-error;   variant: Variants.error; }
        }
    }

    ViewerSection {
        title: root.section-avatar;
        HorizontalLayout {
            spacing: Spacing.sm;
            alignment: start;
            Avatar { initials: root.avatar-sm-initials; size: root.var-sm; }
            Avatar { initials: root.avatar-md-initials; size: root.var-md; }
            Avatar { initials: root.avatar-lg-initials; size: root.var-lg; }
        }
    }

    ViewerSection {
        title: root.section-card;
        HorizontalLayout {
            spacing: Spacing.md;
            alignment: start;
            Card { title: root.card-title-only; width: Sizes.panel-xs; }
            Card { title: root.card-title; subtitle: root.card-subtitle; width: Sizes.panel-sm; }
        }
    }

    ViewerSection {
        title: root.section-listitem;
        VerticalLayout {
            width: Sizes.panel-xl;
            ListItem { title: root.li-normal; }
            ListItem { title: root.li-selected; selected: true; }
            ListItem { title: root.li-subtitle-title; subtitle: root.li-subtitle-text; }
        }
    }

    ViewerSection {
        title: root.section-progress;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xl;
            ProgressBar { value: Sizes.no-fill; }
            ProgressBar { value: Sizes.third; }
            ProgressBar { value: root.progress-two-thirds; }
            ProgressBar { value: Sizes.fill; }
        }
    }

    ViewerSection {
        title: root.section-chip;
        HorizontalLayout {
            alignment: start;
            spacing: Spacing.sm;
            Chip { label: root.chip-default; }
            Chip { label: root.chip-selected; selected: true; }
            Chip { label: root.chip-noclose; closable: false; }
            Chip { label: root.chip-disabled; enabled: false; }
            Chip { label: root.chip-version; closable: false; selected: true; }
        }
    }

    ViewerSection {
        title: root.section-skeleton;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-lg;
            Skeleton { width: parent.width * root.skel-full; height: Sizes.icon-sm; variant: Variants.text; }
            Skeleton { width: parent.width * root.skel-eighty; height: Sizes.icon-sm; variant: Variants.text; }
            Skeleton { width: parent.width * root.skel-sixty; height: Sizes.icon-sm; variant: Variants.text; }
            Skeleton { width: Sizes.panel-lg; height: Sizes.thumb-sm; variant: root.var-rect; }
            HorizontalLayout {
                spacing: Spacing.sm;
                Skeleton { width: root.skel-circle-size; height: root.skel-circle-size; variant: Variants.circle; }
                Skeleton { width: root.skel-circle-size; height: root.skel-circle-size; variant: Variants.circle; animate: false; }
            }
        }
    }
}
