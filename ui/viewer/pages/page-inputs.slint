    ViewerSection {
        title: root.section-textinput;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xxl;
            TextInput { placeholder: root.ti-placeholder; }
            TextInput { label: root.ti-label; placeholder: root.ti-placeholder2; value: root.ti-value; }
            TextInput { label: root.ti-err-label; value: root.ti-err-value; error: root.ti-err-msg; }
        }
    }

    ViewerSection {
        title: root.section-selectfield;
        SelectField {
            width: Sizes.panel-md;
            options: ["Option A", "Option B", "Option C", "Option D"];
            placeholder: root.sf-placeholder;
        }
    }

    ViewerSection {
        title: root.section-searchinput;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-lg;
            SearchInput { placeholder: root.si-placeholder; }
            SearchInput { value: root.si-value; placeholder: root.si-placeholder2; }
        }
    }

    ViewerSection {
        title: root.section-passwordinput;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-lg;
            PasswordInput { placeholder: root.pi-placeholder; }
            PasswordInput { label: root.pi-label; placeholder: root.pi-placeholder2; }
            PasswordInput { label: root.pi-err-label; error: root.pi-err-msg; }
        }
    }

    ViewerSection {
        title: root.section-textarea;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xxl;
            TextArea { placeholder: root.ta-placeholder; rows: Sizes.three; }
            TextArea { label: root.ta-label; placeholder: root.ta-placeholder2; rows: Sizes.four; }
            TextArea { label: root.ta-err-label; error: root.ta-err-msg; rows: Sizes.three; }
        }
    }

    ViewerSection {
        title: root.section-spinbox;
        VerticalLayout {
            spacing: Spacing.sm;
            width: Sizes.panel-xs;
            SpinBox { value: Sizes.five; min: Sizes.zero; max: Sizes.twenty; }
            SpinBox { label: root.sb-label; value: root.spinbox-default-val; min: Sizes.zero; max: Sizes.hundred; }
            SpinBox { value: Sizes.ten; enabled: false; label: root.sb-disabled-label; }
        }
