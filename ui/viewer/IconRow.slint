// IconRow — Scrollable row of icon tiles for one category.

import { Spacing } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";
import { IconTile } from "IconTile.slint";

/// I co nr ow component.
/// component `IconRow`.
export component IconRow inherits Flickable {
    /// Input property "icons".
    /// property `icons`.
    in property <[{glyph: string, name: string}]> icons;
    height: Sizes.thumb-sm;
    viewport-width: row-layout.preferred-width;
    viewport-height: self.height;

    row-layout := HorizontalLayout {
        spacing: Spacing.xs;
        for icon in root.icons: IconTile {
            icon-glyph: icon.glyph;
            icon-name:  icon.name;
        }
    }
}
