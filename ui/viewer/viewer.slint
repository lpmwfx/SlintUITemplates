// FrameworkViewer — browse and verify all SlintUI widgets in one window.
// Dog-foods our own components; topbar writes to Colors/Settings globals live.

import { Colors, Spacing, FluentIcons, Settings } from "../tokens/theme.slint";
import { SideBar }       from "../desktop/side-bar.slint";
import { NavItem }       from "../desktop/types.slint";
import { ViewerTopbar }  from "viewer-topbar.slint";
import { PageButtons }   from "page-buttons.slint";
import { PageInputs }    from "page-inputs.slint";
import { PageDisplay }   from "page-display.slint";
import { PageFeedback }  from "page-feedback.slint";
import { PageLayout }    from "page-layout.slint";
import { PageAppShell }  from "page-app-shell.slint";
import { PageIcons }     from "page-icons.slint";
import { PageSelection } from "page-selection.slint";
import { PageNavigation }from "page-navigation.slint";
import { PageData }      from "page-data.slint";
import { PageCanvas }    from "page-canvas.slint";

export component FrameworkViewer inherits Window {
    preferred-width:  1100px;
    preferred-height: 720px;
    title: "SlintUI Framework Viewer";

    in-out property <string> active-view: "buttons";
    in property <image> canvas-frame;

    background: Colors.bg-primary;

    callback request-bg-style(string);
    callback new-file();
    callback new-window();
    callback open-file();
    callback save();
    callback save-as();
    callback quit();
    callback undo();
    callback redo();
    callback cut();
    callback copy();
    callback paste();
    callback find();
    callback select-all();
    callback open-docs();
    callback open-shortcuts();
    callback about();

    MenuBar {
        Menu {
            title: "File";
            MenuItem { title: "New";          activated => { root.new-file(); } }
            MenuItem { title: "New Window";   activated => { root.new-window(); } }
            MenuItem { title: "Open...";      activated => { root.open-file(); } }
            MenuSeparator {}
            MenuItem { title: "Save";         activated => { root.save(); } }
            MenuItem { title: "Save As...";   activated => { root.save-as(); } }
            MenuSeparator {}
            MenuItem { title: "Exit";         activated => { root.quit(); } }
        }
        Menu {
            title: "Edit";
            MenuItem { title: "Undo";         activated => { root.undo(); } }
            MenuItem { title: "Redo";         activated => { root.redo(); } }
            MenuSeparator {}
            MenuItem { title: "Cut";          activated => { root.cut(); } }
            MenuItem { title: "Copy";         activated => { root.copy(); } }
            MenuItem { title: "Paste";        activated => { root.paste(); } }
            MenuSeparator {}
            MenuItem { title: "Find...";      activated => { root.find(); } }
            MenuItem { title: "Select All";   activated => { root.select-all(); } }
        }
        Menu {
            title: "View";
            MenuItem { title: "Buttons";    activated => { root.active-view = "buttons"; } }
            MenuItem { title: "Inputs";     activated => { root.active-view = "inputs"; } }
            MenuItem { title: "Display";    activated => { root.active-view = "display"; } }
            MenuItem { title: "Feedback";   activated => { root.active-view = "feedback"; } }
            MenuItem { title: "Layout";     activated => { root.active-view = "layout"; } }
            MenuItem { title: "App Shell";  activated => { root.active-view = "app-shell"; } }
            MenuItem { title: "Icons";      activated => { root.active-view = "icons"; } }
            MenuItem { title: "Selection";  activated => { root.active-view = "selection"; } }
            MenuItem { title: "Navigation"; activated => { root.active-view = "navigation"; } }
            MenuItem { title: "Data";       activated => { root.active-view = "data"; } }
            MenuItem { title: "Canvas";     activated => { root.active-view = "canvas"; } }
            MenuSeparator {}
            MenuItem { title: "Dark Mode";  activated => { Colors.dark-mode = !Colors.dark-mode; } }
            MenuSeparator {}
            MenuItem { title: "Zoom 75%";   activated => { Settings.zoom = 0.75; } }
            MenuItem { title: "Zoom 100%";  activated => { Settings.zoom = 1.0; } }
            MenuItem { title: "Zoom 125%";  activated => { Settings.zoom = 1.25; } }
            MenuItem { title: "Zoom 150%";  activated => { Settings.zoom = 1.5; } }
        }
        Menu {
            title: "Help";
            MenuItem { title: "Documentation";      activated => { root.open-docs(); } }
            MenuItem { title: "Keyboard Shortcuts"; activated => { root.open-shortcuts(); } }
            MenuSeparator {}
            MenuItem { title: "About";              activated => { root.about(); } }
        }
    }

    VerticalLayout {
        ViewerTopbar { request-bg-style(s) => { root.request-bg-style(s); } }

        HorizontalLayout {
            vertical-stretch: 1;

            SideBar {
                horizontal-stretch: 0;
                min-width: Spacing.xl * 4 + Spacing.md;
                max-width: Spacing.xl * 4 + Spacing.md;
                active-item: root.active-view;
                items: [
                    { id: "buttons",    label: "Buttons",    icon: FluentIcons.apps },
                    { id: "inputs",     label: "Inputs",     icon: FluentIcons.edit },
                    { id: "display",    label: "Display",    icon: FluentIcons.list },
                    { id: "feedback",   label: "Feedback",   icon: FluentIcons.notification },
                    { id: "layout",     label: "Layout",     icon: FluentIcons.layout },
                    { id: "app-shell",  label: "App Shell",  icon: FluentIcons.panel-left },
                    { id: "icons",      label: "Icons",      icon: FluentIcons.star },
                    { id: "selection",  label: "Selection",  icon: FluentIcons.checkmark },
                    { id: "navigation", label: "Navigation", icon: FluentIcons.list },
                    { id: "data",       label: "Data",       icon: FluentIcons.grid },
                    { id: "canvas",     label: "Canvas",     icon: FluentIcons.image },
                ];
                navigate(id) => { root.active-view = id; }
                toggle-collapsed() => {}
            }

            if root.active-view == "app-shell": PageAppShell { horizontal-stretch: 1; }

            if root.active-view != "app-shell": Rectangle {
                horizontal-stretch: 1;
                background: Colors.bg-surface;

                Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-width:  self.width;
                    viewport-height: pg.preferred-height;

                    pg := VerticalLayout {
                        padding: Spacing.md;
                        spacing: Spacing.md;
                        if root.active-view == "buttons":    PageButtons    {}
                        if root.active-view == "inputs":     PageInputs     {}
                        if root.active-view == "display":    PageDisplay    {}
                        if root.active-view == "feedback":   PageFeedback   {}
                        if root.active-view == "layout":     PageLayout     {}
                        if root.active-view == "icons":      PageIcons      {}
                        if root.active-view == "selection":  PageSelection  {}
                        if root.active-view == "navigation": PageNavigation {}
                        if root.active-view == "data":       PageData       { window-height: root.height; }
                        if root.active-view == "canvas":     PageCanvas     { canvas-frame: root.canvas-frame; }
                    }
                }
            }
        }
    }
}
