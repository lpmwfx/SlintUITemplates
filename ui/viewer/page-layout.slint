// page-layout — showcases DragHandle (live-draggable), PanelContainer, PanelSlot,
// bi-directional 3-panel layout, Divider, and ScrollView.

import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { DragHandle }                from "../modules/DragHandle.slint";
import { PanelContainer, PanelItem } from "../modules/PanelContainer.slint";
import { PanelSlot }                 from "../modules/PanelSlot.slint";
import { ViewSlot }                  from "../modules/ViewSlot.slint";
import { Button }                    from "../shared/button.slint";
import { Divider }                   from "../shared/divider.slint";
import { ScrollView }                from "../shared/scroll-view.slint";
import { ViewerSection } from "viewer-section.slint";

// Demo box with a live column drag handle.
component ColHandleDemo inherits Rectangle {
    private property <length> split: 100px;

    width: 220px;
    height: 80px;
    border-width: 1px;
    border-color: Colors.border;
    clip: true;

    HorizontalLayout {
        Rectangle { width: root.split; background: Colors.bg-surface; }
        DragHandle {
            min-width: Spacing.handle-thickness;
            max-width: Spacing.handle-thickness;
            vertical: false;
            dragged(dx, dy) => { root.split = clamp(root.split + dx * 1px, 20px, 180px); }
        }
        Rectangle { horizontal-stretch: 1; background: Colors.bg-elevated; }
    }
}

// Demo box with a live row drag handle.
component RowHandleDemo inherits Rectangle {
    private property <length> split: 40px;

    width: 220px;
    height: 80px;
    border-width: 1px;
    border-color: Colors.border;
    clip: true;

    VerticalLayout {
        Rectangle { height: root.split; background: Colors.bg-surface; }
        DragHandle {
            min-height: Spacing.handle-thickness;
            max-height: Spacing.handle-thickness;
            vertical: true;
            dragged(dx, dy) => { root.split = clamp(root.split + dy * 1px, 10px, 60px); }
        }
        Rectangle { vertical-stretch: 1; background: Colors.bg-elevated; }
    }
}

// Bi-directional 3-panel demo — drag either handle, both neighbors update.
// Ratio math: ratio_a + ratio_b + ratio_c = 1.0 always (zero-sum flex).
component BiDirDemo inherits Rectangle {
    // Panel ratios — normalized to sum 1.0.  Min per panel: 0.1
    private property <float> ratio-a: 0.25;
    private property <float> ratio-b: 0.50;
    private property <float> ratio-c: 0.25;

    width: 360px;
    height: 100px;
    border-width: 1px;
    border-color: Colors.border;
    clip: true;

    HorizontalLayout {
        // Panel A
        Rectangle {
            horizontal-stretch: 0;
            min-width: root.width * root.ratio-a;
            max-width: root.width * root.ratio-a;
            background: Colors.bg-surface;
            Text {
                text: "A " + Math.round(root.ratio-a * 100) + "%";
                font-size: Type.caption-size;
                color: Colors.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Handle A–B: drag transfers ratio between A and B, C stays fixed.
        DragHandle {
            min-width: Spacing.handle-thickness;
            max-width: Spacing.handle-thickness;
            vertical: false;
            dragged(dx, dy) => {
                root.ratio-a = clamp(root.ratio-a + dx / (root.width / 1px), 0.1, 1.0 - root.ratio-c - 0.1);
                root.ratio-b = 1.0 - root.ratio-a - root.ratio-c;
            }
        }

        // Panel B
        Rectangle {
            horizontal-stretch: 0;
            min-width: root.width * root.ratio-b;
            max-width: root.width * root.ratio-b;
            background: Colors.accent.with-alpha(0.12);
            Text {
                text: "B " + Math.round(root.ratio-b * 100) + "%";
                font-size: Type.caption-size;
                color: Colors.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Handle B–C: drag transfers ratio between B and C, A stays fixed.
        DragHandle {
            min-width: Spacing.handle-thickness;
            max-width: Spacing.handle-thickness;
            vertical: false;
            dragged(dx, dy) => {
                root.ratio-c = clamp(root.ratio-c - dx / (root.width / 1px), 0.1, 1.0 - root.ratio-a - 0.1);
                root.ratio-b = 1.0 - root.ratio-a - root.ratio-c;
            }
        }

        // Panel C
        Rectangle {
            horizontal-stretch: 1;
            background: Colors.bg-elevated;
            Text {
                text: "C " + Math.round(root.ratio-c * 100) + "%";
                font-size: Type.caption-size;
                color: Colors.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component PageLayout inherits VerticalLayout {
    spacing: Spacing.md;
    private property <string> active-slot: "alpha";

    ViewerSection {
        title: "DragHandle";
        HorizontalLayout {
            spacing: Spacing.lg;
            alignment: start;
            ColHandleDemo {}
            RowHandleDemo {}
        }
    }

    ViewerSection {
        title: "Bi-directional 3-panel (drag either handle — both neighbors update)";
        BiDirDemo {}
    }

    ViewerSection {
        title: "PanelContainer (3 panels)";
        PanelContainer {
            width: 400px;
            height: 180px;
            panels: [
                { id: 0, kind: "panel",    label: "Panel A", x: 0.0,  y: 0.0,  w: 0.45, h: 1.0  },
                { id: 1, kind: "handle-h", label: "",        x: 0.45, y: 0.0,  w: 0.05, h: 1.0  },
                { id: 2, kind: "panel",    label: "Panel B", x: 0.5,  y: 0.0,  w: 0.5,  h: 0.5  },
                { id: 3, kind: "handle-v", label: "",        x: 0.5,  y: 0.5,  w: 0.5,  h: 0.05 },
                { id: 4, kind: "panel",    label: "Panel C", x: 0.5,  y: 0.55, w: 0.5,  h: 0.45 },
            ];
        }
    }

    ViewerSection {
        title: "PanelSlot (standalone)";
        PanelSlot {
            width: 200px;
            height: 80px;
            panel-id: 99;
            label: "Standalone slot";
        }
    }

    ViewerSection {
        title: "ViewSlot — slot-id routing (click nav to switch view)";

        VerticalLayout {
            spacing: Spacing.sm;
            width: 360px;

            // Nav buttons
            HorizontalLayout {
                spacing: Spacing.sm;
                alignment: start;
                Button {
                    label: "Alpha";
                    variant: root.active-slot == "alpha" ? "primary" : "secondary";
                    clicked => { root.active-slot = "alpha"; }
                }
                Button {
                    label: "Beta";
                    variant: root.active-slot == "beta" ? "primary" : "secondary";
                    clicked => { root.active-slot = "beta"; }
                }
                Button {
                    label: "Gamma";
                    variant: root.active-slot == "gamma" ? "primary" : "secondary";
                    clicked => { root.active-slot = "gamma"; }
                }
            }

            // Slot content area
            Rectangle {
                height: 80px;
                border-width: 1px;
                border-color: Colors.border;
                background: Colors.bg-surface;
                clip: true;

                ViewSlot {
                    slot-id: "alpha";
                    active: root.active-slot;
                    width: 100%; height: 100%;
                    Text {
                        text: "slot-id: \"alpha\" — visible when active == \"alpha\"";
                        color: Colors.text-primary;
                        font-size: Type.body-size;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                ViewSlot {
                    slot-id: "beta";
                    active: root.active-slot;
                    width: 100%; height: 100%;
                    background: Colors.accent.with-alpha(0.10);
                    Text {
                        text: "slot-id: \"beta\"";
                        color: Colors.accent;
                        font-size: Type.body-size;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                ViewSlot {
                    slot-id: "gamma";
                    active: root.active-slot;
                    width: 100%; height: 100%;
                    background: Colors.bg-elevated;
                    Text {
                        text: "slot-id: \"gamma\"";
                        color: Colors.text-secondary;
                        font-size: Type.body-size;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    ViewerSection {
        title: "Divider";
        VerticalLayout {
            spacing: Spacing.md;
            width: 320px;

            // Horizontal, no label
            Divider { width: 100%; height: Spacing.xs; }

            // Horizontal with label
            Divider { width: 100%; height: Spacing.lg; label: "Section"; }

            // Vertical pair
            HorizontalLayout {
                height: Spacing.xl;
                spacing: Spacing.sm;
                Text { text: "Left";  font-size: Type.body-size; color: Colors.text-secondary; vertical-alignment: center; }
                Divider { orientation: "vertical"; width: Spacing.xs; height: Spacing.xl; }
                Text { text: "Right"; font-size: Type.body-size; color: Colors.text-secondary; vertical-alignment: center; }
            }
        }
    }

    ViewerSection {
        title: "ScrollView";
        ScrollView {
            width: 280px;
            height: 100px;

            VerticalLayout {
                padding: Spacing.sm;
                spacing: Spacing.sm;
                width: 280px;

                for i in [1, 2, 3, 4, 5, 6, 7, 8]: Rectangle {
                    height: Spacing.xl;
                    border-radius: Spacing.xs;
                    background: Colors.bg-elevated;
                    border-width: 1px;
                    border-color: Colors.border;

                    Text {
                        x: Spacing.sm;
                        text: "Row " + i;
                        font-size: Type.body-size;
                        color: Colors.text-primary;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
