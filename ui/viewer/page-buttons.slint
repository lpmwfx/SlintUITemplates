// page-buttons — showcases Button (all variants) and Toggle.

import { Spacing } from "../globals/theme.slint";
import { Variants } from "../globals/variants.slint";
import { Button }  from "../widgets/button.slint";
import { Toggle }  from "../widgets/toggle.slint";
import { ViewerSection } from "viewer-section.slint";

/// Viewer page showcasing button variants and toggle controls.
/// component `PageButtons`.
/// component `PageButtons`.
/// component `PageButtons`.
/// component `PageButtons`.
/// component `PageButtons`.
/// component `PageButtons`.
/// component `PageButtons`.
export component PageButtons inherits VerticalLayout {
    spacing: Spacing.md;

    /// Private property "t1" used internally.
    /// property `t1`.
    /// property `t1`.
    /// property `t1`.
    /// property `t1`.
    /// property `t1`.
    /// property `t1`.
    /// property `t1`.
    private property <bool> t1: true;
    /// Private property "t2" used internally.
    /// property `t2`.
    /// property `t2`.
    /// property `t2`.
    /// property `t2`.
    /// property `t2`.
    /// property `t2`.
    /// property `t2`.
    private property <bool> t2: false;
    /// Private property "t3" used internally.
    /// property `t3`.
    /// property `t3`.
    /// property `t3`.
    /// property `t3`.
    /// property `t3`.
    /// property `t3`.
    /// property `t3`.
    private property <bool> t3: true;
    /// Private property "section-button" used internally.
    /// property `section-button`.
    /// property `section-button`.
    /// property `section-button`.
    /// property `section-button`.
    /// property `section-button`.
    /// property `section-button`.
    /// property `section-button`.
    private property <string> section-button: "Button";
    /// Private property "section-toggle" used internally.
    /// property `section-toggle`.
    /// property `section-toggle`.
    /// property `section-toggle`.
    /// property `section-toggle`.
    /// property `section-toggle`.
    /// property `section-toggle`.
    /// property `section-toggle`.
    private property <string> section-toggle: "Toggle";

    ViewerSection {
        title: root.section-button;
        HorizontalLayout {
            spacing: Spacing.sm;
            Button { label: "Primary";   variant: Variants.primary; }
            Button { label: "Secondary"; variant: Variants.secondary; }
            Button { label: "Ghost";     variant: Variants.ghost; }
            Button { label: "Danger";    variant: Variants.danger; }
            Button { label: "Disabled";  variant: Variants.primary; enabled: false; }
        }
    }

    ViewerSection {
        title: root.section-toggle;
        HorizontalLayout {
            spacing: Spacing.lg;
            alignment: start;
            Toggle { checked: root.t1; label: "Animations"; toggled(v) => { root.t1 = v; } }
            Toggle { checked: root.t2; label: "Auto-save";  toggled(v) => { root.t2 = v; } }
            Toggle { checked: root.t3;                      toggled(v) => { root.t3 = v; } }
        }
    }
}
