// page-icons — Fluent icon catalog.
// Shows all FluentIcons entries with their names in scrollable rows per category.

import { Colors, Spacing, Type, FluentIcons } from "../tokens/theme.slint";
import { ViewerSection } from "viewer-section.slint";

// Single icon tile — glyph + name label.
component IconTile inherits Rectangle {
    in property <string> icon-glyph;
    in property <string> icon-name;

    min-width: 80px;
    height: 72px;
    border-radius: 4px;
    background: tile-ta.has-hover ? Colors.bg-elevated : transparent;
    border-width: tile-ta.has-hover ? 1px : 0px;
    border-color: Colors.border;

    tile-ta := TouchArea {}

    VerticalLayout {
        alignment: center;
        spacing: Spacing.xs;
        padding: Spacing.xs;

        Text {
            text: root.icon-glyph;
            font-family: "Segoe Fluent Icons";
            font-size: 24px;
            color: Colors.text-primary;
            horizontal-alignment: center;
        }

        Text {
            text: root.icon-name;
            font-size: 9px;
            color: Colors.text-secondary;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}

// Scrollable row of icon tiles for one category.
component IconRow inherits Flickable {
    in property <[{glyph: string, name: string}]> icons;
    height: 80px;
    viewport-width: row-layout.preferred-width;
    viewport-height: self.height;

    row-layout := HorizontalLayout {
        spacing: Spacing.xs;
        for icon in root.icons: IconTile {
            icon-glyph: icon.glyph;
            icon-name:  icon.name;
        }
    }
}

export component PageIcons inherits VerticalLayout {
    spacing: Spacing.sm;

    ViewerSection { title: "Navigation"; }
    IconRow {
        icons: [
