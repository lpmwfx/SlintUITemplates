// page-app-shell — live demo of AppShell (Windows) and MobileShell (Android).
// Toggle between platforms to see Fluent 2 vs Material 3 shell.

import { Colors, Spacing, Type, FluentIcons } from "../tokens/theme.slint";
import { AppShell, MobileShell } from "../shell/app-shell.slint";
import { ShellMenu }    from "../shell/types.slint";
import { NavItem }      from "../desktop/types.slint";
import { Button }       from "../shared/button.slint";
import { HomeView }     from "../views/home.slint";
import { ListView }     from "../views/list.slint";
import { SettingsView } from "../views/settings.slint";

export component PageAppShell inherits VerticalLayout {
    private property <string>    layout-mode: "windows";
    private property <string>    active-view: "home";

    private property <[NavItem]> nav-items: [
        { id: "home",     label: "Home",     icon: FluentIcons.home },
        { id: "list",     label: "List",     icon: FluentIcons.list },
        { id: "settings", label: "Settings", icon: FluentIcons.settings },
    ];

    private property <[ShellMenu]> menus: [
        { id: "file", label: "File" },
        { id: "edit", label: "Edit" },
        { id: "view", label: "View" },
        { id: "help", label: "Help" },
    ];

    // Control bar
    Rectangle {
        height: Spacing.xl;
        background: Colors.bg-surface;
        HorizontalLayout {
            padding-left: Spacing.md;
            padding-right: Spacing.md;
            spacing: Spacing.sm;
            Text {
                text: root.layout-mode == "windows" ? "App Shell — Windows (Fluent 2)" : "App Shell — Android (Material 3)";
                font-size: Type.subtitle-size;
                font-weight: Type.weight-semibold;
                color: Colors.text-primary;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                label: root.layout-mode == "windows" ? "→ Android" : "→ Windows";
                variant: "secondary";
                clicked => {
                    root.layout-mode = root.layout-mode == "windows" ? "android" : "windows";
                    root.active-view = "home";
                }
            }
        }
    }

    // ── Windows: AppShell (Fluent 2 desktop) ──────────────────────────────
    if root.layout-mode == "windows": AppShell {
        vertical-stretch: 1;
        nav-items: root.nav-items;
        menus: root.menus;
        status-text: "Active: " + root.active-view;
        active-slot <=> root.active-view;
        slot-changed(id) => { root.active-view = id; }

        if root.active-view == "home":     HomeView     { vertical-stretch: 1; }
        if root.active-view == "list":     ListView     { vertical-stretch: 1; }
        if root.active-view == "settings": SettingsView { vertical-stretch: 1; }
    }

    // ── Android: MobileShell (Material 3) — centered phone frame ─────────
    if root.layout-mode == "android": Rectangle {
        vertical-stretch: 1;
        background: Colors.bg-primary;

        // Phone frame (simulated)
        Rectangle {
            width: 380px;
            height: parent.height;
            x: (parent.width - self.width) / 2;
            border-width: 2px;
            border-color: Colors.border-strong;

            MobileShell {
                title: "App";
                nav-items: root.nav-items;
                active-view: root.active-view;
                fab-icon: FluentIcons.add;
                show-fab: true;
                navigate(id) => { root.active-view = id; }

                if root.active-view == "home":     HomeView     { vertical-stretch: 1; }
                if root.active-view == "list":     ListView     { vertical-stretch: 1; }
                if root.active-view == "settings": SettingsView { vertical-stretch: 1; }
            }
        }
    }
}
