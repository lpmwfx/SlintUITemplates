import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes }                   from "../state/sizes.slint";
import { DragHandle }              from "../modules/DragHandle.slint";

// Demo box with a live row drag handle.
component RowHandleDemo inherits Rectangle {
    /// Private property "split" used internally.
    /// property `split`.
    private property <length> split: Sizes.comp-40;
    /// Private property "split-max" used internally.
    /// property `split-max`.
    private property <length> split-max: Sizes.comp-60;

    width: Sizes.panel-md;
    height: Sizes.thumb-sm;
    border-width: Sizes.border-w;
    border-color: Colors.border;
    clip: true;

    VerticalLayout {
        Rectangle { height: root.split; background: Colors.bg-surface; }
        DragHandle {
            min-height: Spacing.handle-thickness;
            max-height: Spacing.handle-thickness;
            vertical: true;
            dragged(dx, dy) => { root.split = clamp(root.split + dy * Sizes.border-w, Sizes.glyph-sm, root.split-max); }
        }
        Rectangle { vertical-stretch: Sizes.one; background: Colors.bg-elevated; }
    }
}
