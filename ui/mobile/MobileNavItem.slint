import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";

// MobileNavItem — a single nav item in the mobile bottom tab bar.
/// M ob il en av it em component.
/// component `MobileNavItem`.
