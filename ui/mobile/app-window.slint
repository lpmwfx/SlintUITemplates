import { Colors, Spacing } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { NavId }       from "../state/nav-id.slint";
import { NavBar }      from "../desktop/views/nav-bar.slint";
import { ContentArea } from "../desktop/views/content-area.slint";
import { StatusBar }   from "../desktop/views/status-bar.slint";
import { NavItem }     from "../desktop/types.slint";
import { MobileNavItem } from "parts/MobileNavItem.slint";

export { NavItem }

/// A pp wi nd ow component.
/// component `AppWindow`.
/// component `AppWindow`.
/// component `AppWindow`.
/// component `AppWindow`.
/// component `AppWindow`.
/// component `AppWindow`.
/// component `AppWindow`.
export component AppWindow inherits Window {
    preferred-width: Sizes.mobile-width;
    preferred-height: Sizes.mobile-height;
    title: root.window-title;
    background: Colors.bg-primary;

    /// Input property "window-title".
    /// property `window-title`.
    /// property `window-title`.
    /// property `window-title`.
    /// property `window-title`.
    /// property `window-title`.
    /// property `window-title`.
    /// property `window-title`.
    in property <string> window-title: "SlintUITemplates \u{2014} Mobile";
    /// Private property "icon-home" used internally.
    /// property `icon-home`.
    /// property `icon-home`.
    /// property `icon-home`.
    /// property `icon-home`.
    /// property `icon-home`.
    /// property `icon-home`.
    /// property `icon-home`.
    private property <string> icon-home: "\u{1F3E0}";
    /// Private property "icon-list" used internally.
    /// property `icon-list`.
    /// property `icon-list`.
    /// property `icon-list`.
    /// property `icon-list`.
    /// property `icon-list`.
    /// property `icon-list`.
    /// property `icon-list`.
    private property <string> icon-list: "\u{1F4CB}";
    /// Private property "icon-settings" used internally.
    /// property `icon-settings`.
    /// property `icon-settings`.
    /// property `icon-settings`.
    /// property `icon-settings`.
    /// property `icon-settings`.
    /// property `icon-settings`.
    /// property `icon-settings`.
    private property <string> icon-settings: "\u{2699}";
    /// Private property "status-prefix" used internally.
    /// property `status-prefix`.
    /// property `status-prefix`.
    /// property `status-prefix`.
    /// property `status-prefix`.
    /// property `status-prefix`.
    /// property `status-prefix`.
    /// property `status-prefix`.
    private property <string> status-prefix: "View: ";

    property <string>    active-view: NavId.home;
    /// Input property "nav-items".
    /// property `nav-items`.
    /// property `nav-items`.
    /// property `nav-items`.
    /// property `nav-items`.
    /// property `nav-items`.
    /// property `nav-items`.
    /// property `nav-items`.
    in property <[NavItem]> nav-items: [
        { id: NavId.home,     label: "Home",     icon: root.icon-home },
        { id: NavId.list,     label: "List",     icon: root.icon-list },
        { id: NavId.settings, label: "Settings", icon: root.icon-settings },
    ];

    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    callback navigate(string);
    navigate(view) => { self.active-view = view; }

    VerticalLayout {
        // Top nav bar
        NavBar {
            breadcrumb: root.active-view;
            can-go-back: root.active-view != NavId.home;
            go-back => { root.active-view = NavId.home; }
        }

        // Content area fills remaining space
        ContentArea {
            vertical-stretch: Sizes.one;
            active-view: root.active-view;
            navigate(view) => { root.active-view = view; }
        }

        // Inline tab bar
        Rectangle {
            height: Spacing.xl + Spacing.sm;
            background: Colors.bg-surface;

            HorizontalLayout {
                for item in root.nav-items: MobileNavItem {
                    item-id: item.id;
                    icon: item.icon;
                    label: item.label;
                    is-active: item.id == root.active-view;
                    clicked => { root.active-view = item.id; }
                }
            }
        }

        // Status bar
        StatusBar {
            status-text: root.status-prefix + root.active-view;
        }
    }
}
