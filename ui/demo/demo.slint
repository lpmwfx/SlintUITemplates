import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes }         from "../tokens/sizes.slint";
import { Variants }      from "../globals/Variants.slint";
import { NavId }         from "../globals/NavId.slint";
import { NavBar }        from "../desktop/nav-bar.slint";
import { SideBar }       from "../desktop/side-bar.slint";
import { StatusBar }     from "../desktop/status-bar.slint";
import { NavItem }       from "../desktop/types.slint";
import { DragHandle }    from "../modules/DragHandle.slint";
import { Button }        from "../widgets/button.slint";
import { Toggle }        from "../widgets/toggle.slint";
import { HomeView }      from "../views/home.slint";
import { ListView }      from "../views/list.slint";
import { SettingsView }  from "../views/settings.slint";
import { DemoMobileNav }    from "DemoMobileNav.slint";
import { MobilePhoneFrame } from "MobilePhoneFrame.slint";

/// D em ow in do w component.
export component DemoWindow inherits Window {
    preferred-width: Sizes.win-width-md;
    preferred-height: Sizes.win-height-md;
    /// Input property "window-title".
    in property <string> window-title: "SlintUITemplates \u{2014} Phase 2 Demo";
    title: window-title;
    background: Colors.bg-primary;

    /// Two-way property "layout-mode".
    in-out property <string>    layout-mode: Variants.desktop;
    /// Two-way property "active-view".
    in-out property <string>    active-view: NavId.home;
    /// Two-way property "sidebar-collapsed".
    in-out property <bool>      sidebar-collapsed: false;
    /// Two-way property "nav-items".
    in-out property <[NavItem]> nav-items: [
        { id: NavId.home, label: "Home", icon: "\u{1F3E0}" },
        { id: NavId.list, label: "List", icon: "\u{1F4CB}" },
        { id: NavId.settings, label: "Settings", icon: "⚙" },
    ];

    property <length> mobile-frame-width:      Spacing.xl * Sizes.eight + Spacing.md + Spacing.sm;
    property <length> sidebar-expanded-width:  Spacing.xl * Sizes.four + Spacing.md;
    property <length> sidebar-collapsed-width: Spacing.xl + Spacing.sm;
    /// Two-way property "col-left-width".
    in-out property <length> col-left-width:   Spacing.xl * Sizes.four + Spacing.md;

    /// Input property "control-bar-label".
    in property <string> control-bar-label: "SlintUI \u{2014} Phase 2 Demo";
    /// Input property "switch-to-mobile-label".
    in property <string> switch-to-mobile-label: "Switch to Mobile";
    /// Input property "switch-to-desktop-label".
    in property <string> switch-to-desktop-label: "Switch to Desktop";
    /// Input property "dark-label".
    in property <string> dark-label: "Dark";
    /// Input property "status-prefix".
    in property <string> status-prefix: "View: ";

    VerticalLayout {
        // Control bar
        Rectangle {
            height: Spacing.xl;
            background: Colors.bg-surface;
            HorizontalLayout {
                padding-left: Spacing.md;
                padding-right: Spacing.md;
                spacing: Spacing.sm;
                Text {
                    text: root.control-bar-label;
                    font-size: Type.subtitle-size;
                    font-weight: Type.weight-semibold;
                    color: Colors.text-primary;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: Sizes.one; }
                Button {
                    label: root.layout-mode == Variants.desktop ? root.switch-to-mobile-label : root.switch-to-desktop-label;
                    variant: Variants.secondary;
                    clicked => { root.layout-mode = root.layout-mode == Variants.desktop ? Variants.mobile : Variants.desktop; }
                }
                Toggle { label: root.dark-label; checked: Colors.dark-mode; toggled(v) => { Colors.dark-mode = v; } }
            }
        }

        // Desktop layout
        if root.layout-mode == Variants.desktop: HorizontalLayout {
            vertical-stretch: Sizes.one;
            SideBar {
                horizontal-stretch: Sizes.zero;
                min-width: root.sidebar-collapsed ? root.sidebar-collapsed-width : root.col-left-width;
                max-width: root.sidebar-collapsed ? root.sidebar-collapsed-width : root.col-left-width;
                items: root.nav-items;
                active-item: root.active-view;
                collapsed: root.sidebar-collapsed;
                navigate(id) => { root.active-view = id; }
                toggle-collapsed() => { root.sidebar-collapsed = !root.sidebar-collapsed; }
            }
            DragHandle {
                min-width: Spacing.handle-thickness;
                max-width: Spacing.handle-thickness;
                vertical: false;
                dragged(dx, dy) => {
                    root.col-left-width = clamp(root.col-left-width + dx * Sizes.border-w, root.sidebar-collapsed-width, Sizes.panel-xl);
                }
            }
            VerticalLayout {
                horizontal-stretch: Sizes.one;
                NavBar { breadcrumb: root.active-view; can-go-back: root.active-view != NavId.home; go-back => { root.active-view = NavId.home; } }
                if root.active-view == NavId.home:     HomeView     { vertical-stretch: Sizes.one; }
                if root.active-view == NavId.list:     ListView     { vertical-stretch: Sizes.one; }
                if root.active-view == NavId.settings: SettingsView { vertical-stretch: Sizes.one; }
                StatusBar { status-text: root.status-prefix + root.active-view; }
            }
        }

        // Mobile layout — centered frame
        if root.layout-mode == Variants.mobile: Rectangle {
            vertical-stretch: Sizes.one;
            background: Colors.bg-primary;
            MobilePhoneFrame {
                width: root.mobile-frame-width;
                height: parent.height;
                x: (parent.width - self.width) / Sizes.two;
                active-view: root.active-view;
                items: root.nav-items;
                status-prefix: root.status-prefix;
                navigate(id) => { root.active-view = id; }
            }
        }
    }
}
