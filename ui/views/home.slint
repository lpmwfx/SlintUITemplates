import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Card }   from "../shared/card.slint";
import { Badge }  from "../shared/badge.slint";
import { Button } from "../shared/button.slint";

// Designer-editable home view.
// Preview: slint-viewer ui/desktop/app-window.slint --auto-reload
export component HomeView inherits Rectangle {
    background: Colors.bg-primary;

    VerticalLayout {
        padding: Spacing.lg;
        spacing: Spacing.md;
        alignment: start;

        Text {
            text: "Home";
            font-size: Type.heading-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
        }

        Card {
            title: "Getting started";
            subtitle: "Edit ui/views/home.slint to design this view";
        }

        HorizontalLayout {
            spacing: Spacing.sm;
            Button { label: "Primary action"; variant: "primary"; clicked => {} }
            Button { label: "Secondary"; variant: "secondary"; clicked => {} }
            Badge { text: "New"; variant: "info"; }
        }
    }
}
