import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Toggle } from "../shared/toggle.slint";
import { Button } from "../shared/button.slint";

// Designer-editable settings view.
// Preview: slint-viewer ui/desktop/app-window.slint --auto-reload
export component SettingsView inherits Rectangle {
    background: Colors.bg-primary;

    VerticalLayout {
        padding: Spacing.lg;
        spacing: Spacing.md;
        alignment: start;

        Text {
            text: "Settings";
            font-size: Type.heading-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
        }

        Toggle { label: "Enable notifications"; checked: true;  toggled(v) => {} }
        Toggle { label: "Auto-save";            checked: false; toggled(v) => {} }
        Toggle { label: "Show sidebar on start"; checked: true; toggled(v) => {} }

        HorizontalLayout {
            spacing: Spacing.sm;
            Button { label: "Save Changes"; variant: "primary";   clicked => {} }
            Button { label: "Reset";        variant: "secondary"; clicked => {} }
        }
    }
}
