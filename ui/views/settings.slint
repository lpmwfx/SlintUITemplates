import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Variants } from "../state/variants.slint";
import { Toggle } from "../widgets/toggle.slint";
import { Button } from "../widgets/button.slint";

/// Starter settings page for the `settings` navigation slot.
///
/// Shows basic toggle controls and action buttons for shell demos.
/// component `SettingsView`.
export component SettingsView inherits Rectangle {
    background: Colors.bg-primary;
    /// Private property "page-title" used internally.
    /// property `page-title`.
    private property <string> page-title: "Settings";

    VerticalLayout {
        padding: Spacing.lg;
        spacing: Spacing.md;
        alignment: start;

        Text {
            text: root.page-title;
            font-size: Type.heading-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
        }

        Toggle { label: "Enable notifications"; checked: true;  toggled(v) => {} }
        Toggle { label: "Auto-save";            checked: false; toggled(v) => {} }
        Toggle { label: "Show sidebar on start"; checked: true; toggled(v) => {} }

        HorizontalLayout {
            spacing: Spacing.sm;
            Button { label: "Save Changes"; variant: Variants.primary;   clicked => {} }
            Button { label: "Reset";        variant: Variants.secondary; clicked => {} }
        }
    }
}
