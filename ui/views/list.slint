import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { ListItem } from "../widgets/list-item.slint";

/// Starter list page for the `list` navigation slot.
///
/// Demonstrates a simple header plus repeated `ListItem` rows.
/// component `ListView`.
/// component `ListView`.
/// component `ListView`.
/// component `ListView`.
/// component `ListView`.
/// component `ListView`.
/// component `ListView`.
export component ListView inherits Rectangle {
    background: Colors.bg-primary;

    /// Private property "header-title" used internally.
    /// property `header-title`.
    /// property `header-title`.
    /// property `header-title`.
    /// property `header-title`.
    /// property `header-title`.
    /// property `header-title`.
    /// property `header-title`.
    private property <string> header-title: "List";

    VerticalLayout {
        alignment: start;

        Rectangle {
            height: Spacing.xl;
            background: Colors.bg-surface;
            HorizontalLayout {
                padding-left: Spacing.md;
                Text {
                    text: root.header-title;
                    font-size: Type.subtitle-size;
                    font-weight: Type.weight-semibold;
                    color: Colors.text-primary;
                    vertical-alignment: center;
                }
            }
        }

        ListItem { title: "First item";  subtitle: "Subtitle text"; selected: true; }
        ListItem { title: "Second item"; subtitle: "Another subtitle"; }
        ListItem { title: "Third item"; }
        ListItem { title: "Fourth item"; subtitle: "Edit ui/views/list.slint"; }
    }
}
