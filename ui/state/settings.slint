// Settings — runtime configuration pushed from Rust AppSettings.
//
// AppAdapter::apply_settings() is the ONLY writer.
// Components read Settings.* for zoom, icon-style, icon-color, font-family, font-scale.
// AppWindow binds default-font-family to Settings.font-family.

/// S et ti ng s global values.
export global Settings {
    /// Two-way property "zoom".
    in-out property <float>  zoom:         1.0;
    /// Two-way property "icon-style".
    in-out property <string> icon-style:   "filled";   // "filled" | "outlined"
    /// Two-way property "icon-color".
    in-out property <string> icon-color:   "theme";    // "theme" | "accent" | "#rrggbb"
    /// Two-way property "font-family".
    in-out property <string> font-family:  "";         // "" = platform default
    /// Two-way property "font-scale".
    in-out property <float>  font-scale:   1.0;        // font-only multiplier on top of zoom
}
