// Settings — runtime configuration pushed from Rust AppSettings.
//
// AppAdapter::apply_settings() is the ONLY writer.
// Components read Settings.* for zoom, icon-style, icon-color, font-family, font-scale.
// AppWindow binds default-font-family to Settings.font-family.

/// S et ti ng s global values.
export global Settings {
    /// Input property "zoom".
    /// property `zoom`.
    /// property `zoom`.
    /// property `zoom`.
    /// property `zoom`.
    /// property `zoom`.
    /// property `zoom`.
    /// property `zoom`.
    in property <float>  zoom:         1.0;
    /// Input property "icon-style".
    /// property `icon-style`.
    /// property `icon-style`.
    /// property `icon-style`.
    /// property `icon-style`.
    /// property `icon-style`.
    /// property `icon-style`.
    /// property `icon-style`.
    in property <string> icon-style:   "filled";   // "filled" | "outlined"
    /// Input property "icon-color".
    /// property `icon-color`.
    /// property `icon-color`.
    /// property `icon-color`.
    /// property `icon-color`.
    /// property `icon-color`.
    /// property `icon-color`.
    /// property `icon-color`.
    in property <string> icon-color:   "theme";    // "theme" | "accent" | "#rrggbb"
    /// Input property "font-family".
    /// property `font-family`.
    /// property `font-family`.
    /// property `font-family`.
    /// property `font-family`.
    /// property `font-family`.
    /// property `font-family`.
    /// property `font-family`.
    in property <string> font-family:  "";         // "" = platform default
    /// Input property "font-scale".
    /// property `font-scale`.
    /// property `font-scale`.
    /// property `font-scale`.
    /// property `font-scale`.
    /// property `font-scale`.
    /// property `font-scale`.
    /// property `font-scale`.
    in property <float>  font-scale:   1.0;        // font-only multiplier on top of zoom
}
