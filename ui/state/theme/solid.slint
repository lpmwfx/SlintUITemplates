// Solid material palette — WinUI3 Fluent 2 exact values.
// Pure constants: no logic, no dark/light switching — Theme.slint selects.

/// S ol id global values.
export global Solid {
    // ── Dark ──────────────────────────────────────────────────────────────────
    /// Output property "dark-bg-primary".
    out property <color> dark-bg-primary:     #202020;
    /// Output property "dark-bg-surface".
    out property <color> dark-bg-surface:     #2C2C2C;
    /// Output property "dark-bg-elevated".
    out property <color> dark-bg-elevated:    #383838;
    /// Output property "dark-text-primary".
    out property <color> dark-text-primary:   #FFFFFF;
    /// Output property "dark-text-secondary".
    out property <color> dark-text-secondary: #9D9D9D;
    /// Output property "dark-text-disabled".
    out property <color> dark-text-disabled:  #6B6B6B;
    /// Output property "dark-accent".
    out property <color> dark-accent:         #60CDFF;
    /// Output property "dark-accent-hover".
    out property <color> dark-accent-hover:   #4CC2F1;
    /// Output property "dark-accent-text".
    out property <color> dark-accent-text:    #000000;
    /// Output property "dark-border".
    out property <color> dark-border:         #3D3D3D;
    /// Output property "dark-border-strong".
    out property <color> dark-border-strong:  #575757;
    /// Output property "dark-shadow".
    out property <color> dark-shadow:         #00000080;

    // ── Light ─────────────────────────────────────────────────────────────────
    /// Output property "light-bg-primary".
    out property <color> light-bg-primary:     #FFFFFF;
    /// Output property "light-bg-surface".
    out property <color> light-bg-surface:     #F3F3F3;
    /// Output property "light-bg-elevated".
    out property <color> light-bg-elevated:    #FFFFFF;
    /// Output property "light-text-primary".
    out property <color> light-text-primary:   #1C1C1C;
    /// Output property "light-text-secondary".
    out property <color> light-text-secondary: #616161;
    /// Output property "light-text-disabled".
    out property <color> light-text-disabled:  #A0A0A0;
    /// Output property "light-accent".
    out property <color> light-accent:         #0078D4;
    /// Output property "light-accent-hover".
    out property <color> light-accent-hover:   #106EBE;
    /// Output property "light-accent-text".
    out property <color> light-accent-text:    #FFFFFF;
    /// Output property "light-border".
    out property <color> light-border:         #E0E0E0;
    /// Output property "light-border-strong".
    out property <color> light-border-strong:  #C0C0C0;
    /// Output property "light-shadow".
    out property <color> light-shadow:         #0000001F;
}
