    out property <length> content-md:   600px;
    /// Output property "content-lg".
    /// property `content-lg`.
    out property <length> content-lg:   700px;
    /// Output property "content-xl".
    /// property `content-xl`.
    out property <length> content-xl:   800px;

    // ── Font sizes (icon glyphs) ────────────────────────────────────────
    /// Output property "glyph-sm".
