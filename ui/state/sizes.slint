    /// property `border-w`.
    out property <length> border-w:    1px;
    /// Output property "border-w-2".
    /// property `border-w-2`.
    out property <length> border-w-2:  2px;
    /// Output property "border-w-3".
    /// property `border-w-3`.
    out property <length> border-w-3:  3px;
    /// Output property "no-size".
    /// property `no-size`.
    out property <length> no-size:     0px;

    // ── Window dimensions ─────────────────────────────────────────────
    /// Output property "docs-window-width".
    /// property `docs-window-width`.
    out property <length> docs-window-width:      1100px;
