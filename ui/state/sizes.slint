// Sizes — layout stretch constants, dimension tokens, and reusable size values.
//
// Use instead of hardcoded integers in horizontal-stretch / vertical-stretch
// and preferred-width / preferred-height on top-level windows.

/// S iz es global values.
export global Sizes {
    // ── Layout stretch ────────────────────────────────────────────────────
    /// Output property "fill".
    /// property `fill`.
    out property <float> fill:    1.0;   // fill remaining space
    /// Output property "no-fill".
    /// property `no-fill`.
    out property <float> no-fill: 0.0;   // fixed / no stretch

    // ── Percentage fills ────────────────────────────────────────────────
    /// Output property "full".
    /// property `full`.
    out property <float> full: 1.0;      // 100%
    /// Output property "half".
    /// property `half`.
    out property <float> half: 0.5;      // 50%
    /// Output property "third".
    /// property `third`.
    out property <float> third: 0.33;    // 33%
    /// Output property "quarter".
    /// property `quarter`.
    out property <float> quarter: 0.25;  // 25%
    /// Output property "three-quarter".
    /// property `three-quarter`.
    out property <float> three-quarter: 0.75;

    // ── Common ratios ───────────────────────────────────────────────────
    /// Output property "ratio-xs".
    /// property `ratio-xs`.
    out property <float> ratio-xs:  0.05;
    /// Output property "ratio-sm".
    /// property `ratio-sm`.
    out property <float> ratio-sm:  0.1;
    /// Output property "ratio-md".
    /// property `ratio-md`.
    out property <float> ratio-md:  0.4;
    /// Output property "ratio-lg".
    /// property `ratio-lg`.
    out property <float> ratio-lg:  0.45;

    // ── Integer counts / indices ────────────────────────────────────────
    /// Output property "zero".
    /// property `zero`.
    out property <int> zero: 0;
    /// Output property "one".
    /// property `one`.
    out property <int> one:  1;
    /// Output property "two".
    /// property `two`.
    out property <int> two:  2;
    /// Output property "three".
    /// property `three`.
    out property <int> three: 3;
    /// Output property "four".
    /// property `four`.
    out property <int> four:  4;
    /// Output property "five".
    /// property `five`.
    out property <int> five:  5;
    /// Output property "six".
    /// property `six`.
    out property <int> six:   6;
    /// Output property "ten".
    /// property `ten`.
    out property <int> ten:  10;
    /// Output property "eleven".
    /// property `eleven`.
    out property <int> eleven: 11;
    /// Output property "hundred".
    /// property `hundred`.
    out property <int> hundred: 100;

    // ── Border / line widths ────────────────────────────────────────────
