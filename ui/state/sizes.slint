    out property <length> glyph-sm:    10px;
    /// Output property "glyph-md".
    /// property `glyph-md`.
    out property <length> glyph-md:    14px;
    /// Output property "glyph-lg".
    /// property `glyph-lg`.
    out property <length> glyph-lg:    16px;
    /// Output property "glyph-xl".
    /// property `glyph-xl`.
    out property <length> glyph-xl:    20px;

    // ── Miscellaneous ───────────────────────────────────────────────────
    /// Output property "handle-w".
    /// property `handle-w`.
    out property <length> handle-w:    9px;
    /// Output property "track-h".
    /// property `track-h`.
    out property <length> track-h:     4px;

    // ── Additional component sizes ───────────────────────────────────────
    /// Output property "comp-6".
    /// property `comp-6`.
    out property <length> comp-6:   6px;
    /// Output property "comp-9".
    /// property `comp-9`.
    out property <length> comp-9:   9px;
    /// Output property "comp-12".
    /// property `comp-12`.
    out property <length> comp-12: 12px;
    /// Output property "comp-36".
    /// property `comp-36`.
    out property <length> comp-36: 36px;
    /// Output property "comp-60".
    /// property `comp-60`.
    out property <length> comp-60: 60px;
    /// Output property "comp-64".
    /// property `comp-64`.
    out property <length> comp-64: 64px;
    /// Output property "comp-72".
    /// property `comp-72`.
    out property <length> comp-72: 72px;
    /// Output property "comp-140".
    /// property `comp-140`.
    out property <length> comp-140: 140px;
    /// Output property "comp-160".
    /// property `comp-160`.
    out property <length> comp-160: 160px;
    /// Output property "comp-240".
    /// property `comp-240`.
    out property <length> comp-240: 240px;
    /// Output property "comp-260".
