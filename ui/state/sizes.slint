    out property <length> thumb-sm:    80px;
    /// Output property "thumb-md".
    /// property `thumb-md`.
    out property <length> thumb-md:    100px;
    /// Output property "thumb-lg".
    /// property `thumb-lg`.
    out property <length> thumb-lg:    120px;

    /// Output property "panel-xs".
    /// property `panel-xs`.
    out property <length> panel-xs:    180px;
    /// Output property "panel-sm".
    /// property `panel-sm`.
    out property <length> panel-sm:    200px;
    /// Output property "panel-md".
