// Scale — icon sizes derived from Settings.zoom.
//
// Components that render icons import Scale instead of hardcoding px values.
// Font sizes are handled in typography.slint (Type global).

import { Settings } from "../state/settings.slint";

/// S ca le global values.
export global Scale {
    /// Output property "icon-sm".
    /// property `icon-sm`.
    out property <length> icon-sm: Settings.zoom * 16px;
    /// Output property "icon-md".
    /// property `icon-md`.
    out property <length> icon-md: Settings.zoom * 24px;
    /// Output property "icon-lg".
    /// property `icon-lg`.
    out property <length> icon-lg: Settings.zoom * 32px;
    /// Output property "icon-xl".
    /// property `icon-xl`.
    out property <length> icon-xl: Settings.zoom * 48px;
}
