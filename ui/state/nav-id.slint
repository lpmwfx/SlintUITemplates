// NavId — named constants for navigation destination IDs.
// Prevents stringly-typed state comparisons in shell/nav components.

/// N av id global values.
export global NavId {
    /// Output property "home".
    /// property `home`.
    out property <string> home:     "home";
    /// Output property "list".
    /// property `list`.
    out property <string> list:     "list";
    /// Output property "settings".
    /// property `settings`.
    out property <string> settings: "settings";
}
