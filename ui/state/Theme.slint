// Theme — controller global. Imports palette files from theme/ and exposes the token surface.
//
// AXIOM: AppWindow is the only writer of `dark`, `material`, and `platform`.
//        Components read Theme.* (or Colors.* via barrel alias in tokens/theme.slint).
//
// Palettes live in theme/ — one file per material, pure constants, no logic.
// Platform routing: Theme derives ~24 platform-agnostic tokens that widgets use
// instead of FluentXxx.* directly. AppAdapter sets `platform` at startup.

import { Palette }  from "std-widgets.slint";
import { Solid }    from "theme/solid.slint";
import { Mica }     from "theme/mica.slint";
import { Acrylic }  from "theme/acrylic.slint";
import { ThemeMode } from "../globals/ThemeMode.slint";

import { FluentRadius, FluentSpacing, FluentType } from "../tokens/fluent/mod.slint";
import { MaterialRadius, MaterialSpacing, MaterialType } from "../tokens/material/mod.slint";
import { SteamRadius, SteamSpacing, SteamType } from "../tokens/steam/mod.slint";
import { Variants } from "../globals/Variants.slint";

/// T he me global values.
export global Theme {
    /// Two-way property "material".
    in-out property <string> material: "solid";  // "solid" | "mica" | "acrylic"
    /// Two-way property "dark".
    in-out property <bool>   dark: Palette.color-scheme == ColorScheme.dark;
    /// Two-way property "dark-mode".
    in-out property <bool>   dark-mode <=> dark;  // backwards-compat alias
    /// Two-way property "accent-override".
    in-out property <color>  accent-override: transparent;  // alpha=0 → derive from palette

    /// Output property "bg-primary".
    out property <color> bg-primary:
        material == ThemeMode.mica    ? (dark ? Mica.dark-bg-primary       : Mica.light-bg-primary)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-bg-primary    : Acrylic.light-bg-primary)
      :                         (dark ? Solid.dark-bg-primary      : Solid.light-bg-primary);

    /// Output property "bg-surface".
    out property <color> bg-surface:
        material == ThemeMode.mica    ? (dark ? Mica.dark-bg-surface       : Mica.light-bg-surface)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-bg-surface    : Acrylic.light-bg-surface)
      :                         (dark ? Solid.dark-bg-surface      : Solid.light-bg-surface);

    /// Output property "bg-elevated".
    out property <color> bg-elevated:
        material == ThemeMode.mica    ? (dark ? Mica.dark-bg-elevated      : Mica.light-bg-elevated)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-bg-elevated   : Acrylic.light-bg-elevated)
      :                         (dark ? Solid.dark-bg-elevated     : Solid.light-bg-elevated);

    /// Output property "text-primary".
    out property <color> text-primary:
        material == ThemeMode.mica    ? (dark ? Mica.dark-text-primary     : Mica.light-text-primary)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-text-primary  : Acrylic.light-text-primary)
      :                         (dark ? Solid.dark-text-primary    : Solid.light-text-primary);

    /// Output property "text-secondary".
    out property <color> text-secondary:
        material == ThemeMode.mica    ? (dark ? Mica.dark-text-secondary   : Mica.light-text-secondary)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-text-secondary: Acrylic.light-text-secondary)
      :                         (dark ? Solid.dark-text-secondary  : Solid.light-text-secondary);

    /// Output property "text-disabled".
    out property <color> text-disabled:
        material == ThemeMode.mica    ? (dark ? Mica.dark-text-disabled    : Mica.light-text-disabled)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-text-disabled : Acrylic.light-text-disabled)
      :                         (dark ? Solid.dark-text-disabled   : Solid.light-text-disabled);

    /// Output property "accent".
    out property <color> accent:
        accent-override.alpha > 0 ? accent-override
      : material == ThemeMode.mica    ? (dark ? Mica.dark-accent           : Mica.light-accent)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-accent        : Acrylic.light-accent)
      :                         (dark ? Solid.dark-accent          : Solid.light-accent);

    /// Output property "accent-hover".
    out property <color> accent-hover:
        material == ThemeMode.mica    ? (dark ? Mica.dark-accent-hover     : Mica.light-accent-hover)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-accent-hover  : Acrylic.light-accent-hover)
      :                         (dark ? Solid.dark-accent-hover    : Solid.light-accent-hover);

    /// Output property "accent-text".
    out property <color> accent-text:
        material == ThemeMode.mica    ? (dark ? Mica.dark-accent-text      : Mica.light-accent-text)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-accent-text   : Acrylic.light-accent-text)
      :                         (dark ? Solid.dark-accent-text     : Solid.light-accent-text);

    /// Output property "error".
    out property <color> error:   #C42B1C;
    /// Output property "success".
    out property <color> success: #0F7B0F;
    /// Output property "warning".
    out property <color> warning: #9D5D00;

    /// Output property "border".
    out property <color> border:
        material == ThemeMode.mica    ? (dark ? Mica.dark-border           : Mica.light-border)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-border        : Acrylic.light-border)
      :                         (dark ? Solid.dark-border          : Solid.light-border);

    /// Output property "border-strong".
    out property <color> border-strong:
        material == ThemeMode.mica    ? (dark ? Mica.dark-border-strong    : Mica.light-border-strong)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-border-strong : Acrylic.light-border-strong)
      :                         (dark ? Solid.dark-border-strong   : Solid.light-border-strong);

    /// Output property "border-focus".
    out property <color> border-focus: accent;

    /// Output property "shadow".
    out property <color> shadow:
        material == ThemeMode.mica    ? (dark ? Mica.dark-shadow           : Mica.light-shadow)
      : material == ThemeMode.acrylic ? (dark ? Acrylic.dark-shadow        : Acrylic.light-shadow)
      :                         (dark ? Solid.dark-shadow          : Solid.light-shadow);

    // ── Overlay ───────────────────────────────────────────────────────────────
    /// Output property "overlay".
    out property <color> overlay: #00000040;

    // ── Aliases ───────────────────────────────────────────────────────────────
    /// Output property "bg-panel".
    out property <color> bg-panel:     bg-surface;
    /// Output property "handle".
    out property <color> handle:       border;
    /// Output property "handle-hover".
    out property <color> handle-hover: border-strong;
    /// Output property "danger".
    out property <color> danger:       error;
    /// Output property "text-muted".
    out property <color> text-muted:   text-secondary;

    // ── Platform router ───────────────────────────────────────────────────────
    // AppWindow is the only writer of `platform`.
    // Values: "windows" | "android" | "ios" | "steam-linux" | "steam-deck" |
    //         "tablet" | "handheld" | "macos" | "linux"
    /// Two-way property "platform".
    in-out property <string> platform: Variants.windows;

    // Internal routing helpers — not part of the public surface.
    property <bool> is-steam:
        platform == Variants.steam-linux || platform == Variants.steam-deck || platform == Variants.handheld;
    property <bool> is-material:
        platform == Variants.android || platform == Variants.ios || platform == Variants.tablet || platform == Variants.gnome;

    // ── Platform-routed radius ─────────────────────────────────────────────
    /// Small border radius — checkboxes, chips.
    out property <length> radius-sm:
        is-steam ? SteamRadius.sm : is-material ? MaterialRadius.extra-small : FluentRadius.sm;
    /// Standard border radius — buttons, inputs.
    out property <length> radius-md:
        is-steam ? SteamRadius.md : is-material ? MaterialRadius.small : FluentRadius.md;
    /// Large border radius — cards, panels.
    out property <length> radius-lg:
        is-steam ? SteamRadius.lg : is-material ? MaterialRadius.medium : FluentRadius.lg;
    /// Extra-large border radius — dialogs, large surfaces.
    out property <length> radius-xl:
        is-steam ? SteamRadius.xl : is-material ? MaterialRadius.large : FluentRadius.xl;
    /// Full pill / circle radius.
    out property <length> radius-circle:
        is-steam ? SteamRadius.circle : is-material ? MaterialRadius.full : FluentRadius.circle;

    // ── Platform-routed touch targets ─────────────────────────────────────
    /// Small control height — compact items.
    out property <length> touch-sm:
        is-steam ? SteamSpacing.control-sm : is-material ? MaterialSpacing.control-sm : FluentSpacing.control-sm;
    /// Standard control height — buttons, inputs.
    out property <length> touch-md:
        is-steam ? SteamSpacing.control-md : is-material ? MaterialSpacing.control-md : FluentSpacing.control-md;
    /// Large control height — primary targets.
    out property <length> touch-lg:
        is-steam ? SteamSpacing.control-lg : is-material ? MaterialSpacing.control-lg : FluentSpacing.control-lg;

    // ── Platform-routed typography ────────────────────────────────────────
    /// Caption / label text size.
    out property <length> font-caption:
        is-steam ? SteamType.caption : is-material ? MaterialType.label-medium : FluentType.caption;
    /// Body text size.
    out property <length> font-body:
        is-steam ? SteamType.body : is-material ? MaterialType.body-medium : FluentType.body;
    /// Subtitle / section heading.
    out property <length> font-subtitle:
        is-steam ? SteamType.subtitle : is-material ? MaterialType.title-large : FluentType.subtitle;
    /// Heading.
    out property <length> font-heading:
        is-steam ? SteamType.heading : is-material ? MaterialType.headline-small : FluentType.subtitle;
    /// Title / display.
    out property <length> font-title:
        is-steam ? SteamType.title : is-material ? MaterialType.headline-medium : FluentType.title;

    // ── Platform-routed font weights ──────────────────────────────────────
    /// Regular weight (400).
    out property <int> font-weight-regular:
        is-steam ? SteamType.weight-regular : is-material ? MaterialType.weight-regular : FluentType.weight-regular;
    /// Medium weight (500).
    out property <int> font-weight-medium:
        is-steam ? SteamType.weight-medium : is-material ? MaterialType.weight-medium : FluentType.weight-medium;
    /// Bold weight (700).
    out property <int> font-weight-bold:
        is-steam ? SteamType.weight-bold : is-material ? MaterialType.weight-bold : FluentType.weight-bold;

    // ── Platform-routed spacing ────────────────────────────────────────────
    /// Extra-small spacing.
    out property <length> space-xs:
        is-steam ? SteamSpacing.xs : is-material ? MaterialSpacing.xs : FluentSpacing.xs;
    /// Small spacing.
    out property <length> space-sm:
        is-steam ? SteamSpacing.sm : is-material ? MaterialSpacing.sm : FluentSpacing.sm;
    /// Medium spacing.
    out property <length> space-md:
        is-steam ? SteamSpacing.md : is-material ? MaterialSpacing.md : FluentSpacing.md;
    /// Large spacing.
    out property <length> space-lg:
        is-steam ? SteamSpacing.lg : is-material ? MaterialSpacing.lg : FluentSpacing.lg;
    /// Extra-large spacing.
    out property <length> space-xl:
        is-steam ? SteamSpacing.xl : is-material ? MaterialSpacing.xl : FluentSpacing.xl;

    // ── Platform-routed nav chrome ─────────────────────────────────────────
    /// Side navigation rail width.
    out property <length> nav-rail-width:
        is-steam ? SteamSpacing.nav-rail-width : is-material ? MaterialSpacing.nav-rail-width : FluentSpacing.nav-width-collapsed;
    /// Navigation bar height (bottom nav / toolbar).
    out property <length> nav-bar-height:
        is-steam ? SteamSpacing.bottom-rail-height : is-material ? MaterialSpacing.bottom-nav-bar-height : FluentSpacing.toolbar-height;
    /// Top bar / title bar height.
    out property <length> top-bar-height:
        is-steam ? SteamSpacing.top-bar-height : is-material ? MaterialSpacing.top-app-bar-height : FluentSpacing.titlebar-height;

    // ── Platform convenience shortcuts ────────────────────────────────────
    /// Minimum safe interactive target for this platform.
    /// Use for min-width / min-height on buttons and nav items.
    out property <length> touch-target:
        is-steam ? SteamSpacing.control-lg : is-material ? MaterialSpacing.control-md : FluentSpacing.control-md;
    /// Recommended nav chrome pattern for this platform.
    out property <string> nav-style:
        is-steam   ? Variants.nav-compact :
        is-material ? Variants.nav-bottom  :
        Variants.nav-sidebar;
}
