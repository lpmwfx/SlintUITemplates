// SlintUITemplates — Public Component Hub
//
// Single import point for all public widgets + tokens.
// Consumer .slint files import from here via:
//   import { Button, Card, TextInput } from "components.slint";
//
// Only leaf/public components are re-exported here.
// Internal helpers (ClearButton, SpinButton, etc.) are not part of the public API.

// ── State globals ─────────────────────────────────────────────────────────────
export { Theme }    from "globals/theme/controller.slint";
export { Settings } from "state/settings.slint";

// ── Design tokens ─────────────────────────────────────────────────────────────
export { Colors, Spacing, Type, FluentIcons,
         FluentColors, FluentSpacing, FluentRadius,
         FluentElevation, FluentMotion, FluentType,
         MaterialColors, MaterialSpacing, MaterialRadius,
         MaterialType, MaterialElevation }
    from "globals/theme.slint";

export { Sizes }    from "globals/theme/sizes.slint";
export { Scale }    from "globals/theme/scale.slint";

// ── Globals ───────────────────────────────────────────────────────────────────
export { Variants } from "globals/variants.slint";
export { ThemeMode } from "state/theme-mode.slint";

