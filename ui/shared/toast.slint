import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Variants } from "../globals/Variants.slint";

/// T oa st component.
export component Toast inherits Rectangle {
    /// Input property "message".
    in property <string> message: "";
    /// Input property "variant".
    in property <string> variant: "info";   // info | success | warning | error
    // visible is the built-in — caller sets visible: true/false directly

    // Position at bottom center
    height: Spacing.xl;
    border-radius: Spacing.xs;
    clip: true;

    background:
        variant == Variants.success ? Colors.success :
        variant == Variants.warning ? Colors.warning :
        variant == Variants.error   ? Colors.error :
        Colors.accent;

    HorizontalLayout {
        alignment: center;
        padding-left: Spacing.md;
        padding-right: Spacing.md;

        Text {
            text: root.message;
            font-size: Type.body-size;
            color: Colors.accent-text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}
