import { Colors, Spacing } from "../tokens/theme.slint";

export component Skeleton inherits Rectangle {
    in property <string> variant: "rect";   // text | circle | rect
    in property <bool>   animate: true;

    background: Colors.bg-elevated;
    clip: true;
    border-radius:
        root.variant == "circle" ? root.height / 2 :
        root.variant == "text"   ? 2px :
        Spacing.xs;

    private property <float> shimmer-pos: 0.0;

    timer := Timer {
        interval: 16ms;
        running: root.animate;
        triggered => {
            root.shimmer-pos = root.shimmer-pos + 0.01;
            if root.shimmer-pos > 1.33 { root.shimmer-pos = -0.33; }
        }
    }

    // Shimmer overlay
    if root.animate: Rectangle {
        x: (root.shimmer-pos - 0.33) * parent.width;
        y: 0;
        width: parent.width * 0.33;
        height: parent.height;
        opacity: 0.4;
        background: Colors.bg-surface;
    }
}
