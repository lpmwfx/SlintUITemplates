import { Colors, Spacing } from "../tokens/theme.slint";
import { DropdownEntry, DropdownMenuItem } from "dropdown-entry.slint";

export { DropdownMenuItem }

export component DropdownMenu inherits Rectangle {
    in property <[DropdownMenuItem]> items: [];
    in property <length>             window-height;
    in property <int>                separator-count: 0;
    callback activated(string);

    private property <length> pop-x:     0px;
    private property <length> pop-y:     0px;
    private property <length> border-px: 1px;
    private property <length> popup-w:   220px;
    private property <length> est-popup-h:
        (items.length - root.separator-count) * Spacing.xl
        + root.separator-count * Spacing.xs
        + Spacing.sm * 2;
    private property <length> popup-h:
        root.window-height > root.pop-y
            && root.est-popup-h > root.window-height - Spacing.md * 2
            ? root.window-height - Spacing.md * 2
            : root.est-popup-h;

    background: transparent;

    popup := PopupWindow {
        x: root.pop-x;
        y: root.pop-y;
        width: root.popup-w;
        height: root.popup-h;

        Rectangle {
            background: Colors.bg-elevated;
            border-radius: Spacing.xs;
            border-width: root.border-px;
            border-color: Colors.border;
            drop-shadow-blur: Spacing.sm;
            drop-shadow-color: Colors.shadow;
            clip: true;

            Flickable {
                width: parent.width;
                height: parent.height;
                viewport-width: self.width;
                viewport-height: root.est-popup-h;

                VerticalLayout {
                    padding: Spacing.xs;
                    for item in root.items: DropdownEntry {
                        item: item;
                        activated(id) => { root.activated(id); popup.close(); }
                    }
                }
            }
        }
    }

    public function show-at(xp: length, yp: length) {
        root.pop-x = xp;
        if root.window-height > root.pop-y
                && root.absolute-position.y + yp + root.popup-h > root.window-height {
            root.pop-y = yp - root.popup-h;
            if root.absolute-position.y + root.pop-y < root.pop-x - root.pop-x {
                root.pop-y = root.pop-x - root.pop-x;
            }
        } else {
            root.pop-y = yp;
        }
        popup.show();
    }
}
