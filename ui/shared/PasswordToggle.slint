import { Colors, Spacing, Type } from "../tokens/theme.slint";

// PasswordToggle — eye icon toggle button for PasswordInput.
/// P as sw or dt og gl e component.
export component PasswordToggle inherits Rectangle {
    /// Input property "show-password".
    in property <bool> show-password: false;
    /// Callback fired for t og gl ed.
    callback toggled();

    width: Spacing.xl;
    background: eye-ta.has-hover ? Colors.bg-surface : transparent;

    Text {
        text: root.show-password ? "\u{25CF}" : "\u{25CB}";
        font-size: Type.body-size;
        color: Colors.text-secondary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    eye-ta := TouchArea {
        clicked => { root.toggled(); }
    }
}
