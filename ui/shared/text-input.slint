import { Colors, Spacing, Type } from "../tokens/theme.slint";

export component TextInput inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "";
    in property <string> placeholder: "";
    in property <string> error: "";
    callback changed(string);
    callback submitted(string);

    height: label != "" ? Spacing.xl + Type.caption-size + Spacing.xs : Spacing.xl;

    VerticalLayout {
        spacing: Spacing.xs;

        if root.label != "": Text {
            text: root.label;
            font-size: Type.caption-size;
            font-weight: Type.weight-semibold;
            color: root.error != "" ? Colors.error : Colors.text-secondary;
        }

        Rectangle {
            height: Spacing.xl;
            border-radius: Spacing.xs;
            border-width: 1px;
            border-color: root.error != "" ? Colors.error :
                          input.has-focus ? Colors.border-focus : Colors.border;
            background: Colors.bg-elevated;

            HorizontalLayout {
                padding-left: Spacing.sm;
                padding-right: Spacing.sm;

                input := TextInput {
                    text: root.value;
                    font-size: Type.body-size;
                    color: Colors.text-primary;
                    vertical-alignment: center;

                    edited => { root.changed(self.text); }
                    accepted => { root.submitted(self.text); }
                }
            }

            // Placeholder
            if input.text == "" && !input.has-focus: Text {
                x: Spacing.sm;
                text: root.placeholder;
                font-size: Type.body-size;
                color: Colors.text-disabled;
                vertical-alignment: center;
            }
        }

        if root.error != "": Text {
            text: root.error;
            font-size: Type.caption-size;
            color: Colors.error;
        }
    }
}
