import { Colors, Spacing, Type } from "../tokens/theme.slint";

export struct BreadcrumbItem {
    id: string,
    label: string,
}

export component Breadcrumb inherits Rectangle {
    in property <[BreadcrumbItem]> items: [];
    in property <string>           separator: "›";
    callback navigate(string);

    height: Spacing.xl;
    background: transparent;

    HorizontalLayout {
        alignment: start;
        spacing: Spacing.xs;
        padding-left: 0;

        for item[i] in root.items: HorizontalLayout {
            spacing: Spacing.xs;
            alignment: center;

            if i > 0: Text {
                text: root.separator;
                font-size: Type.body-size;
                color: Colors.text-secondary;
                vertical-alignment: center;
            }

            crumb-btn := Rectangle {
                height: Spacing.xl;
                width: crumb-text.preferred-width + Spacing.xs * 2;
                background: crumb-ta.has-hover && i < root.items.length - 1
                    ? Colors.bg-elevated : transparent;
                border-radius: Spacing.xs;

                crumb-text := Text {
                    x: Spacing.xs;
                    text: item.label;
                    font-size: Type.body-size;
                    color: i == root.items.length - 1 ? Colors.text-primary : Colors.accent;
                    font-weight: i == root.items.length - 1 ? Type.weight-semibold : Type.weight-regular;
                    vertical-alignment: center;
                }

                crumb-ta := TouchArea {
                    enabled: i < root.items.length - 1;
                    clicked => { root.navigate(item.id); }
                }
            }
        }
    }
}
