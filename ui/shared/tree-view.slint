import { Colors, Spacing, Type } from "../tokens/theme.slint";

export struct TreeNode {
    id: string,
    label: string,
    icon: string,
    level: int,
    expanded: bool,
    leaf: bool,
}

export component TreeView inherits Rectangle {
    in property <[TreeNode]> nodes: [];
    in-out property <string> selected: "";
    callback selected-changed(string);
    callback toggle-expanded(string);

    background: Colors.bg-surface;
    clip: true;

    Flickable {
        width: parent.width;
        height: parent.height;
        viewport-height: root.nodes.length * Spacing.xl;

        VerticalLayout {
            for node in root.nodes: node-row := Rectangle {
                height: Spacing.xl;
                background: node.id == root.selected ? Colors.accent :
                            node-ta.has-hover ? Colors.bg-elevated : transparent;

                HorizontalLayout {
                    padding-left: node.level * Spacing.lg;
                    spacing: Spacing.xs;
                    alignment: start;

                    // Expand/collapse toggle
                    if !node.leaf: expand-btn := Rectangle {
                        width: Spacing.md;
                        height: Spacing.md;
                        background: transparent;

                        Text {
                            text: node.expanded ? "▼" : "▶";
                            font-size: Type.caption-size;
                            color: node.id == root.selected
                                ? Colors.accent-text : Colors.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        expand-ta := TouchArea {
                            clicked => { root.toggle-expanded(node.id); }
                        }
                    }

                    // Spacer for leaf nodes (alignment)
                    if node.leaf: Rectangle {
                        width: Spacing.md;
                        background: transparent;
                    }

                    // Icon
                    if node.icon != "": Text {
                        text: node.icon;
                        font-family: "Segoe Fluent Icons";
                        font-size: Type.body-size;
                        color: node.id == root.selected
                            ? Colors.accent-text : Colors.text-secondary;
                        vertical-alignment: center;
                    }

                    // Label
                    Text {
                        text: node.label;
                        font-size: Type.body-size;
                        color: node.id == root.selected
                            ? Colors.accent-text : Colors.text-primary;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                }

                node-ta := TouchArea {
                    clicked => {
                        root.selected = node.id;
                        root.selected-changed(node.id);
                    }
                }
            }
        }
    }

    // Vertical scrollbar
    if root.nodes.length * Spacing.xl > root.height: Rectangle {
        x: parent.width - 4px;
        width: 4px;
        border-radius: 2px;
        background: Colors.border-strong;
        opacity: 0.6;
    }
}
