import { Colors, Spacing, Type, FluentIcons } from "../tokens/theme.slint";

export component Rating inherits Rectangle {
    in-out property <int> value: 0;
    in property <int>  max: 5;
    in property <bool> readonly: false;
    callback changed(int);

    private property <int> hover-val: 0;

    height: Spacing.xl;
    background: transparent;

    VerticalLayout {
        alignment: center;

        stars-row := HorizontalLayout {
            alignment: start;
            spacing: Spacing.xs;

            for i in [1, 2, 3, 4, 5]: Rectangle {
                visible: i <= root.max;
                width: Spacing.lg;
                height: Spacing.lg;
                background: transparent;

                Text {
                    text: i <= (root.hover-val > 0 ? root.hover-val : root.value)
                        ? FluentIcons.star-filled : FluentIcons.star;
                    font-family: "Segoe Fluent Icons";
                    font-size: Type.subtitle-size;
                    color: i <= (root.hover-val > 0 ? root.hover-val : root.value)
                        ? Colors.accent : Colors.text-disabled;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                star-ta := TouchArea {
                    enabled: !root.readonly;
                    clicked => {
                        root.value = i;
                        root.changed(i);
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move || e.kind == PointerEventKind.down {
                            root.hover-val = i;
                        }
                        if e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel {
                            root.hover-val = 0;
                        }
                    }
                }
            }
        }
    }

    // Reset hover when mouse leaves the widget
    exit-ta := TouchArea {
        pointer-event(e) => {
            if e.kind == PointerEventKind.cancel {
                root.hover-val = 0;
            }
        }
    }
}
