import { Colors, Spacing, Type } from "../tokens/theme.slint";

export component RadioButton inherits Rectangle {
    in property <bool>   checked: false;
    in property <string> label: "";
    in property <bool>   enabled: true;
    callback clicked();

    private property <length> circle-size: Spacing.md + Spacing.xs;   // 20px
    private property <length> dot-size:    Spacing.sm + Spacing.xs;   // 10px

    height: Spacing.xl;
    background: transparent;
    opacity: root.enabled ? 1.0 : 0.5;

    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: start;
            spacing: Spacing.sm;

            Rectangle {
                width:  root.circle-size;
                height: root.circle-size;
                border-radius: root.circle-size / 2;
                border-width: 2px;
                border-color: root.checked ? Colors.accent : Colors.border;
                background: transparent;

                if root.checked: Rectangle {
                    x: (parent.width  - root.dot-size) / 2;
                    y: (parent.height - root.dot-size) / 2;
                    width:  root.dot-size;
                    height: root.dot-size;
                    border-radius: root.dot-size / 2;
                    background: Colors.accent;
                }
            }

            if root.label != "": Text {
                text: root.label;
                font-size: Type.body-size;
                color: Colors.text-primary;
                vertical-alignment: center;
            }
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

export component RadioGroup inherits VerticalLayout {
    in property <[string]> options: [];
    in-out property <string> value: "";
    in property <bool> enabled: true;
    callback changed(string);

    spacing: Spacing.sm;

    for opt in root.options: RadioButton {
        label: opt;
        checked: opt == root.value;
        enabled: root.enabled;
        clicked => {
            root.value = opt;
            root.changed(opt);
        }
    }
}
