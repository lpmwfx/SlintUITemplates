import { Colors, Spacing, Type, FluentColors } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";
import { DialogButton } from "DialogButton.slint";

/// D ia lo g component.
export component Dialog inherits Rectangle {
    /// Input property "title".
    in property <string> title: "Dialog";
    /// Input property "cancel-label".
    in property <string> cancel-label: "Cancel";
    /// Input property "confirm-label".
    in property <string> confirm-label: "OK";
    // visible is the built-in — caller sets visible: true/false directly
    /// Callback fired for c on fi rm ed.
    callback confirmed();
    /// Callback fired for c an ce ll ed.
    callback cancelled();

    // Overlay constants
    /// Private property "overlay-bg" used internally.
    private property <color> overlay-bg:     FluentColors.overlay-medium;
    /// Private property "shadow-color" used internally.
    private property <color> shadow-color:   FluentColors.overlay-light;

    // Full overlay
    background: root.overlay-bg;

    // Center card
    Rectangle {
        width: Sizes.panel-max;
        height: Sizes.panel-sm;
        x: (parent.width - self.width) / Sizes.two;
        y: (parent.height - self.height) / Sizes.two;
        background: Colors.bg-elevated;
        border-radius: Spacing.sm;
        drop-shadow-blur: Spacing.lg;
        drop-shadow-color: root.shadow-color;

        VerticalLayout {
            padding: Spacing.lg;
            spacing: Spacing.md;

            Text {
                text: root.title;
                font-size: Type.heading-size;
                font-weight: Type.weight-semibold;
                color: Colors.text-primary;
            }

            // Spacer
            Rectangle { vertical-stretch: Sizes.one; }

            // Action buttons
            HorizontalLayout {
                alignment: end;
                spacing: Spacing.sm;

                DialogButton {
                    label: root.cancel-label;
                    bg-normal: transparent;
                    bg-hover: Colors.bg-surface;
                    text-color: Colors.text-primary;
                    clicked => { root.cancelled(); }
                }

                DialogButton {
                    label: root.confirm-label;
                    bg-normal: Colors.accent;
                    bg-hover: Colors.accent-hover;
                    text-color: Colors.accent-text;
                    text-weight: Type.weight-semibold;
                    clicked => { root.confirmed(); }
                }
            }
        }
    }
}
