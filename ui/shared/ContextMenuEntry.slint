import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";

export struct ContextMenuItem {
    id:         string,
    label:      string,
    icon:       string,
    disabled:   bool,
    separator:  bool,
    keybinding: string,
}

// Private helper — keeps popup VerticalLayout at nesting depth ≤ 5.
export component ContextMenuEntry inherits Rectangle {
    in property <ContextMenuItem> item;
    in property <string> icon-font: "Segoe Fluent Icons";
    callback activated(string);

    height: item.separator ? Spacing.xs : Spacing.xl;

    // Separator line
    if item.separator: Rectangle {
        y: Spacing.xs / Sizes.two;
        width: parent.width;
        height: Sizes.border-w;
        background: Colors.border;
    }

    // Item row
    if !item.separator: Rectangle {
        border-radius: Spacing.xs;
        background: !item.disabled && row-ta.has-hover ? Colors.bg-surface : transparent;
        opacity: item.disabled ? Sizes.half : Sizes.fill;

        HorizontalLayout {
            padding-left: Spacing.sm;
            padding-right: Spacing.sm;
            spacing: Spacing.sm;
            if item.icon != "": Text {
                text: item.icon;
                font-family: root.icon-font;
                font-size: Type.body-size;
                color: Colors.text-secondary;
                vertical-alignment: center;
            }
            Text {
                text: item.label;
                font-size: Type.body-size;
                color: item.disabled ? Colors.text-disabled : Colors.text-primary;
                vertical-alignment: center;
                horizontal-stretch: Sizes.one;
            }
            if item.keybinding != "": Text {
                text: item.keybinding;
                font-size: Type.caption-size;
                color: Colors.text-disabled;
                vertical-alignment: center;
            }
        }

        row-ta := TouchArea {
            enabled: !item.disabled;
            clicked => { root.activated(root.item.id); }
        }
    }
}
