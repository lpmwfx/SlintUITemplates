import { Colors, Spacing, Type } from "../tokens/theme.slint";

export component Divider inherits Rectangle {
    in property <string> orientation: "horizontal";   // horizontal | vertical
    in property <string> label: "";
    in property <color>  line-color: Colors.border;

    background: transparent;

    // Horizontal — no label
    if root.orientation == "horizontal" && root.label == "": Rectangle {
        width: parent.width;
        height: 1px;
        y: (parent.height - 1px) / 2;
        background: root.line-color;
    }

    // Horizontal — with label
    if root.orientation == "horizontal" && root.label != "": HorizontalLayout {
        alignment: stretch;

        Rectangle {
            height: 1px;
            y: parent.height / 2;
            horizontal-stretch: 1;
            background: root.line-color;
        }

        Rectangle {
            width: label-text.preferred-width + Spacing.md;
            label-text := Text {
                x: Spacing.sm;
                text: root.label;
                font-size: Type.caption-size;
                color: Colors.text-secondary;
            }
        }

        Rectangle {
            height: 1px;
            y: parent.height / 2;
            horizontal-stretch: 1;
            background: root.line-color;
        }
    }

    // Vertical
    if root.orientation == "vertical": Rectangle {
        width: 1px;
        height: parent.height;
        x: (parent.width - 1px) / 2;
        background: root.line-color;
    }
}
