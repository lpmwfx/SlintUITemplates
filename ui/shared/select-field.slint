import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";
import { SelectFieldItem } from "./SelectFieldItem.slint";

/// S el ec tf ie ld component.
export component SelectField inherits Rectangle {
    /// Input property "options".
    in property <[string]> options: [];
    /// Input property "selected".
    in property <string>   selected: "";
    /// Input property "placeholder".
    in property <string>   placeholder: "Select...";
    /// Callback fired for c ha ng ed.
    callback changed(string);

    height: Spacing.xl;
    clip: false;

    // Dropdown popup — auto-closes on outside click (Slint PopupWindow behavior)
    popup := PopupWindow {
        x: Sizes.no-size;
        y: Spacing.xl + Spacing.xs;
        width: root.width;
        height: Spacing.xl * root.options.length;

        Rectangle {
            border-radius: Spacing.xs;
            border-width: Sizes.border-w;
            border-color: Colors.border;
            background: Colors.bg-elevated;
            drop-shadow-blur: Spacing.sm;
            drop-shadow-color: Colors.shadow;

            VerticalLayout {
                for item in root.options: SelectFieldItem {
                    label: item;
                    is-selected: item == root.selected;
                    picked(v) => { root.changed(v); popup.close(); }
                }
            }
        }
    }

    // Trigger row
    trigger := Rectangle {
        height: Spacing.xl;
        border-radius: Spacing.xs;
        border-width: Sizes.border-w;
        border-color: trigger-ta.has-hover ? Colors.border-focus : Colors.border;
        background: Colors.bg-elevated;

        HorizontalLayout {
            padding-left: Spacing.sm;
            padding-right: Spacing.sm;

            Text {
                text: root.selected != "" ? root.selected : root.placeholder;
                font-size: Type.body-size;
                color: root.selected != "" ? Colors.text-primary : Colors.text-disabled;
                vertical-alignment: center;
                horizontal-stretch: Sizes.one;
            }

            Text {
                text: "▼";
                font-size: Type.caption-size;
                color: Colors.text-secondary;
                vertical-alignment: center;
            }
        }

        trigger-ta := TouchArea {
            clicked => { popup.show(); }
        }
    }
}
