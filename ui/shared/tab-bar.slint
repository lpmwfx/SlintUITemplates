import { Colors, Spacing, Type } from "../tokens/theme.slint";

export struct TabItem {
    id: string,
    label: string,
    icon: string,
}

export component TabBar inherits Rectangle {
    in property <[TabItem]> tabs: [];
    in-out property <string> active: "";
    callback changed(string);

    height: Spacing.xl;
    background: Colors.bg-surface;

    // Bottom separator line
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        width: parent.width;
        background: Colors.border;
    }

    HorizontalLayout {
        alignment: start;

        for tab in root.tabs: tab-item := Rectangle {
            width: tab-lbl.preferred-width + Spacing.lg * 2;
            height: parent.height;
            background: tab-ta.has-hover && tab.id != root.active
                ? Colors.bg-elevated : transparent;

            // Active indicator bar
            Rectangle {
                y: parent.height - 2px;
                height: 2px;
                width: parent.width;
                background: tab.id == root.active ? Colors.accent : transparent;
            }

            HorizontalLayout {
                alignment: center;
                spacing: Spacing.xs;
                padding-left: Spacing.lg;
                padding-right: Spacing.lg;

                if tab.icon != "": Text {
                    text: tab.icon;
                    font-family: "Segoe Fluent Icons";
                    font-size: Type.caption-size;
                    color: tab.id == root.active ? Colors.accent : Colors.text-secondary;
                    vertical-alignment: center;
                }

                tab-lbl := Text {
                    text: tab.label;
                    font-size: Type.body-size;
                    font-weight: tab.id == root.active ? Type.weight-semibold : Type.weight-regular;
                    color: tab.id == root.active ? Colors.accent : Colors.text-secondary;
                    vertical-alignment: center;
                }
            }

            tab-ta := TouchArea {
                clicked => {
                    root.active = tab.id;
                    root.changed(tab.id);
                }
            }
        }
    }
}
