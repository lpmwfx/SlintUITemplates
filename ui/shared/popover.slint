// Popover — inline overlay that appears below the trigger element.
//
// Usage:
//   popover-wrap := Rectangle {
//       Popover {
//           open: show-popover;
//           title: "Info";
//           body: "This is a popover.";
//           close-requested => { show-popover = false; }
//       }
//       Button { clicked => { show-popover = !show-popover; } }
//   }

import { Spacing } from "../tokens/theme.slint";
import { PopoverInner } from "popover-inner.slint";

export component Popover inherits Rectangle {
    in property <bool>   open: false;
    in property <length> popup-width:  220px;
    in property <length> popup-height: 140px;
    in property <string> title: "";
    in property <string> body: "";
    callback close-requested();

    clip: false;

    @children

    if root.open: PopoverInner {
        y: parent.height + Spacing.xs;
        width: root.popup-width;
        height: root.popup-height;
        title: root.title;
        body: root.body;
        close-requested => { root.close-requested(); }
    }
}
