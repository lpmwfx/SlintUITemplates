import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";
import { PasswordToggle } from "PasswordToggle.slint";

/// P as sw or di np ut component.
export component PasswordInput inherits Rectangle {
    /// Input property "label".
    in property <string> label: "";
    /// Input property "placeholder".
    in property <string> placeholder: "";
    /// Input property "error".
    in property <string> error: "";
    /// Input property "enabled".
    in property <bool>   enabled: true;
    /// Callback fired for c ha ng ed.
    callback changed(string);

    /// Private property "show-password" used internally.
    private property <bool> show-password: false;

    height: root.label != "" ? Spacing.xl + Type.caption-size + Spacing.xs : Spacing.xl;
    opacity: root.enabled ? Sizes.fill : Sizes.half;

    VerticalLayout {
        spacing: Spacing.xs;

        if root.label != "": Text {
            text: root.label;
            font-size: Type.caption-size;
            font-weight: Type.weight-semibold;
            color: root.error != "" ? Colors.error : Colors.text-secondary;
        }

        Rectangle {
            height: Spacing.xl;
            border-radius: Spacing.xs;
            border-width: Sizes.border-w;
            border-color: root.error != "" ? Colors.error :
                          input.has-focus ? Colors.border-focus : Colors.border;
            background: Colors.bg-elevated;

            HorizontalLayout {
                padding-left: Spacing.sm;

                input := TextInput {
                    text: "";
                    font-size: Type.body-size;
                    color: Colors.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: Sizes.one;
                    input-type: root.show-password ? InputType.text : InputType.password;
                    enabled: root.enabled;

                    edited => { root.changed(self.text); }
                }

                PasswordToggle {
                    show-password: root.show-password;
                    toggled => { root.show-password = !root.show-password; }
                }
            }

            // Placeholder
            if input.text == "" && !input.has-focus: Text {
                x: Spacing.sm;
                text: root.placeholder;
                font-size: Type.body-size;
                color: Colors.text-disabled;
                vertical-alignment: center;
            }
        }

        if root.error != "": Text {
            text: root.error;
            font-size: Type.caption-size;
            color: Colors.error;
        }
    }
}
