import { Palette }                           from "std-widgets.slint";
import { Theme }                             from "../state/Theme.slint";
import { Spacing }                           from "../tokens/theme.slint";
import { Sizes }                             from "../tokens/sizes.slint";
import { Variants }                          from "../globals/Variants.slint";
import { PanelContainer, PanelItem }         from "../modules/PanelContainer.slint";

// AppWindow — the ONLY state owner in the entire UI.
//
// AXIOM 1: Only this component has in-out properties.
// AXIOM 2: Theme.dark is set here and nowhere else.
//          Children read Theme.* — never write to it.
//
// theme-mode: "system" | "dark" | "light"
//   system → follows OS via Palette.color-scheme (live, reactive)
//   dark   → always dark
//   light  → always light

/// A pp wi nd ow component.
export component AppWindow inherits Window {
    preferred-width:  Sizes.win-width-xl;
    preferred-height: Sizes.win-height-xl;
    title: root.app-title;
    /// Private property "app-title" used internally.
    private property <string> app-title: "SlintUITemplates";

    // ── Theme state ────────────────────────────────────────────────────────
    /// Two-way property "theme-mode".
    in-out property <string> theme-mode: Variants.system;
    /// Two-way property "material".
    in-out property <string> material: Variants.solid;  // "solid" | "mica" | "acrylic"
    /// Two-way property "platform".
    in-out property <string> platform: Variants.windows;

    // Reactive: recomputes whenever theme-mode or OS scheme changes
    property <bool> effective-dark:
        theme-mode == Variants.dark  ? true  :
        theme-mode == Variants.light ? false :
        Palette.color-scheme == ColorScheme.dark;

    // Drive Theme global — AppWindow is the only writer
    Theme.dark:     effective-dark;
    Theme.material: root.material;
    Theme.platform: root.platform;

    background: Theme.bg-primary;

    // ── Panel layout state ──────────────────────────────────────────────────
    // Rust pushes [PanelItem] here after parsing DSL + solving geometry.
    /// Two-way property "panels".
    in-out property <[PanelItem]> panels;

    // Drag event — Rust adapter recalculates ratios, re-pushes model
    /// Callback fired for p an el d ra gg ed.
    callback panel-dragged(int, float, float);   // id, dx, dy in logical px

    // ── Layout ──────────────────────────────────────────────────────────────
    PanelContainer {
        width:  root.width;
        height: root.height;
        panels: root.panels;
        panel-dragged(id, dx, dy) => { root.panel-dragged(id, dx, dy); }
    }
}
