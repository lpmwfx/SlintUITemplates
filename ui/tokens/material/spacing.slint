// Material 3 spacing — 8dp base grid.
// Reference: https://m3.material.io/foundations/layout/understanding-layout/spacing

export global MaterialSpacing {
    out property <length> xs:   4px;
    out property <length> sm:   8px;
    out property <length> md:  16px;
    out property <length> lg:  24px;
    out property <length> xl:  32px;

    // ── Component heights ─────────────────────────────────────────────────
    out property <length> top-app-bar-height:    64px;
    out property <length> bottom-nav-bar-height: 80px;
    out property <length> nav-item-height:       64px;
    out property <length> fab-size:              56px;
    out property <length> fab-extended-height:   56px;
    out property <length> icon-button-size:      48px;
}
