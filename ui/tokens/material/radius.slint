// Material 3 shape tokens — corner radii.
// Reference: https://m3.material.io/styles/shape/shape-scale-tokens

export global MaterialRadius {
    out property <length> none:       0px;
    out property <length> extra-small: 4px;
    out property <length> small:       8px;
    out property <length> medium:     12px;
    out property <length> large:      16px;
    out property <length> extra-large: 28px;  // FAB, BottomSheet
    out property <length> full:       9999px; // pills, avatars
}
