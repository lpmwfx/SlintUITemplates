export global Type {
    out property <length> caption-size:  12px;
    out property <length> body-size:     14px;
    out property <length> subtitle-size: 16px;
    out property <length> heading-size:  20px;
    out property <length> title-size:    28px;

    out property <int> weight-regular:   400;
    out property <int> weight-semibold:  600;
    out property <int> weight-bold:      700;
}
