// macOS type scale — SF Pro / SF Compact sizes per Apple HIG.
// Reference: https://developer.apple.com/design/human-interface-guidelines/typography

import { Settings } from "../../state/settings.slint";

export global MacosType {
    // ── Sizes (reactive: zoom × font-scale) ──────────────────────────────
    /// Caption 2 / footnote — smallest readable.
    out property <length> caption:   Settings.zoom * Settings.font-scale * 11px;
    /// Caption 1 / subheadline.
    out property <length> subhead:   Settings.zoom * Settings.font-scale * 12px;
    /// Body — standard reading size.
    out property <length> body:      Settings.zoom * Settings.font-scale * 13px;
    /// Callout — slightly larger body.
    out property <length> callout:   Settings.zoom * Settings.font-scale * 14px;
    /// Headline / section title.
    out property <length> headline:  Settings.zoom * Settings.font-scale * 15px;
    /// Title 3 — smaller dialog heading.
    out property <length> title3:    Settings.zoom * Settings.font-scale * 17px;
    /// Title 2.
    out property <length> title2:    Settings.zoom * Settings.font-scale * 20px;
    /// Title 1 — large heading.
    out property <length> title1:    Settings.zoom * Settings.font-scale * 26px;
    /// Large title — hero / window title.
    out property <length> title:     Settings.zoom * Settings.font-scale * 34px;

    // ── Weights ───────────────────────────────────────────────────────────
    /// Regular weight (SF Pro Text).
    out property <int> weight-regular:  400;
    /// Medium weight.
    out property <int> weight-medium:   500;
    /// Semibold — preferred for macOS headings.
    out property <int> weight-semibold: 600;
    /// Bold weight.
    out property <int> weight-bold:     700;

    // ── Font family (cross-platform fallback chain) ────────────────────────
    /// System font: SF Pro on macOS, system-ui elsewhere.
    out property <string> font-system: "SF Pro Text";
    /// Monospace: SF Mono on macOS, monospace elsewhere.
    out property <string> font-mono:   "SF Mono";
}
