import { Colors, Spacing, Sizes } from "../globals/theme.slint";
import { NavItem } from "../state/desktop-types.slint";
import { SideBarRow } from "side-bar-row.slint";

// ── SideBar — scrollbart TOC-panel med kollapsible gruppe-headers ─────────────
// Pure child: receives items + active state, emits navigate / toggle-group.
/// S id eb ar component.
/// component `SideBar`.
/// component `SideBar`.
/// component `SideBar`.
/// component `SideBar`.
/// component `SideBar`.
/// component `SideBar`.
/// component `SideBar`.
export component SideBar inherits Rectangle {
    /// Input property "items".
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    in property <[NavItem]> items: [];
    /// Input property "active-item".
    /// property `active-item`.
    /// property `active-item`.
    /// property `active-item`.
    /// property `active-item`.
    /// property `active-item`.
    /// property `active-item`.
    /// property `active-item`.
    in property <string>    active-item: "";
    /// Input property "collapsed".
    /// property `collapsed`.
    /// property `collapsed`.
    /// property `collapsed`.
    /// property `collapsed`.
    /// property `collapsed`.
    /// property `collapsed`.
    /// property `collapsed`.
    in property <bool>      collapsed: false;
    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    callback navigate(string);
    /// Callback fired for t og gl e c ol la ps ed.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    /// callback `toggle-collapsed`.
    callback toggle-collapsed();
    /// Callback fired for t og gl e g ro up.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    callback toggle-group(string);

    background: Colors.bg-surface;

    // Right border — absolutely positioned at right edge
    Rectangle {
        x:          parent.width - Spacing.border;
        y:          Spacing.none;
        width:      Spacing.border;
        height:     parent.height;
        background: Colors.border;
    }

    VerticalLayout {
        // Scrollbart TOC-panel — fylder al tilgængelig plads
        toc-flick := Flickable {
            vertical-stretch: Sizes.fill;
            interactive:      true;

            toc-vl := VerticalLayout {
                width: toc-flick.width;

                for item in root.items: SideBarRow {
                    item:              item;
                    is-active:         item.id == root.active-item;
                    sidebar-collapsed: root.collapsed;
                    navigate(id)      => { root.navigate(id); }
                    toggle-group(id)  => { root.toggle-group(id); }
                }
            }
        }

        // Tynd divider over collapse-knap
        Rectangle {
            height:     Spacing.border;
            background: Colors.border;
        }

        // Collapse toggle
        Rectangle {
            height:     Spacing.xl;
            background: collapse-ta.has-hover ? Colors.bg-elevated : transparent;

            collapse-ta := TouchArea {
                clicked => { root.toggle-collapsed(); }
            }

            Text {
                text:                root.collapsed ? "\u{00BB}" : "\u{00AB}";
                font-size:           Spacing.md;
                color:               Colors.text-secondary;
                horizontal-alignment: TextHorizontalAlignment.center;
                vertical-alignment:  TextVerticalAlignment.center;
            }
        }
    }
}
