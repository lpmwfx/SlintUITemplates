import { Colors, Spacing, Type, Sizes } from "../globals/theme.slint";
import { Strings } from "../globals/strings.slint";
import { NavItem } from "../state/desktop-types.slint";

// ── SideBarRow — enkelt navigationsrække (header eller fil-item) ──────────────
// Pure child: receives item data via in property, emits clicks via callbacks.
/// S id eb ar ro w component.
/// component `SideBarRow`.
/// component `SideBarRow`.
/// component `SideBarRow`.
/// component `SideBarRow`.
/// component `SideBarRow`.
/// component `SideBarRow`.
/// component `SideBarRow`.
export component SideBarRow inherits Rectangle {
    /// Input property "item".
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    in property <NavItem> item;
    /// Input property "is-active".
    /// property `is-active`.
    /// property `is-active`.
    /// property `is-active`.
    /// property `is-active`.
    /// property `is-active`.
    /// property `is-active`.
    /// property `is-active`.
    in property <bool>    is-active;
    /// Input property "sidebar-collapsed".
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    /// property `sidebar-collapsed`.
    in property <bool>    sidebar-collapsed;
    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    callback navigate(string);
    /// Callback fired for t og gl e g ro up.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    /// callback `toggle-group`.
    callback toggle-group(string);

    height:     item.hidden ? Spacing.none : Spacing.xl;
    clip:       true;
    background: is-active    ? Colors.bg-elevated :
                ta.has-hover ? Colors.bg-elevated :
                item.is-header ? Colors.bg-primary : transparent;

    // Always-present: hover detection + item navigation
    ta := TouchArea {
        clicked => { root.navigate(item.id); }
    }

    // Header overlay: intercepts clicks for collapsible group headers
    if item.is-header: TouchArea {
        clicked => { root.toggle-group(item.id); }
    }

    HorizontalLayout {
        padding-left:  Spacing.sm;
        padding-right: Spacing.sm;
        spacing:       Spacing.sm;
        alignment:     start;

        Text {
            text:               item.icon;
            font-size:          Type.subtitle-size;
            color:              is-active      ? Colors.accent :
                                item.is-header ? Colors.text-secondary : Colors.text-primary;
            vertical-alignment: center;
            width:              Spacing.lg;
        }

        if !root.sidebar-collapsed: Text {
            horizontal-stretch: Sizes.fill;
            text:               item.label;
            font-size:          item.is-header ? Type.caption-size  : Type.body-size;
            font-weight:        item.is-header ? Type.weight-semibold : Type.weight-regular;
            color:              is-active      ? Colors.accent :
                                item.is-header ? Colors.text-secondary : Colors.text-primary;
            vertical-alignment: center;
        }

        if !root.sidebar-collapsed && item.is-header: Text {
            text:               Strings.sidebar-header-icon;
            font-size:          Type.caption-size;
            color:              Colors.text-secondary;
            vertical-alignment: center;
            width:              Spacing.lg;
        }
    }

    // Separator under group-headers
    if item.is-header: Rectangle {
        y:          parent.height - Spacing.border;
        height:     Spacing.border;
        background: Colors.border;
    }
}
