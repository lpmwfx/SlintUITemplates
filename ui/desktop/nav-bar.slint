import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes }               from "../state/sizes.slint";

/// N av ba r component.
/// component `NavBar`.
export component NavBar inherits Rectangle {
    /// Input property "breadcrumb".
    /// property `breadcrumb`.
    in property <string> breadcrumb: "";
    /// Input property "can-go-back".
    /// property `can-go-back`.
    in property <bool> can-go-back: false;
    /// Callback fired for g o b ac k.
    /// callback `go-back`.
    callback go-back();
    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    callback navigate(string);

    /// Private property "back-icon" used internally.
    /// property `back-icon`.
    private property <string> back-icon: "\u{2190}";

    background: Colors.bg-surface;

    HorizontalLayout {
        padding-left: Spacing.md;
        padding-right: Spacing.md;
        spacing: Spacing.sm;
        alignment: start;

        // Back button
        if root.can-go-back: Rectangle {
            width: Sizes.icon-xl;

            Text {
                text: root.back-icon;
                font-size: Type.subtitle-size;
                color: Colors.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            TouchArea {
                clicked => { root.go-back(); }
            }
        }

        // Breadcrumb label
        Text {
            text: root.breadcrumb;
            font-size: Type.body-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
            vertical-alignment: center;
        }
    }
}
