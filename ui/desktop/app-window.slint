import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { NavBar }      from "nav-bar.slint";
import { NavItem }     from "types.slint";
import { SideBar }     from "side-bar.slint";
import { ContentArea } from "content-area.slint";
import { StatusBar }   from "status-bar.slint";

export { Colors }
export { NavItem }

export component AppWindow inherits Window {
    title: "SlintUI Templates";
    preferred-width: 900px;
    preferred-height: 600px;
    background: Colors.bg-primary;

    // State (mother owns all)
    in-out property <string>    active-view: "home";
    in-out property <bool>      sidebar-open: true;
    in-out property <bool>      sidebar-collapsed: false;
    in-out property <[NavItem]> nav-items: [
        { id: "home",     label: "Home",     icon: "🏠" },
        { id: "list",     label: "List",     icon: "📋" },
        { id: "settings", label: "Settings", icon: "⚙" },
    ];

    // Grid ratios (pushed from Rust grid engine)
    in-out property <float> row-top-ratio: 1;
    in-out property <float> row-main-ratio: 10;
    in-out property <float> row-bottom-ratio: 1;
    in-out property <float> col-left-ratio: 3;
    in-out property <float> col-center-ratio: 4;
    in-out property <float> col-right-ratio: 3;

    // Private sizing (token expressions — no literals)
    property <length> sidebar-expanded-width:  Spacing.xl * 4 + Spacing.md;
    property <length> sidebar-collapsed-width: Spacing.xl + Spacing.sm;

    callback navigate(string);
    navigate(view) => { self.active-view = view; }

    VerticalLayout {
        NavBar {
            vertical-stretch: root.row-top-ratio;
            breadcrumb: root.active-view;
            can-go-back: root.active-view != "home";
            go-back => { root.active-view = "home"; }
        }

        HorizontalLayout {
            vertical-stretch: root.row-main-ratio;

            SideBar {
                horizontal-stretch: 0;
                min-width: root.sidebar-collapsed
                    ? root.sidebar-collapsed-width
                    : root.sidebar-expanded-width;
                items: root.nav-items;
                active-item: root.active-view;
                collapsed: root.sidebar-collapsed;
                navigate(id) => { root.active-view = id; }
                toggle-collapsed() => { root.sidebar-collapsed = !root.sidebar-collapsed; }
                animate min-width { duration: 200ms; easing: ease-in-out; }
            }

            ContentArea {
                horizontal-stretch: root.col-center-ratio;
                active-view: root.active-view;
                navigate(view) => { root.active-view = view; }
            }

            // Right zone — placeholder (phase 4 scope)
            Rectangle {
                horizontal-stretch: root.col-right-ratio;
                background: Colors.bg-surface;
                border-width: 1px;
                border-color: Colors.border;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "right";
                        font-size: Type.caption-size;
                        color: Colors.text-secondary;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        StatusBar {
            vertical-stretch: root.row-bottom-ratio;
            status-text: "View: " + root.active-view;
        }
    }
}
