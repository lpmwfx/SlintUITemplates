import { Colors, Spacing, Type, Settings, FluentIcons } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { Strings } from "../globals/strings.slint";
import { Variants }    from "../globals/variants.slint";
import { NavId }       from "../state/nav-id.slint";
import { NavBar }      from "nav-bar.slint";
import { NavItem }     from "../state/desktop-types.slint";
import { SideBar }     from "side-bar.slint";
import { ContentArea } from "content-area.slint";
import { StatusBar }   from "status-bar.slint";
import { DragHandle }  from "../modules/DragHandle.slint";
import { ShellToolbar }     from "../shell/desktop/tool-bar.slint";
import { ShellToolbarItem } from "../shell/types.slint";

export { Colors }
export { Settings }
export { NavItem }

/// Desktop application window component.
/// component `AppWindow`.
export component AppWindow inherits Window {
    /// Window title text.
    /// property `window-title`.
    in property <string> window-title: "SlintUI Templates";
    title: window-title;
    icon: @image-url("../../assets/rustui-icon.png");
    preferred-width: Sizes.win-width-sm;
    preferred-height: Sizes.win-height-sm;
    default-font-family: Settings.font-family;

    // Window background follows Theme.bg-primary — transparent for mica/acrylic,
    // opaque solid for solid. Theme.material is set by Rust via Theme global.
    background: Colors.bg-primary;

    // State (mother owns all)
    /// Active view identifier.
    /// property `active-view`.
    in property <string>    active-view: NavId.home;
    property <bool>      sidebar-open: true;
    property <bool>      sidebar-collapsed: false;
    /// Navigation item model.
    /// property `nav-items`.
    in property <[NavItem]> nav-items: [
        { id: NavId.home,     label: "Home",     icon: FluentIcons.home },
        { id: NavId.list,     label: "List",     icon: FluentIcons.list },
        { id: NavId.settings, label: "Settings", icon: FluentIcons.settings },
    ];

    // Toolbar
    /// Whether the toolbar is visible.
    /// property `show-toolbar`.
    in property <bool>               show-toolbar:  false;
    /// Toolbar item model.
    /// property `toolbar-items`.
    in property <[ShellToolbarItem]> toolbar-items: [];

    // Status bar text (Rhai / Rust override; empty = default "View: <active-view>")
    /// Custom status bar text override.
    /// property `status-text`.
    in property <string> status-text: Strings.label-default;
    /// Status bar prefix text.
    /// property `status-prefix`.
    in property <string> status-prefix: Strings.status-view-prefix;
    /// Right panel label.
    /// property `right-panel-label`.
    in property <string> right-panel-label: "right";

    // Menu labels
    /// File menu label.
    /// property `menu-file-label`.
    in property <string> menu-file-label: "File";
    /// Exit menu label.
    /// property `menu-exit-label`.
    in property <string> menu-exit-label: "Exit";
    /// View menu label.
    /// property `menu-view-label`.
    in property <string> menu-view-label: "View";
    /// Home menu label.
    /// property `menu-home-label`.
    in property <string> menu-home-label: "Home";
    /// List menu label.
    /// property `menu-list-label`.
    in property <string> menu-list-label: "List";
    /// Settings menu label.
    /// property `menu-settings-label`.
    in property <string> menu-settings-label: "Settings";
    /// Help menu label.
    /// property `menu-help-label`.
    in property <string> menu-help-label: "Help";
    /// About menu label.
    /// property `menu-about-label`.
    in property <string> menu-about-label: "About";

    // Callbacks wired by DSL / Rust host
    /// Callback fired for menu action.
    /// callback `menu-action`.
    callback menu-action(string);
    /// Callback fired for toolbar click.
    /// callback `toolbar-clicked`.
    callback toolbar-clicked(string);

    // Grid ratios (pushed from Rust grid engine)
    /// Top row stretch ratio.
    /// property `row-top-ratio`.
    in property <float> row-top-ratio: Sizes.fill;
    /// Main row stretch ratio.
    /// property `row-main-ratio`.
    in property <float> row-main-ratio: Sizes.ten;
    /// Bottom row stretch ratio.
    /// property `row-bottom-ratio`.
    in property <float> row-bottom-ratio: Sizes.fill;

    // Column pixel widths — draggable (no literals — token expressions)
    property <length> col-left-width:  Spacing.xl * Sizes.four + Spacing.md;
    property <length> col-right-width: Spacing.xl * Sizes.five;

    // Reference widths for sidebar toggle snap
    property <length> sidebar-expanded-width:  Spacing.xl * Sizes.four + Spacing.md;
    property <length> sidebar-collapsed-width: Spacing.xl + Spacing.sm;

    /// Callback fired for navigation.
    /// callback `navigate`.
    callback navigate(string);

    // Native OS menu bar (muda-backed via Slint — must live in Window)
    MenuBar {
        Menu {
            title: root.menu-file-label;
            MenuItem { title: root.menu-exit-label; activated => { } }
        }
        Menu {
            title: root.menu-view-label;
            MenuItem { title: root.menu-home-label;     activated => { root.navigate(NavId.home); } }
            MenuItem { title: root.menu-list-label;     activated => { root.navigate(NavId.list); } }
            MenuItem { title: root.menu-settings-label; activated => { root.navigate(NavId.settings); } }
        }
        Menu {
            title: root.menu-help-label;
            MenuItem { title: root.menu-about-label; activated => { } }
        }
    }

    VerticalLayout {
        // ROW: toolbar (optional, below native MenuBar)
        if root.show-toolbar: ShellToolbar {
            items: root.toolbar-items;
            item-clicked(id) => { root.toolbar-clicked(id); }
        }

        // ROW: top — NavBar (fixed, not resizable)
        NavBar {
            vertical-stretch: root.row-top-ratio;
            breadcrumb: root.active-view;
            can-go-back: root.active-view != NavId.home;
            go-back => { root.navigate(NavId.home); }
        }

        // ROW: main — 3 columns with draggable vertical gutters
        HorizontalLayout {
            vertical-stretch: root.row-main-ratio;

            // Left — SideBar (fixed width, drag-resizable)
            SideBar {
                horizontal-stretch: Sizes.zero;
                min-width: root.sidebar-collapsed ? root.sidebar-collapsed-width : root.col-left-width;
                max-width: root.sidebar-collapsed ? root.sidebar-collapsed-width : root.col-left-width;
                items: root.nav-items;
                active-item: root.active-view;
                collapsed: root.sidebar-collapsed;
                navigate(id) => { root.navigate(id); }
                toggle-collapsed() => { root.sidebar-collapsed = !root.sidebar-collapsed; }
            }

            // Gutter: left | center (draggable)
            DragHandle {
                min-width: Spacing.handle-thickness;
                max-width: Spacing.handle-thickness;
                vertical: false;
                dragged(dx, dy) => {
                    root.col-left-width = clamp(root.col-left-width + dx * Sizes.border-w, root.sidebar-collapsed-width, Sizes.panel-xl);
                }
            }

            // Center — ContentArea (takes remaining space)
            ContentArea {
                horizontal-stretch: Sizes.one;
                active-view: root.active-view;
                navigate(view) => { root.navigate(view); }
            }

            // Gutter: center | right (draggable)
            DragHandle {
                min-width: Spacing.handle-thickness;
                max-width: Spacing.handle-thickness;
                vertical: false;
                dragged(dx, dy) => {
                    root.col-right-width = clamp(root.col-right-width - dx * Sizes.border-w, Spacing.xl + Spacing.lg, Sizes.panel-xl);
                }
            }

            // Right — placeholder (phase 4 scope, fixed width, drag-resizable)
            Rectangle {
                horizontal-stretch: Sizes.zero;
                min-width: root.col-right-width;
                max-width: root.col-right-width;
                background: Colors.bg-surface;

                Text {
                    text: root.right-panel-label;
                    font-size: Type.caption-size;
                    color: Colors.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ROW: bottom — StatusBar (fixed, not resizable)
        StatusBar {
            vertical-stretch: root.row-bottom-ratio;
            status-text: root.status-text != Strings.label-default ? root.status-text : root.status-prefix + root.active-view;
        }
    }
}
