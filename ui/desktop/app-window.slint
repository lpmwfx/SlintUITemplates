import { Colors, Spacing, Type, Settings, FluentIcons } from "../tokens/theme.slint";
import { NavBar }      from "nav-bar.slint";
import { NavItem }     from "types.slint";
import { SideBar }     from "side-bar.slint";
import { ContentArea } from "content-area.slint";
import { StatusBar }   from "status-bar.slint";
import { DragHandle }  from "../modules/DragHandle.slint";
import { ShellToolbar }     from "../shell/desktop/tool-bar.slint";
import { ShellToolbarItem } from "../shell/types.slint";

export { Colors }
export { Settings }
export { NavItem }

export component AppWindow inherits Window {
    title: "SlintUI Templates";
    preferred-width: 900px;
    preferred-height: 600px;
    background: Colors.bg-primary;
    default-font-family: Settings.font-family;

    // State (mother owns all)
    in-out property <string>    active-view: "home";
    in-out property <bool>      sidebar-open: true;
    in-out property <bool>      sidebar-collapsed: false;
    in-out property <[NavItem]> nav-items: [
        { id: "home",     label: "Home",     icon: FluentIcons.home },
        { id: "list",     label: "List",     icon: FluentIcons.list },
        { id: "settings", label: "Settings", icon: FluentIcons.settings },
    ];

    // Toolbar
    in property <bool>               show-toolbar:  false;
    in property <[ShellToolbarItem]> toolbar-items: [];

    // Status bar text (Rhai / Rust override; empty = default "View: <active-view>")
    in-out property <string> status-text: "";

    // Callbacks wired by DSL / Rust host
    callback menu-action(string);
    callback toolbar-clicked(string);

    // Grid ratios (pushed from Rust grid engine)
    in-out property <float> row-top-ratio: 1;
    in-out property <float> row-main-ratio: 10;
    in-out property <float> row-bottom-ratio: 1;

    // Column pixel widths — draggable (no literals — token expressions)
    in-out property <length> col-left-width:  Spacing.xl * 4 + Spacing.md;   // 208px
    in-out property <length> col-right-width: Spacing.xl * 5;                 // 240px

    // Reference widths for sidebar toggle snap
    property <length> sidebar-expanded-width:  Spacing.xl * 4 + Spacing.md;
    property <length> sidebar-collapsed-width: Spacing.xl + Spacing.sm;

    callback navigate(string);
    navigate(view) => { self.active-view = view; }

    // Native OS menu bar (muda-backed via Slint — must live in Window)
    MenuBar {
        Menu {
            title: "File";
            MenuItem { title: "Exit"; activated => { } }
        }
        Menu {
            title: "View";
            MenuItem { title: "Home";     activated => { root.active-view = "home"; } }
            MenuItem { title: "List";     activated => { root.active-view = "list"; } }
            MenuItem { title: "Settings"; activated => { root.active-view = "settings"; } }
        }
        Menu {
            title: "Help";
            MenuItem { title: "About"; activated => { } }
        }
    }

    VerticalLayout {
        // ROW: toolbar (optional, below native MenuBar)
        if root.show-toolbar: ShellToolbar {
            items: root.toolbar-items;
            item-clicked(id) => { root.toolbar-clicked(id); }
        }

        // ROW: top — NavBar (fixed, not resizable)
        NavBar {
            vertical-stretch: root.row-top-ratio;
            breadcrumb: root.active-view;
            can-go-back: root.active-view != "home";
            go-back => { root.active-view = "home"; }
        }

        // ROW: main — 3 columns with draggable vertical gutters
        HorizontalLayout {
            vertical-stretch: root.row-main-ratio;

            // Left — SideBar (fixed width, drag-resizable)
            SideBar {
                horizontal-stretch: 0;
                min-width: root.col-left-width;
                max-width: root.col-left-width;
                items: root.nav-items;
                active-item: root.active-view;
                collapsed: root.sidebar-collapsed;
                navigate(id) => { root.active-view = id; }
                toggle-collapsed() => {
                    root.sidebar-collapsed = !root.sidebar-collapsed;
                    root.col-left-width = root.sidebar-collapsed
                        ? root.sidebar-collapsed-width
                        : root.sidebar-expanded-width;
                }
            }

            // Gutter: left | center (draggable)
            DragHandle {
                min-width: Spacing.handle-thickness;
                max-width: Spacing.handle-thickness;
                vertical: false;
                dragged(dx, dy) => {
                    root.col-left-width = root.col-left-width + dx * 1px;
                    if (root.col-left-width < root.sidebar-collapsed-width) {
                        root.col-left-width = root.sidebar-collapsed-width;
                    }
                }
            }

            // Center — ContentArea (takes remaining space)
            ContentArea {
                horizontal-stretch: 1;
                active-view: root.active-view;
                navigate(view) => { root.active-view = view; }
            }

            // Gutter: center | right (draggable)
            DragHandle {
                min-width: Spacing.handle-thickness;
                max-width: Spacing.handle-thickness;
                vertical: false;
                dragged(dx, dy) => {
                    root.col-right-width = root.col-right-width - dx * 1px;
                    if (root.col-right-width < Spacing.xl + Spacing.lg) {
                        root.col-right-width = Spacing.xl + Spacing.lg;
                    }
                }
            }

            // Right — placeholder (phase 4 scope, fixed width, drag-resizable)
            Rectangle {
                horizontal-stretch: 0;
                min-width: root.col-right-width;
                max-width: root.col-right-width;
                background: Colors.bg-surface;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "right";
                        font-size: Type.caption-size;
                        color: Colors.text-secondary;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // ROW: bottom — StatusBar (fixed, not resizable)
        StatusBar {
            vertical-stretch: root.row-bottom-ratio;
            status-text: root.status-text != "" ? root.status-text : "View: " + root.active-view;
        }
    }
}
