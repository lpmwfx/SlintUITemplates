import { Colors, Spacing, Type } from "../tokens/theme.slint";

export component StatusBar inherits Rectangle {
    in property <string> status-text: "Ready";
    in property <float>  progress: 0.0;
    in property <bool>   show-progress: false;

    preferred-width: 100%;
    background: Colors.bg-elevated;

    // Progress bar track width — token-derived (48+48+24 = 120px)
    property <length> bar-width: Spacing.xl + Spacing.xl + Spacing.lg;

    HorizontalLayout {
        padding-left: Spacing.md;
        padding-right: Spacing.md;
        spacing: Spacing.sm;

        Text {
            text: root.status-text;
            font-size: Type.caption-size;
            color: Colors.text-secondary;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        if root.show-progress: Rectangle {
            width: root.bar-width;
            height: Spacing.sm;
            border-radius: Spacing.xs;
            background: Colors.bg-surface;

            Rectangle {
                x: 0;
                y: 0;
                width: root.bar-width * root.progress;
                height: parent.height;
                border-radius: Spacing.xs;
                background: Colors.accent;
            }
        }
    }
}
