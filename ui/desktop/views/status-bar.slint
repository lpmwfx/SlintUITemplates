import { Colors, Spacing, Type } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { Strings } from "../../globals/strings.slint";

/// S ta tu sb ar component.
/// component `StatusBar`.
/// component `StatusBar`.
/// component `StatusBar`.
/// component `StatusBar`.
/// component `StatusBar`.
/// component `StatusBar`.
/// component `StatusBar`.
export component StatusBar inherits Rectangle {
    /// Input property "status-text".
    /// property `status-text`.
    /// property `status-text`.
    /// property `status-text`.
    /// property `status-text`.
    /// property `status-text`.
    /// property `status-text`.
    /// property `status-text`.
    in property <string> status-text: Strings.app-status-ready;
    /// Input property "progress".
    /// property `progress`.
    /// property `progress`.
    /// property `progress`.
    /// property `progress`.
    /// property `progress`.
    /// property `progress`.
    /// property `progress`.
    in property <float>  progress: Sizes.no-fill;
    /// Input property "show-progress".
    /// property `show-progress`.
    /// property `show-progress`.
    /// property `show-progress`.
    /// property `show-progress`.
    /// property `show-progress`.
    /// property `show-progress`.
    /// property `show-progress`.
    in property <bool>   show-progress: false;

    // Remove preferred-width — let parent control layout
    background: Colors.bg-elevated;

    // Progress bar track width — token-derived (48+48+24 = 120px)
    property <length> bar-width: Spacing.xl + Spacing.xl + Spacing.lg;

    HorizontalLayout {
        padding-left: Spacing.md;
        padding-right: Spacing.md;
        spacing: Spacing.sm;

        Text {
            text: root.status-text;
            font-size: Type.caption-size;
            color: Colors.text-secondary;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: Sizes.one; }

        if root.show-progress: Rectangle {
            width: root.bar-width;
            height: Spacing.sm;
            border-radius: Spacing.xs;
            background: Colors.bg-surface;

            Rectangle {
                x: Sizes.no-size;
                y: Sizes.no-size;
                width: root.bar-width * root.progress;
                height: parent.height;
                border-radius: Spacing.xs;
                background: Colors.accent;
            }
        }
    }
}
