import { Colors } from "../globals/theme.slint";
import { NavId }       from "../state/nav-id.slint";
import { HomeView }     from "../views/home.slint";
import { ListView }     from "../views/list.slint";
import { SettingsView } from "../views/settings.slint";

// Routes active-view to the designer-editable views in ui/views/.
// To add a view: create ui/views/my-view.slint, add an import + if-block below.
/// C on te nt ar ea component.
/// component `ContentArea`.
/// component `ContentArea`.
/// component `ContentArea`.
/// component `ContentArea`.
/// component `ContentArea`.
/// component `ContentArea`.
/// component `ContentArea`.
export component ContentArea inherits Rectangle {
    /// Input property "active-view".
    /// property `active-view`.
    /// property `active-view`.
    /// property `active-view`.
    /// property `active-view`.
    /// property `active-view`.
    /// property `active-view`.
    /// property `active-view`.
    in property <string> active-view: NavId.home;
    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    callback navigate(string);

    background: Colors.bg-primary;

    if root.active-view == NavId.home:     HomeView     {}
    if root.active-view == NavId.list:     ListView     {}
    if root.active-view == NavId.settings: SettingsView {}
}
