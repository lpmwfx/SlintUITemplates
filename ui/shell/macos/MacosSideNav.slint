// MacosSideNav — macOS left sidebar showing nav items.
// Fixed sidebar-width, surface background, right-edge separator.

import { Colors }                              from "../../globals/theme.slint";
import { MacosColors, MacosSpacing }           from "../../globals/theme/macos/mod.slint";
import { Sizes }                               from "../../state/sizes.slint";
import { NavItem }                             from "../types.slint";
import { MacosNavItem }                        from "MacosNavItem.slint";

/// macOS left sidebar — stacked nav items inside a fixed-width surface panel.
/// component `MacosSideNav`.
export component MacosSideNav inherits Rectangle {
    /// Items to render in the sidebar.
    /// property `items`.
    in property <[NavItem]> items;
    /// Id of the currently active item.
    /// property `active-item`.
    in property <string>    active-item;

    /// Fired when a nav item is selected.
    /// callback `navigate`.
    callback navigate(string);

    width:      MacosSpacing.sidebar-width;
    background: Colors.dark ? MacosColors.bg-surface-dark : MacosColors.bg-surface-light;

    // ── Nav items ─────────────────────────────────────────────────────────────
    VerticalLayout {
        padding: MacosSpacing.xs;
        spacing: MacosSpacing.xs;

        for item in root.items: MacosNavItem {
            item:   item;
            active: item.id == root.active-item;
            navigate(id) => { root.navigate(id); }
        }
    }

    // ── Right-edge separator (drawn on top of layout) ─────────────────────────
    Rectangle {
        x:          root.width - Sizes.border-w;
        y:          Sizes.no-size;
        width:      Sizes.border-w;
        height:     root.height;
        background: Colors.border;
    }
}
