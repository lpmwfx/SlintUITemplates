// Material 3 NavigationBar (bottom nav) — 3-5 destinations.
// Reference: https://m3.material.io/components/navigation-bar

import { MaterialColors, MaterialSpacing } from "../../../globals/theme/material/mod.slint";
import { Sizes } from "../../../globals/theme/sizes.slint";
import { NavItem }       from "../../types.slint";
import { BottomNavItem } from "BottomNavItem.slint";

/// B ot to mn av ba r component.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
/// component `BottomNavBar`.
export component BottomNavBar inherits Rectangle {
    /// Input property "items".
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    in property <[NavItem]> items;
    /// Input property "active".
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    in property <string>    active: "";
    /// Input property "icon-font".
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    in property <string>    icon-font: "Segoe Fluent Icons";
    /// Callback fired for n av ig at e.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    /// callback `navigate`.
    callback navigate(string);

    /// Private property "pad-top" used internally.
    /// property `pad-top`.
    /// property `pad-top`.
    /// property `pad-top`.
    /// property `pad-top`.
    /// property `pad-top`.
    /// property `pad-top`.
    /// property `pad-top`.
    private property <length> pad-top: Sizes.comp-12;
    /// Private property "pill-w" used internally.
    /// property `pill-w`.
    /// property `pill-w`.
    /// property `pill-w`.
    /// property `pill-w`.
    /// property `pill-w`.
    /// property `pill-w`.
    /// property `pill-w`.
    private property <length> pill-w:  Sizes.comp-64;

    height: MaterialSpacing.bottom-nav-bar-height;
    background: MaterialColors.surface-container;

    // Top border
    Rectangle {
        height: Sizes.border-w;
        background: MaterialColors.outline-variant;
    }

    HorizontalLayout {
        padding-top: root.pad-top;
        padding-bottom: Sizes.icon-sm;

        for item in root.items: BottomNavItem {
            item-id: item.id;
            icon: item.icon;
            label: item.label;
            icon-font: root.icon-font;
            is-active: item.id == root.active;
            pill-w: root.pill-w;
            clicked => { root.navigate(item.id); }
        }
    }
}
