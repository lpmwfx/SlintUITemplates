// ShellSideNav — Fluent 2 NavigationView left panel.
// Collapsible; shows icon + label per nav item; Segoe Fluent Icons.

import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";
import { Sizes }    from "../../state/sizes.slint";
import { NavItem }  from "../types.slint";
import { NavItemRow } from "NavItemRow.slint";

/// Collapsible desktop side navigation listing shell destinations.
/// component `ShellSideNav`.
export component ShellSideNav inherits Rectangle {
    /// Navigation items rendered in the side rail.
    /// property `items`.
    in property <[NavItem]> items;
    /// Id of the currently active navigation item.
    /// property `active-item`.
    in property <string>    active-item: "";
    /// Renders the compact icon-only mode when `true`.
    /// property `collapsed`.
    in property <bool>      collapsed: false;
    /// Font family used to render icon glyph strings.
    /// property `icon-font`.
    in property <string>    icon-font: "Segoe Fluent Icons";
    /// Fired when the user chooses a navigation item.
    /// callback `navigate`.
    callback navigate(string);
    /// Fired when the collapse/expand affordance is clicked.
    /// callback `toggle-collapsed`.
    callback toggle-collapsed();

    /// Private property "active-alpha" used internally.
    /// property `active-alpha`.
    private property <float>  active-alpha: Sizes.alpha-15;
    /// Private property "indicator-w" used internally.
    /// property `indicator-w`.
    private property <length> indicator-w: Sizes.border-w-3;
    /// Private property "indicator-radius" used internally.
    /// property `indicator-radius`.
    private property <length> indicator-radius: Sizes.border-w-2;

    background: Colors.bg-surface;

    HorizontalLayout {
        // Nav item list
        VerticalLayout {
            horizontal-stretch: Sizes.one;
            padding-top: Spacing.sm;

            for item in root.items: NavItemRow {
                item-id: item.id;
                icon: item.icon;
                label: item.label;
                icon-font: root.icon-font;
                is-active: item.id == root.active-item;
                collapsed: root.collapsed;
                active-alpha: root.active-alpha;
                indicator-w: root.indicator-w;
                indicator-radius: root.indicator-radius;
                clicked => { root.navigate(item.id); }
            }

            Rectangle { vertical-stretch: Sizes.one; }

            // Collapse toggle button
            Rectangle {
                height: Spacing.xl;
                border-radius: Sizes.track-h;
                background: collapse-ta.has-hover ? Colors.bg-elevated : transparent;

                collapse-ta := TouchArea {
                    clicked => { root.toggle-collapsed(); }
                }

                Text {
                    text: root.collapsed ? FluentIcons.nav-expand : FluentIcons.nav-collapse;
                    font-family: root.icon-font;
                    font-size: Type.subtitle-size;
                    color: Colors.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Right border
        Rectangle {
            width: Sizes.border-w;
            background: Colors.border;
        }
    }
}
