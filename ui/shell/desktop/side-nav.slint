// ShellSideNav — Fluent 2 NavigationView left panel.
// Collapsible; shows icon + label per nav item; Segoe Fluent Icons.

import { Colors, Spacing, Type, FluentIcons } from "../../tokens/theme.slint";
import { NavItem } from "../types.slint";

export component ShellSideNav inherits Rectangle {
    in property <[NavItem]> items;
    in property <string>    active-item: "";
    in property <bool>      collapsed: false;
    callback navigate(string);
    callback toggle-collapsed();

    background: Colors.bg-surface;
    // Width is controlled by parent (DesktopShell sets min-width/max-width)

    HorizontalLayout {
        // Nav item list
        VerticalLayout {
            horizontal-stretch: 1;
            padding-top: Spacing.sm;

            for item in root.items: Rectangle {
                height: Spacing.xl;
                clip: true;
                border-radius: 4px;
                background: item.id == root.active-item ? Colors.accent.with-alpha(0.15) :
                            item-ta.has-hover ? Colors.bg-elevated : transparent;

                item-ta := TouchArea {
                    clicked => { root.navigate(item.id); }
                }

                // Active indicator bar
                if item.id == root.active-item: Rectangle {
                    width: 3px;
                    height: 20px;
                    y: (parent.height - self.height) / 2;
                    background: Colors.accent;
                    border-radius: 2px;
                }

                HorizontalLayout {
                    padding-left: Spacing.sm;
                    padding-right: Spacing.sm;
                    spacing: Spacing.sm;
                    alignment: start;

                    Text {
                        text: item.icon;
                        font-family: "Segoe Fluent Icons";
                        font-size: Type.subtitle-size;
                        color: item.id == root.active-item ? Colors.accent : Colors.text-primary;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        width: Spacing.lg;
                    }

                    if !root.collapsed: Text {
                        text: item.label;
                        font-size: Type.body-size;
                        color: item.id == root.active-item ? Colors.accent : Colors.text-primary;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            // Collapse toggle button
            Rectangle {
                height: Spacing.xl;
                border-radius: 4px;
                background: collapse-ta.has-hover ? Colors.bg-elevated : transparent;

                collapse-ta := TouchArea {
                    clicked => { root.toggle-collapsed(); }
                }

                Text {
                    text: root.collapsed ? FluentIcons.nav-expand : FluentIcons.nav-collapse;
                    font-family: "Segoe Fluent Icons";
                    font-size: Type.subtitle-size;
                    color: Colors.text-secondary;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // Right border
        Rectangle {
            width: 1px;
            background: Colors.border;
        }
    }
}
