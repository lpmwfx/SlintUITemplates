// ShellToolbar — optional Fluent 2 icon toolbar below the menu bar.

import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { ShellToolbarItem } from "../types.slint";

/// Desktop icon toolbar rendered below the menu bar when enabled.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
/// component `ShellToolbar`.
export component ShellToolbar inherits Rectangle {
    /// Toolbar items to render left-to-right.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    in property <[ShellToolbarItem]> items;
    /// Fired with the clicked toolbar item id.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    /// callback `item-clicked`.
    callback item-clicked(string);

    /// Private property "icon-font" used internally.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    /// property `icon-font`.
    private property <string> icon-font: "Segoe Fluent Icons";

    height: Spacing.xl;
    background: Colors.bg-surface;

    HorizontalLayout {
        padding-left: Spacing.sm;
        padding-right: Spacing.sm;
        spacing: Spacing.xs;
        alignment: start;

        for item in root.items: Rectangle {
            width: Spacing.xl;
            height: Spacing.xl;
            border-radius: Sizes.track-h;
            background: btn-ta.has-hover ? Colors.bg-elevated : transparent;

            btn-ta := TouchArea {
                clicked => { root.item-clicked(item.id); }
            }

            Text {
                text: item.icon;
                font-family: root.icon-font;
                font-size: Type.subtitle-size;
                color: Colors.text-primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // Bottom border
    Rectangle {
        y: parent.height - Sizes.border-w;
        height: Sizes.border-w;
        background: Colors.border;
    }
}
