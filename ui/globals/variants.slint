// Variants — named constants for component variant/style discriminators.
// Prevents stringly-typed state comparisons.

/// Variants global values.
export global Variants {
    // ── Button / component variants ─────────────────────────────────────
    /// Primary button variant.
    /// property `primary`.
    out property <string> primary:   "primary";
    /// Secondary button variant.
    /// property `secondary`.
    out property <string> secondary: "secondary";
    /// Accent button variant.
    /// property `accent`.
    out property <string> accent:    "accent";
    /// Danger button variant.
    /// property `danger`.
    out property <string> danger:    "danger";
    /// Outlined button variant.
    /// property `outlined`.
    out property <string> outlined:  "outlined";
    /// Ghost button variant.
    /// property `ghost`.
    out property <string> ghost:     "ghost";
    /// Text button variant.
    /// property `text`.
    out property <string> text:      "text";

    // ── Severity / status ───────────────────────────────────────────────
    /// Info severity variant.
    /// property `info`.
    out property <string> info:    "info";
    /// Success severity variant.
    /// property `success`.
    out property <string> success: "success";
    /// Warning severity variant.
    /// property `warning`.
    out property <string> warning: "warning";
    /// Error severity variant.
    /// property `error`.
    out property <string> error:   "error";

    // ── Platform ────────────────────────────────────────────────────────
    /// Desktop platform variant.
    /// property `desktop`.
    out property <string> desktop:     "desktop";
    /// Mobile platform variant.
    /// property `mobile`.
    out property <string> mobile:      "mobile";
    /// Windows platform variant.
    /// property `windows`.
    out property <string> windows:     "windows";
    /// Android platform variant.
    /// property `android`.
    out property <string> android:     "android";
    /// iOS platform variant.
    /// property `ios`.
    out property <string> ios:         "ios";
    /// macOS platform variant.
    /// property `macos`.
    out property <string> macos:       "macos";
    /// Linux platform variant.
    /// property `linux`.
    out property <string> linux:       "linux";
    /// Steam Linux platform variant.
    /// property `steam-linux`.
    out property <string> steam-linux: "steam-linux";
    /// Steam Deck platform variant.
    /// property `steam-deck`.
    out property <string> steam-deck:  "steam-deck";
    /// Tablet platform variant.
    /// property `tablet`.
    out property <string> tablet:      "tablet";
    /// Handheld platform variant.
    /// property `handheld`.
    out property <string> handheld:    "handheld";
    /// GNOME platform variant.
    /// property `gnome`.
    out property <string> gnome:       "gnome";
    /// KDE platform variant.
    /// property `kde`.
    out property <string> kde:         "kde";

    // ── Nav style ─────────────────────────────────────────────────────────
    /// Sidebar navigation variant.
    /// property `nav-sidebar`.
    out property <string> nav-sidebar: "nav-sidebar";
    /// Bottom navigation variant.
    /// property `nav-bottom`.
    out property <string> nav-bottom:  "nav-bottom";
    /// Compact navigation variant.
    /// property `nav-compact`.
    out property <string> nav-compact: "nav-compact";
    /// Gamepad navigation variant.
    /// property `nav-gamepad`.
    out property <string> nav-gamepad: "nav-gamepad";

    // ── Theme ───────────────────────────────────────────────────────────
    /// System theme variant.
    /// property `system`.
    out property <string> system: "system";
    /// Dark theme variant.
    /// property `dark`.
    out property <string> dark:   "dark";
    /// Light theme variant.
    /// property `light`.
    out property <string> light:  "light";

    // ── Material / backdrop ───────────────────────────────────────────
    /// Solid backdrop variant.
    /// property `solid`.
    out property <string> solid:   "solid";
    /// Mica backdrop variant.
    /// property `mica`.
    out property <string> mica:    "mica";
    /// Acrylic backdrop variant.
    /// property `acrylic`.
    out property <string> acrylic: "acrylic";

    // ── Orientation / position ──────────────────────────────────────────
    /// Horizontal orientation variant.
    /// property `horizontal`.
    out property <string> horizontal: "horizontal";
    /// Vertical orientation variant.
    /// property `vertical`.
    out property <string> vertical:   "vertical";
    /// Left position variant.
    /// property `left`.
    out property <string> left:   "left";
    /// Right position variant.
    /// property `right`.
    out property <string> right:  "right";
    /// Top position variant.
    /// property `top`.
    out property <string> top:    "top";
    /// Bottom position variant.
    /// property `bottom`.
    out property <string> bottom: "bottom";

    // ── Size ──────────────────────────────────────────────────────────
    /// Small size variant.
    /// property `sm`.
    out property <string> sm: "sm";
    /// Medium size variant.
    /// property `md`.
    out property <string> md: "md";
    /// Large size variant.
    /// property `lg`.
    out property <string> lg: "lg";

    // ── Shape ───────────────────────────────────────────────────────────
    /// Circle shape variant.
    /// property `circle`.
    out property <string> circle: "circle";
    /// Panel shape variant.
    /// property `panel`.
    out property <string> panel:  "panel";

    // ── Handle types ────────────────────────────────────────────────────
    /// Horizontal handle variant.
    /// property `handle-h`.
    out property <string> handle-h: "handle-h";
    /// Vertical handle variant.
    /// property `handle-v`.
    out property <string> handle-v: "handle-v";

    // ── Doc block kinds ─────────────────────────────────────────────────
    /// Heading level 1 block kind.
    /// property `h1`.
    out property <string> h1:   "h1";
    /// Heading level 2 block kind.
    /// property `h2`.
    out property <string> h2:   "h2";
    /// Heading level 3 block kind.
    /// property `h3`.
    out property <string> h3:   "h3";
    /// Paragraph block kind.
    /// property `p`.
    out property <string> p:    "p";
    /// Code block kind.
    /// property `code`.
    out property <string> code: "code";
    /// List item block kind.
    /// property `li`.
    out property <string> li:   "li";
    /// Nested list item block kind.
    /// property `li2`.
    out property <string> li2:  "li2";
    /// Table header block kind.
    /// property `th`.
    out property <string> th:   "th";
    /// Table row block kind.
    /// property `tr`.
    out property <string> tr:   "tr";
    /// Horizontal rule block kind.
    /// property `hr`.
    out property <string> hr:   "hr";
    /// Blockquote block kind.
    /// property `bq`.
    out property <string> bq:   "bq";

    // ── Test IDs ────────────────────────────────────────────────────────
    /// Alpha test ID.
    /// property `alpha`.
    out property <string> alpha: "alpha";
    /// Beta test ID.
    /// property `beta`.
    out property <string> beta:  "beta";
    /// Gamma test ID.
    /// property `gamma`.
    out property <string> gamma: "gamma";
}
