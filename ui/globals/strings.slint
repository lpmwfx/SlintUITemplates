// Strings — translatable UI text constants.
//
// All user-visible text is centralized here with English defaults.
// Runtime adapters can inject other languages via callbacks.
// Use instead of hardcoded strings in components.

/// Strings global values.
export global Strings {
    /// Application title.
    /// property `app-title`.
    out property <string> app-title: "SlintUI Templates";

    /// Default status bar text.
    /// property `app-status-ready`.
    out property <string> app-status-ready: "Ready";

    /// Close action label.
    /// property `action-close`.
    out property <string> action-close: "Close";

    /// OK action label.
    /// property `action-ok`.
