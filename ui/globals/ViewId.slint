// ViewId — named constants for all viewer navigation IDs.
// Prevents stringly-typed state comparisons in viewer components.

/// V ie wi d global values.
export global ViewId {
    /// Output property "buttons".
    out property <string> buttons:    "buttons";
    /// Output property "inputs".
    out property <string> inputs:     "inputs";
    /// Output property "display".
    out property <string> display:    "display";
    /// Output property "feedback".
    out property <string> feedback:   "feedback";
    /// Output property "layout".
    out property <string> layout:     "layout";
    /// Output property "app-shell".
    out property <string> app-shell:  "app-shell";
    /// Output property "icons".
    out property <string> icons:      "icons";
    /// Output property "selection".
    out property <string> selection:  "selection";
    /// Output property "navigation".
    out property <string> navigation: "navigation";
    /// Output property "data".
    out property <string> data:       "data";
    /// Output property "canvas".
    out property <string> canvas:     "canvas";
    /// Output property "utilities".
    out property <string> utilities:  "utilities";
    /// Output property "popups".
    out property <string> popups:     "popups";
    /// Output property "panels".
    out property <string> panels:     "panels";
}
