// macOS color tokens — SF-inspired system palette.
// Light and dark follow Apple Human Interface Guidelines.
// Reference: https://developer.apple.com/design/human-interface-guidelines/color

export global MacosColors {
    // ── Backgrounds ───────────────────────────────────────────────────────
    /// Primary window background (light: white, dark: #1e1e1e).
    out property <color> bg-primary-light:    #ffffff;
    /// Primary window background — dark variant (#1e1e1e).
    out property <color> bg-primary-dark:     #1e1e1e;
    /// Secondary surface (light: #f2f2f7, dark: #2c2c2e).
    out property <color> bg-surface-light:    #f2f2f7;
    /// Secondary surface — dark variant (#2c2c2e).
    out property <color> bg-surface-dark:     #2c2c2e;
    /// Elevated surface — cards, popovers (light: white, dark: #3a3a3c).
    out property <color> bg-elevated-light:   #ffffff;
    /// Elevated surface — dark variant (#3a3a3c).
    out property <color> bg-elevated-dark:    #3a3a3c;
    /// Title bar / toolbar (light: #ebebeb, dark: #323232).
    out property <color> bg-titlebar-light:   #ebebeb;
    /// Title bar — dark variant (#323232).
    out property <color> bg-titlebar-dark:    #323232;

    // ── Text ──────────────────────────────────────────────────────────────
    /// Primary label (light: #000000, dark: #ffffff).
    out property <color> text-primary-light:   #000000;
    /// Primary label — dark variant (#ffffff).
    out property <color> text-primary-dark:    #ffffff;
    /// Secondary label (light: #3c3c4399, dark: #ebebf599).
    out property <color> text-secondary-light: #3c3c4399;
    /// Secondary label — dark variant (#ebebf599).
    out property <color> text-secondary-dark:  #ebebf599;
    /// Disabled label.
    out property <color> text-disabled-light:  #3c3c4340;
    /// Disabled label — dark variant (#ebebf540).
    out property <color> text-disabled-dark:   #ebebf540;

    // ── Accent (macOS Blue by default) ────────────────────────────────────
    /// System blue accent.
    out property <color> accent-light:         #007aff;
    /// System blue accent — dark variant (#0a84ff).
    out property <color> accent-dark:          #0a84ff;
    /// Accent hover.
    out property <color> accent-hover-light:   #0066d6;
    /// Accent hover — dark variant (#409cff).
    out property <color> accent-hover-dark:    #409cff;
    /// Text on accent.
    out property <color> accent-text:          #ffffff;

    // ── Borders / separators ──────────────────────────────────────────────
    /// Separator (light: #c6c6c8, dark: #38383a).
    out property <color> border-light:         #c6c6c8;
    /// Separator — dark variant (#38383a).
    out property <color> border-dark:          #38383a;
    /// Strong separator.
    out property <color> border-strong-light:  #aeaeb2;
    /// Strong separator — dark variant (#545458).
    out property <color> border-strong-dark:   #545458;

    // ── Semantic ──────────────────────────────────────────────────────────
    /// System red.
    out property <color> error:    #ff3b30;
    /// System green.
    out property <color> success:  #34c759;
    /// System orange.
    out property <color> warning:  #ff9500;

    // ── Overlay ───────────────────────────────────────────────────────────
    /// Drop shadow colour (4 % black).
    out property <color> shadow:   #00000033;
    /// Modal overlay tint (25 % black).
    out property <color> overlay:  #00000040;

    // ── Traffic light colours (window controls) ───────────────────────────
    /// Close button red.
    out property <color> traffic-close:    #ff5f57;
    /// Minimise button yellow.
    out property <color> traffic-min:      #febc2e;
    /// Fullscreen button green.
    out property <color> traffic-full:     #28c840;
}
