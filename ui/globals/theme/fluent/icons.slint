// Fluent Icon codepoints — Segoe Fluent Icons font (Windows 11).
// Font is pre-installed on all Windows 11 systems — no packaging needed.
//
// Usage:
//   Text { text: FluentIcons.settings; font-family: "Segoe Fluent Icons"; }
//
// Full catalog: https://learn.microsoft.com/en-us/windows/apps/design/style/segoe-fluent-icons-font

/// F lu en ti co ns global values.
export global FluentIcons {
    // ── Font name ──────────────────────────────────────────────────────────
    /// Output property "icon-font".
    out property <string> icon-font: "Segoe Fluent Icons";

    // ── Navigation ─────────────────────────────────────────────────────────
    /// Output property "home".
    out property <string> home:         "\u{E80F}";
    /// Output property "back".
    out property <string> back:         "\u{E72B}";
    /// Output property "forward".
    out property <string> forward:      "\u{E72A}";
    /// Output property "menu".
    out property <string> menu:         "\u{E700}";
    /// Output property "settings".
    out property <string> settings:     "\u{E713}";
    /// Output property "nav-collapse".
    out property <string> nav-collapse: "\u{E89F}";  // CollapseMenu
    /// Output property "nav-expand".
    out property <string> nav-expand:   "\u{E8A0}";  // OpenPane

    // ── Actions ────────────────────────────────────────────────────────────
    /// Output property "add".
    out property <string> add:          "\u{E710}";
    /// Output property "remove".
    out property <string> remove:       "\u{E738}";
    /// Output property "delete".
    out property <string> delete:       "\u{E74D}";
    /// Output property "edit".
    out property <string> edit:         "\u{E70F}";
    /// Output property "save".
    out property <string> save:         "\u{E74E}";
    /// Output property "copy".
    out property <string> copy:         "\u{E8C8}";
    /// Output property "paste".
    out property <string> paste:        "\u{E77F}";
    /// Output property "cut".
    out property <string> cut:          "\u{E8C6}";
    /// Output property "undo".
    out property <string> undo:         "\u{E7A7}";
    /// Output property "redo".
    out property <string> redo:         "\u{E7A6}";
    /// Output property "refresh".
    out property <string> refresh:      "\u{E72C}";
    /// Output property "close".
    out property <string> close:        "\u{E8BB}";
    /// Output property "search".
    out property <string> search:       "\u{E721}";
    /// Output property "filter".
    out property <string> filter:       "\u{E71C}";
    /// Output property "sort".
    out property <string> sort:         "\u{E8CB}";
    /// Output property "share".
    out property <string> share:        "\u{E72D}";
    /// Output property "download".
    out property <string> download:     "\u{E896}";
    /// Output property "upload".
    out property <string> upload:       "\u{E898}";
    /// Output property "print".
    out property <string> print:        "\u{E749}";
    /// Output property "pin".
    out property <string> pin:          "\u{E718}";
    /// Output property "unpin".
    out property <string> unpin:        "\u{E77A}";
    /// Output property "star".
    out property <string> star:         "\u{E734}";
    /// Output property "star-filled".
    out property <string> star-filled:  "\u{E735}";

    // ── Window chrome ──────────────────────────────────────────────────────
    /// Output property "maximize".
    out property <string> maximize:     "\u{E922}";
    /// Output property "minimize".
    out property <string> minimize:     "\u{E921}";
    /// Output property "restore".
    out property <string> restore:      "\u{E923}";

    // ── Files & Data ──────────────────────────────────────────────────────
    /// Output property "folder".
    out property <string> folder:       "\u{E8B7}";
    /// Output property "folder-open".
    out property <string> folder-open:  "\u{E8DA}";
    /// Output property "file".
    out property <string> file:         "\u{E7C3}";
    /// Output property "file-new".
    out property <string> file-new:     "\u{E8A5}";
    /// Output property "cloud".
    out property <string> cloud:        "\u{E753}";
    /// Output property "database".
    out property <string> database:     "\u{EFC7}";

    // ── Media ─────────────────────────────────────────────────────────────
    /// Output property "play".
    out property <string> play:         "\u{E768}";
    /// Output property "pause".
    out property <string> pause:        "\u{E769}";
    /// Output property "stop".
    out property <string> stop:         "\u{E71A}";
    /// Output property "volume".
    out property <string> volume:       "\u{E767}";
    /// Output property "mute".
    out property <string> mute:         "\u{E74F}";
    /// Output property "camera".
    out property <string> camera:       "\u{E722}";
    /// Output property "image".
    out property <string> image:        "\u{E8B9}";

    // ── UI / Layout ───────────────────────────────────────────────────────
    /// Output property "list".
    out property <string> list:         "\u{E8FD}";
    /// Output property "grid".
    out property <string> grid:         "\u{F0E2}";
    /// Output property "layout".
    out property <string> layout:       "\u{E8EF}";
    /// Output property "apps".
    out property <string> apps:         "\u{E8A9}";
    /// Output property "view-all".
    out property <string> view-all:     "\u{E8A9}";
    /// Output property "panel-left".
    out property <string> panel-left:   "\u{F6D9}";
    /// Output property "panel-right".
    out property <string> panel-right:  "\u{F6DA}";
    /// Output property "fullscreen".
    out property <string> fullscreen:   "\u{E740}";

    // ── People & Communication ────────────────────────────────────────────
    /// Output property "person".
    out property <string> person:       "\u{E77B}";
    /// Output property "people".
    out property <string> people:       "\u{E716}";
    /// Output property "chat".
    out property <string> chat:         "\u{E8BD}";
    /// Output property "mail".
    out property <string> mail:         "\u{E715}";
    /// Output property "phone".
    out property <string> phone:        "\u{E717}";
    /// Output property "notification".
    out property <string> notification: "\u{EA8F}";
    /// Output property "help".
    out property <string> help:         "\u{E897}";
    /// Output property "info".
    out property <string> info:         "\u{E946}";
    /// Output property "warning".
    out property <string> warning:      "\u{E7BA}";
    /// Output property "error-icon".
    out property <string> error-icon:   "\u{EA39}";
    /// Output property "checkmark".
    out property <string> checkmark:    "\u{E73E}";
    /// Output property "dismiss".
    out property <string> dismiss:      "\u{E8BB}";

    // ── Device ────────────────────────────────────────────────────────────
    /// Output property "device".
    out property <string> device:       "\u{E8FC}";
    /// Output property "keyboard".
    out property <string> keyboard:     "\u{E765}";
    /// Output property "wifi".
    out property <string> wifi:         "\u{E701}";
    /// Output property "bluetooth".
    out property <string> bluetooth:    "\u{E702}";
}
