// Fluent 2 corner radius — per WinUI3 design system.
// Reference: https://learn.microsoft.com/en-us/windows/apps/design/style/rounded-corner

/// F lu en tr ad iu s global values.
export global FluentRadius {
    /// Output property "none".
    out property <length> none:  0px;
    /// Output property "sm".
    out property <length> sm:    2px;   // checkboxes, small chips
    /// Output property "md".
    out property <length> md:    4px;   // buttons, inputs, cards
    /// Output property "lg".
    out property <length> lg:    8px;   // panels, dialogs, larger cards
    /// Output property "xl".
    out property <length> xl:   12px;   // navigation pane, large surfaces
    /// Output property "circle".
    out property <length> circle: 9999px; // pills, avatars
}
