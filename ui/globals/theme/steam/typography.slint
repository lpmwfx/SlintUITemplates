// Steam type scale — readable at arm's length (TV / handheld distance).
// Larger base sizes than Fluent — accounts for couch/handheld viewing distance.

import { Settings } from "../../../state/settings.slint";

export global SteamType {
    /// Small label / caption.
    /// property `caption`.
    /// property `caption`.
    /// property `caption`.
    /// property `caption`.
    /// property `caption`.
    /// property `caption`.
    /// property `caption`.
    out property <length> caption:  Settings.zoom * Settings.font-scale * 12px;
    /// Body text — larger than Fluent (16px vs 14px).
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    out property <length> body:     Settings.zoom * Settings.font-scale * 16px;
