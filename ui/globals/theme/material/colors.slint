// Material Design 3 color roles — light mode reference palette.
// Reference: https://m3.material.io/styles/color/roles

/// M at er ia lc ol or s global values.
export global MaterialColors {
    // ── Primary ────────────────────────────────────────────────────────────
    /// Output property "primary".
    out property <color> primary:           #6750A4;
    /// Output property "on-primary".
    out property <color> on-primary:        #FFFFFF;
    /// Output property "primary-container".
    out property <color> primary-container: #EADDFF;
    /// Output property "on-primary-container".
    out property <color> on-primary-container: #21005D;

    // ── Secondary ──────────────────────────────────────────────────────────
    /// Output property "secondary".
    out property <color> secondary:           #625B71;
    /// Output property "on-secondary".
    out property <color> on-secondary:        #FFFFFF;
    /// Output property "secondary-container".
    out property <color> secondary-container: #E8DEF8;
    /// Output property "on-secondary-container".
    out property <color> on-secondary-container: #1D192B;

    // ── Tertiary ───────────────────────────────────────────────────────────
    /// Output property "tertiary".
    out property <color> tertiary:           #7D5260;
    /// Output property "on-tertiary".
    out property <color> on-tertiary:        #FFFFFF;
    /// Output property "tertiary-container".
    out property <color> tertiary-container: #FFD8E4;
    /// Output property "on-tertiary-container".
    out property <color> on-tertiary-container: #31111D;

    // ── Error ──────────────────────────────────────────────────────────────
    /// Output property "error".
    out property <color> error:            #B3261E;
    /// Output property "on-error".
    out property <color> on-error:         #FFFFFF;
    /// Output property "error-container".
    out property <color> error-container:  #F9DEDC;
    /// Output property "on-error-container".
    out property <color> on-error-container: #410E0B;

    // ── Surface ────────────────────────────────────────────────────────────
    /// Output property "surface".
    out property <color> surface:           #FFFBFE;
    /// Output property "on-surface".
    out property <color> on-surface:        #1C1B1F;
    /// Output property "surface-variant".
    out property <color> surface-variant:   #E7E0EC;
    /// Output property "on-surface-variant".
    out property <color> on-surface-variant: #49454F;
    /// Output property "surface-container".
    out property <color> surface-container: #F3EDF7;
    /// Output property "surface-container-high".
    out property <color> surface-container-high: #ECE6F0;

    // ── Background ────────────────────────────────────────────────────────
    /// Output property "background".
    out property <color> background:    #FFFBFE;
    /// Output property "on-background".
    out property <color> on-background: #1C1B1F;

    // ── Outline ───────────────────────────────────────────────────────────
    /// Output property "outline".
    out property <color> outline:         #79747E;
    /// Output property "outline-variant".
    out property <color> outline-variant: #CAC4D0;

    // ── Inverse ───────────────────────────────────────────────────────────
    /// Output property "inverse-surface".
    out property <color> inverse-surface:    #313033;
    /// Output property "inverse-on-surface".
    out property <color> inverse-on-surface: #F4EFF4;
    /// Output property "inverse-primary".
    out property <color> inverse-primary:    #D0BCFF;
}
