// Material 3 elevation — surface tint overlay levels.
// Elevation uses primary color tint at increasing opacity.
// Reference: https://m3.material.io/styles/elevation/tokens

import { MaterialColors } from "colors.slint";

/// M at er ia le le va ti on global values.
export global MaterialElevation {
    // Overlay alpha per level (applied as primary color tint on surface)
    /// Output property "level-0".
    /// property `level-0`.
    /// property `level-0`.
    /// property `level-0`.
    /// property `level-0`.
    /// property `level-0`.
    /// property `level-0`.
    /// property `level-0`.
    out property <float> level-0: 0.00;   // no tint
    /// Output property "level-1".
    /// property `level-1`.
    /// property `level-1`.
    /// property `level-1`.
    /// property `level-1`.
    /// property `level-1`.
    /// property `level-1`.
    /// property `level-1`.
    out property <float> level-1: 0.05;   // +5% primary  (Cards, Nav drawer)
    /// Output property "level-2".
    /// property `level-2`.
    /// property `level-2`.
    /// property `level-2`.
    /// property `level-2`.
    /// property `level-2`.
    /// property `level-2`.
    /// property `level-2`.
    out property <float> level-2: 0.08;   // +8% primary  (FAB resting, SearchBar)
    /// Output property "level-3".
    /// property `level-3`.
    /// property `level-3`.
    /// property `level-3`.
    /// property `level-3`.
    /// property `level-3`.
    /// property `level-3`.
    /// property `level-3`.
    out property <float> level-3: 0.11;   // +11% primary (FAB pressed)
    /// Output property "level-4".
    /// property `level-4`.
    /// property `level-4`.
    /// property `level-4`.
    /// property `level-4`.
    /// property `level-4`.
    /// property `level-4`.
    /// property `level-4`.
    out property <float> level-4: 0.12;   // +12% primary (BottomNavBar)
    /// Output property "level-5".
    /// property `level-5`.
    /// property `level-5`.
    /// property `level-5`.
    /// property `level-5`.
    /// property `level-5`.
    /// property `level-5`.
    /// property `level-5`.
    out property <float> level-5: 0.14;   // +14% primary (BottomSheet)
}
