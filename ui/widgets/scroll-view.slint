import { Colors, Spacing } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";

/// S cr ol lv ie w component.
/// component `ScrollView`.
export component ScrollView inherits Rectangle {
    /// Input property "interactive".
    /// property `interactive`.
    in property <bool>  interactive:    true;
    /// Input property "show-scrollbar".
    /// property `show-scrollbar`.
    in property <bool>  show-scrollbar: true;
    /// Output property "viewport-width".
    /// property `viewport-width`.
    out property <length> viewport-width  <=> fl.viewport-width;
    /// Output property "viewport-height".
    /// property `viewport-height`.
    out property <length> viewport-height <=> fl.viewport-height;

    /// Private property "scrollbar-inset" used internally.
    /// property `scrollbar-inset`.
    private property <length> scrollbar-inset: Sizes.border-w-2;
    /// Private property "scrollbar-w" used internally.
    /// property `scrollbar-w`.
    private property <length> scrollbar-w: Sizes.border-w-3;

    clip: true;

    fl := Flickable {
        width: parent.width;
        height: parent.height;
        interactive: root.interactive;
        viewport-width: self.width;
        @children
    }

    // Vertical scrollbar thumb
    if root.show-scrollbar && fl.viewport-height > fl.height: Rectangle {
        x: parent.width - Spacing.xs - root.scrollbar-inset;
        y: (-fl.viewport-y / fl.viewport-height) * fl.height;
        width: root.scrollbar-w;
        height: max((fl.height / fl.viewport-height) * fl.height, Spacing.md);
        border-radius: Spacing.xs;
        background: Colors.border-strong;
        opacity: Sizes.three-quarter;
    }
}
