import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";

/// C ar d component.
export component Card inherits Rectangle {
    /// Input property "title".
    in property <string> title: "";
    /// Input property "subtitle".
    in property <string> subtitle: "";

    /// Private property "shadow-y" used internally.
    private property <length> shadow-y: Sizes.border-w-2;

    background: Colors.bg-elevated;
    border-radius: Spacing.sm;
    drop-shadow-blur: Spacing.sm;
    drop-shadow-color: Colors.shadow;
    drop-shadow-offset-y: root.shadow-y;

    VerticalLayout {
        padding: Spacing.md;
        spacing: Spacing.xs;

        if root.title != "": Text {
            text: root.title;
            font-size: Type.subtitle-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
        }

        if root.subtitle != "": Text {
            text: root.subtitle;
            font-size: Type.body-size;
            color: Colors.text-secondary;
        }
    }
}
