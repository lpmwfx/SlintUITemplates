import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";

/// C hi p component.
/// component `Chip`.
/// component `Chip`.
/// component `Chip`.
/// component `Chip`.
/// component `Chip`.
/// component `Chip`.
/// component `Chip`.
export component Chip inherits Rectangle {
    /// Input property "label".
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    in property <string> label: "";
    /// Input property "closable".
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    in property <bool>   closable: true;
    /// Input property "icon".
    /// property `icon`.
    /// property `icon`.
    /// property `icon`.
    /// property `icon`.
    /// property `icon`.
    /// property `icon`.
    /// property `icon`.
    in property <string> icon: "";
    /// Input property "selected".
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    in property <bool>   selected: false;
    /// Input property "enabled".
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    in property <bool>   enabled: true;
    /// Callback fired for c lo se d.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    callback closed();
    /// Callback fired for c li ck ed.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    callback clicked();

    /// Private property "close-icon-size" used internally.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    /// property `close-icon-size`.
    private property <length> close-icon-size: Sizes.glyph-sm;

    height: Spacing.control-md;
    border-radius: root.height / Sizes.two;
    border-width: Sizes.border-w;
    border-color: root.selected ? transparent : Colors.border;
    background: root.selected    ? Colors.accent :
                body-ta.has-hover ? Colors.bg-elevated :
                Colors.bg-surface;
    opacity: root.enabled ? Sizes.fill : Sizes.half;
    clip: true;

    HorizontalLayout {
        padding-left: Spacing.sm;
        padding-right: root.closable ? Spacing.xs : Spacing.sm;
        spacing: Spacing.xs;
        alignment: center;

        if root.icon != "": Text {
            text: root.icon;
            font-family: FluentIcons.icon-font;
            font-size: Type.caption-size;
            color: root.selected ? Colors.accent-text : Colors.text-primary;
            vertical-alignment: center;
        }

        Text {
            text: root.label;
            font-size: Type.caption-size;
            color: root.selected ? Colors.accent-text : Colors.text-primary;
            vertical-alignment: center;
        }

        if root.closable: close-btn := Rectangle {
            width: Spacing.md;
            height: Spacing.md;
            border-radius: parent.height / Sizes.two;
            background: close-ta.has-hover ? Colors.bg-surface.with-alpha(Sizes.half) : transparent;

            Text {
                text: FluentIcons.dismiss;
                font-family: FluentIcons.icon-font;
                font-size: root.close-icon-size;
                color: root.selected ? Colors.accent-text : Colors.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            close-ta := TouchArea {
                enabled: root.enabled;
                clicked => { root.closed(); }
            }
        }
    }

    body-ta := TouchArea {
        width: root.width - (root.closable ? Spacing.md + Spacing.xs : Sizes.no-size);
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}
