import { Colors, Spacing } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { StarItem } from "StarItem.slint";

/// R at in g component.
/// component `Rating`.
/// component `Rating`.
/// component `Rating`.
/// component `Rating`.
/// component `Rating`.
/// component `Rating`.
/// component `Rating`.
export component Rating inherits Rectangle {
    /// Input property "value".
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    in property <int> value: Sizes.zero;
    /// Input property "max".
    /// property `max`.
    /// property `max`.
    /// property `max`.
    /// property `max`.
    /// property `max`.
    /// property `max`.
    /// property `max`.
    in property <int>  max: Sizes.five;
    /// Input property "readonly".
    /// property `readonly`.
    /// property `readonly`.
    /// property `readonly`.
    /// property `readonly`.
    /// property `readonly`.
    /// property `readonly`.
    /// property `readonly`.
    in property <bool> readonly: false;
    /// Callback fired for c ha ng ed.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    callback changed(int);

    /// Private property "hover-val" used internally.
    /// property `hover-val`.
    /// property `hover-val`.
    /// property `hover-val`.
    /// property `hover-val`.
    /// property `hover-val`.
    /// property `hover-val`.
    /// property `hover-val`.
    private property <int> hover-val: Sizes.zero;

    height: Spacing.xl;
    background: transparent;

    VerticalLayout {
        alignment: center;

        stars-row := HorizontalLayout {
            alignment: start;
            spacing: Spacing.xs;

            for i in [Sizes.one, Sizes.two, Sizes.three, Sizes.four, Sizes.five]: StarItem {
                visible: i <= root.max;
                index: i;
                display-val: root.hover-val > Sizes.zero ? root.hover-val : root.value;
                readonly: root.readonly;
                clicked => { root.changed(i); }
                hover-changed(val) => { root.hover-val = val; }
            }
        }
    }

    // Reset hover when mouse leaves the widget
    exit-ta := TouchArea {
        pointer-event(e) => { root.hover-val = e.kind == PointerEventKind.cancel ? Sizes.zero : root.hover-val; }
    }
}
