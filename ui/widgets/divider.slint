import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { Variants } from "../globals/variants.slint";

/// D iv id er component.
/// component `Divider`.
/// component `Divider`.
/// component `Divider`.
/// component `Divider`.
/// component `Divider`.
/// component `Divider`.
/// component `Divider`.
export component Divider inherits Rectangle {
    /// Input property "orientation".
    /// property `orientation`.
    /// property `orientation`.
    /// property `orientation`.
    /// property `orientation`.
    /// property `orientation`.
    /// property `orientation`.
    /// property `orientation`.
    in property <string> orientation: Variants.horizontal;   // horizontal | vertical
    /// Input property "label".
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    in property <string> label: "";
    /// Input property "line-color".
    /// property `line-color`.
    /// property `line-color`.
    /// property `line-color`.
    /// property `line-color`.
    /// property `line-color`.
    /// property `line-color`.
    /// property `line-color`.
    in property <color>  line-color: Colors.border;

    background: transparent;

    // Horizontal — no label
    if root.orientation == Variants.horizontal && root.label == "": Rectangle {
        width: parent.width;
        height: Sizes.border-w;
        y: (parent.height - Sizes.border-w) / Sizes.two;
        background: root.line-color;
    }

    // Horizontal — with label
    if root.orientation == Variants.horizontal && root.label != "": HorizontalLayout {
        alignment: stretch;

        Rectangle {
            height: Sizes.border-w;
            y: parent.height / Sizes.two;
            horizontal-stretch: Sizes.one;
            background: root.line-color;
        }

        Rectangle {
            width: label-text.preferred-width + Spacing.md;
            label-text := Text {
                x: Spacing.sm;
                text: root.label;
                font-size: Type.caption-size;
                color: Colors.text-secondary;
            }
        }

        Rectangle {
            height: Sizes.border-w;
            y: parent.height / Sizes.two;
            horizontal-stretch: Sizes.one;
            background: root.line-color;
        }
    }

    // Vertical
    if root.orientation == Variants.vertical: Rectangle {
        width: Sizes.border-w;
        height: parent.height;
        x: (parent.width - Sizes.border-w) / Sizes.two;
        background: root.line-color;
    }
}
