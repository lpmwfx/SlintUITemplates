import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";

/// S eg me nt it em struct.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
/// struct `SegmentItem`.
export struct SegmentItem {
    id:    string,
    label: string,
    icon:  string,
}

/// S eg me nt ta b component.
/// component `SegmentTab`.
/// component `SegmentTab`.
/// component `SegmentTab`.
/// component `SegmentTab`.
/// component `SegmentTab`.
/// component `SegmentTab`.
/// component `SegmentTab`.
export component SegmentTab inherits Rectangle {
    /// Input property "item".
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    in property <SegmentItem> item;
    /// Input property "active".
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    /// property `active`.
    in property <bool>        active: false;
    /// Callback fired for c li ck ed.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    callback clicked(string);

    border-radius: Spacing.xs;
    clip: true;
    background: root.active  ? Colors.accent :
                ta.has-hover ? Colors.bg-elevated : transparent;

    HorizontalLayout {
        padding-left:  Spacing.sm;
        padding-right: Spacing.sm;
        spacing: Spacing.xs;
        alignment: center;

        if item.icon != "": Text { text: item.icon;
            font-family: FluentIcons.icon-font;
            font-size: Type.body-size;
            color: root.active ? Colors.accent-text : Colors.text-primary;
            vertical-alignment: center;
        }

        Text {
            text: item.label;
            font-size: Type.body-size;
            font-weight: root.active ? Type.weight-semibold : Type.weight-regular;
            color: root.active ? Colors.accent-text : Colors.text-primary;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(root.item.id); }
    }
}
