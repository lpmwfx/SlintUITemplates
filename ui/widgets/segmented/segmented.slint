import { Colors, Spacing } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { SegmentTab, SegmentItem } from "segment-tab.slint";

export { SegmentItem }

/// S eg me nt ed component.
/// component `Segmented`.
/// component `Segmented`.
/// component `Segmented`.
/// component `Segmented`.
/// component `Segmented`.
/// component `Segmented`.
/// component `Segmented`.
export component Segmented inherits Rectangle {
    /// Input property "items".
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    /// property `items`.
    in property <[SegmentItem]> items: [];
    /// Input property "selected".
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    in property <string>        selected: "";
    /// Callback fired for c ha ng ed.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    callback changed(string);

    /// Private property "border-px" used internally.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    private property <length> border-px: Sizes.border-w;
    /// Private property "pad-px" used internally.
    /// property `pad-px`.
    /// property `pad-px`.
    /// property `pad-px`.
    /// property `pad-px`.
    /// property `pad-px`.
    /// property `pad-px`.
    /// property `pad-px`.
    private property <length> pad-px:    Sizes.border-w-2;
    /// Private property "v-stretch" used internally.
    /// property `v-stretch`.
    /// property `v-stretch`.
    /// property `v-stretch`.
    /// property `v-stretch`.
    /// property `v-stretch`.
    /// property `v-stretch`.
    /// property `v-stretch`.
    private property <int>    v-stretch: 1;
    /// Private property "h-stretch" used internally.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    private property <int>    h-stretch: 1;

    height: Spacing.control-lg;
    border-radius: Spacing.sm;
    border-width: root.border-px;
    border-color: Colors.border;
    background: Colors.bg-surface;

    HorizontalLayout {
        padding: root.pad-px;
        spacing: root.pad-px;

        for item in root.items: SegmentTab {
            item: item;
            active: item.id == root.selected;
            vertical-stretch: root.v-stretch;
            horizontal-stretch: root.h-stretch;
            clicked(id) => { root.changed(id); }
        }
    }
}
