// Flyout — base primitive for popup overlays.
//
// Place the trigger element as a child of the Flyout via @children.
// PopupWindow always renders at window z-level regardless of nesting depth.
//
//   flyout := Flyout { window-height: root.window-height; title: "Hello"; body: "World";
//       Rectangle { TouchArea { clicked => { flyout.show-at(self.mouse-x, self.mouse-y); } } }
//   }

import { Spacing } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { FlyoutInner } from "flyout-inner.slint";

/// F ly ou t component.
/// component `Flyout`.
/// component `Flyout`.
/// component `Flyout`.
/// component `Flyout`.
/// component `Flyout`.
/// component `Flyout`.
/// component `Flyout`.
export component Flyout inherits Rectangle {
    /// Input property "window-height".
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    in property <length> window-height;
    /// Input property "popup-width".
    /// property `popup-width`.
    /// property `popup-width`.
    /// property `popup-width`.
    /// property `popup-width`.
    /// property `popup-width`.
    /// property `popup-width`.
    /// property `popup-width`.
    in property <length> popup-width:  Sizes.panel-md;
    /// Input property "popup-height".
    /// property `popup-height`.
    /// property `popup-height`.
    /// property `popup-height`.
    /// property `popup-height`.
    /// property `popup-height`.
    /// property `popup-height`.
    /// property `popup-height`.
    in property <length> popup-height: Sizes.comp-160;
    /// Input property "title".
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    in property <string> title: "";
    /// Input property "body".
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    in property <string> body: "";
    /// Callback fired for c lo se d.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    callback closed();

    /// Private property "pop-x" used internally.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    private property <length> pop-x: Sizes.no-size;
    /// Private property "pop-y" used internally.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    private property <length> pop-y: Sizes.no-size;

    background: transparent;

    @children

    popup := PopupWindow {
        x: root.pop-x;
        y: root.pop-y;
        width: root.popup-width;
        height: root.popup-height;

        FlyoutInner {
            title: root.title;
            body:  root.body;
            closed => { popup.close(); root.closed(); }
        }
    }

    public function show-at(xp: length, yp: length) {
        root.pop-x = xp;
        if root.window-height > root.pop-x - root.pop-x
                && root.absolute-position.y + yp + root.popup-height > root.window-height {
            root.pop-y = yp - root.popup-height;
            if root.absolute-position.y + root.pop-y < root.pop-x - root.pop-x {
                root.pop-y = -root.absolute-position.y;
            }
        } else {
            root.pop-y = yp;
        }
        popup.show();
    }

    public function close() {
        popup.close();
    }
}
