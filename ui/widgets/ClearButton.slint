export component ClearButton inherits Rectangle {
    /// Callback fired for c le ar ed.
    /// callback `cleared`.
    /// callback `cleared`.
    /// callback `cleared`.
    /// callback `cleared`.
    /// callback `cleared`.
    /// callback `cleared`.
    /// callback `cleared`.
    callback cleared();

    width: Spacing.lg;
    background: btn-ta.has-hover ? Colors.bg-surface : transparent;
    border-radius: Spacing.xs;

    Text {
        text: FluentIcons.dismiss;
        font-family: FluentIcons.icon-font;
        font-size: Type.caption-size;
        color: Colors.text-secondary;
