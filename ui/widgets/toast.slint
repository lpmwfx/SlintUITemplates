import { Colors, Spacing, Type, Sizes } from "../globals/theme.slint";
import { Variants } from "../globals/variants.slint";

/// T oa st component.
/// component `Toast`.
/// component `Toast`.
/// component `Toast`.
/// component `Toast`.
/// component `Toast`.
/// component `Toast`.
/// component `Toast`.
export component Toast inherits Rectangle {
    /// Input property "message".
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    in property <string> message: "";
    /// Input property "variant".
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    in property <string> variant: "info";   // info | success | warning | error
    // visible is the built-in — caller sets visible: true/false directly

    // Position at bottom center
    horizontal-stretch: Sizes.no-fill;
    width: self.preferred-width;
    height: Spacing.xl;
    border-radius: Spacing.xs;
    clip: true;

    background:
        variant == Variants.success ? Colors.success :
        variant == Variants.warning ? Colors.warning :
        variant == Variants.error   ? Colors.error :
        Colors.accent;

    HorizontalLayout {
        alignment: center;
        padding-left: Spacing.md;
        padding-right: Spacing.md;
        horizontal-stretch: Sizes.no-fill;

        Text {
            text: root.message;
            font-size: Type.body-size;
            color: Colors.accent-text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}
