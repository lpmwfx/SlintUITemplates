import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Button } from "button.slint";

/// E mp ty st at e component.
/// component `EmptyState`.
export component EmptyState inherits Rectangle {
    /// Input property "icon".
    /// property `icon`.
    in property <string> icon: "\u{E8FD}";
    /// Input property "title".
    /// property `title`.
    in property <string> title: "No items";
    /// Input property "description".
    /// property `description`.
    in property <string> description: "";
    /// Input property "action-label".
    /// property `action-label`.
    in property <string> action-label: "";
    /// Callback fired for a ct io n.
    /// callback `action`.
    callback action();

    /// Private property "icon-sz" used internally.
    /// property `icon-sz`.
    private property <length> icon-sz: Type.heading-size * 2;

    background: transparent;

    VerticalLayout {
        alignment: center;
        spacing: Spacing.sm;
        padding: Spacing.lg;

        Text { text: root.icon;
            font-family: FluentIcons.icon-font;
            font-size: root.icon-sz;
            color: Colors.text-disabled;
            horizontal-alignment: center;
        }

        Text {
            text: root.title;
            font-size: Type.subtitle-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
            horizontal-alignment: center;
        }

        if root.description != "": Text {
            text: root.description;
            font-size: Type.body-size;
            color: Colors.text-secondary;
            horizontal-alignment: center;
        }

        if root.action-label != "": HorizontalLayout {
            alignment: center;
            padding-top: Spacing.sm;
            Button {
                label: root.action-label;
                clicked => { root.action(); }
            }
        }
    }
}
