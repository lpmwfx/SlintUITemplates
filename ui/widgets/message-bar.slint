import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { Strings } from "../globals/strings.slint";

/// M es sa ge ba r component.
/// component `MessageBar`.
/// component `MessageBar`.
/// component `MessageBar`.
/// component `MessageBar`.
/// component `MessageBar`.
/// component `MessageBar`.
/// component `MessageBar`.
export component MessageBar inherits Rectangle {
    /// Input property "message".
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    /// property `message`.
    in property <string> message: "";
    /// Input property "variant".
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    /// property `variant`.
    in property <string> variant: "info";   // info | warning | error | success
    /// Input property "action-label".
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    in property <string> action-label: "";
    /// Input property "closable".
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    /// property `closable`.
    in property <bool>   closable: true;
    /// Callback fired for a ct io n.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    callback action();
    /// Callback fired for c lo se d.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    /// callback `closed`.
    callback closed();

    /// Private property "v-error" used internally.
    /// property `v-error`.
    /// property `v-error`.
    /// property `v-error`.
    /// property `v-error`.
    /// property `v-error`.
    /// property `v-error`.
    /// property `v-error`.
    private property <string> v-error:   "error";
    /// Private property "v-warning" used internally.
    /// property `v-warning`.
    /// property `v-warning`.
    /// property `v-warning`.
    /// property `v-warning`.
    /// property `v-warning`.
    /// property `v-warning`.
    /// property `v-warning`.
    private property <string> v-warning: "warning";
    /// Private property "v-success" used internally.
    /// property `v-success`.
    /// property `v-success`.
    /// property `v-success`.
    /// property `v-success`.
    /// property `v-success`.
    /// property `v-success`.
    /// property `v-success`.
    private property <string> v-success: "success";
    /// Private property "border-px" used internally.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    private property <length> border-px: Sizes.border-w;
    /// Private property "bar-w" used internally.
    /// property `bar-w`.
    /// property `bar-w`.
    /// property `bar-w`.
    /// property `bar-w`.
    /// property `bar-w`.
    /// property `bar-w`.
    /// property `bar-w`.
    private property <length> bar-w:     Sizes.border-w-3;
    /// Private property "btn-shrink" used internally.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    /// property `btn-shrink`.
    private property <int>    btn-shrink: 0;
    /// Private property "text-grow" used internally.
    /// property `text-grow`.
    /// property `text-grow`.
    /// property `text-grow`.
    /// property `text-grow`.
    /// property `text-grow`.
    /// property `text-grow`.
    /// property `text-grow`.
    private property <int>    text-grow:  1;
    /// Private property "accent-color" used internally.
    /// property `accent-color`.
    /// property `accent-color`.
    /// property `accent-color`.
    /// property `accent-color`.
    /// property `accent-color`.
    /// property `accent-color`.
    /// property `accent-color`.
    private property <color> accent-color:
        variant == root.v-error   ? Colors.error   :
        variant == root.v-warning ? Colors.warning :
        variant == root.v-success ? Colors.success :
        Colors.accent;
    /// Private property "icon-glyph" used internally.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    /// property `icon-glyph`.
    private property <string> icon-glyph:
        variant == root.v-error   ? "\u{E783}" :
        variant == root.v-warning ? "\u{E7BA}" :
        variant == root.v-success ? "\u{E73E}" :
        "\u{E946}";

    height: Spacing.xl + Spacing.sm;
    background: Colors.bg-surface;
    border-width: root.border-px;
    border-color: Colors.border;
    border-radius: Spacing.xs;
    clip: true;

    // Left accent bar
    Rectangle {
        x: Sizes.no-size;
        y: Sizes.no-size;
        width: root.bar-w;
        height: parent.height;
        background: root.accent-color;
    }

    HorizontalLayout {
        padding-left: root.bar-w + Spacing.md;
        padding-right: Spacing.sm;
        spacing: Spacing.sm;

        Text {
            text: root.icon-glyph;
            font-family: FluentIcons.icon-font;
            font-size: Type.body-size;
            color: root.accent-color;
            vertical-alignment: center;
        }

        Text {
            text: root.message;
            font-size: Type.body-size;
            color: Colors.text-primary;
            vertical-alignment: center;
            horizontal-stretch: root.text-grow;
            overflow: elide;
        }

        if root.action-label != "": Rectangle {
            width: action-text.preferred-width + Spacing.sm * Sizes.two;
            height: Spacing.control-md;
            border-radius: Spacing.xs;
            border-width: root.border-px;
            border-color: Colors.border;
            background: act-ta.has-hover ? Colors.bg-elevated : transparent;
            vertical-stretch: root.btn-shrink;

            action-text := Text {
                text: root.action-label;
                font-size: Type.body-size;
                color: Colors.accent;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            act-ta := TouchArea {
                clicked => { root.action(); }
            }
        }

        if root.closable: Rectangle {
            width: Spacing.xl;
            height: Spacing.xl;
            border-radius: Spacing.xs;
            background: close-ta.has-hover ? Colors.bg-elevated : transparent;

            Text { text: Strings.icon-close;
                font-family: FluentIcons.icon-font;
                font-size: Type.body-size;
                color: Colors.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            close-ta := TouchArea {
                clicked => { root.closed(); }
            }
        }
    }
}
