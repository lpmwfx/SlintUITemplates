import { Colors, Spacing, Type } from "../../globals/theme.slint";

// SpinButton — reusable increment/decrement button for SpinBox.
/// S pi nb ut to n component.
/// component `SpinButton`.
/// component `SpinButton`.
/// component `SpinButton`.
/// component `SpinButton`.
/// component `SpinButton`.
/// component `SpinButton`.
/// component `SpinButton`.
export component SpinButton inherits Rectangle {
    /// Input property "label".
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    in property <string> label;
    /// Input property "btn-enabled".
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    /// property `btn-enabled`.
    in property <bool>   btn-enabled: true;
    /// Callback fired for c li ck ed.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    callback clicked();

    width: Spacing.xl;
    background: btn-ta.has-hover && root.btn-enabled
        ? Colors.bg-surface : transparent;

    Text {
        text: root.label;
        font-size: Type.body-size;
        color: root.btn-enabled
            ? Colors.text-primary : Colors.text-disabled;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    btn-ta := TouchArea {
        enabled: root.btn-enabled;
        clicked => { root.clicked(); }
    }
}
