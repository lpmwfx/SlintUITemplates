import { Colors, Spacing, Type } from "../globals/theme.slint";
import { TextEdit } from "std-widgets.slint";
import { Sizes } from "../globals/theme/sizes.slint";

/// T ex ta re a component.
/// component `TextArea`.
/// component `TextArea`.
/// component `TextArea`.
/// component `TextArea`.
/// component `TextArea`.
/// component `TextArea`.
/// component `TextArea`.
export component TextArea inherits Rectangle {
    /// Input property "label".
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    in property <string> label: "";
    /// Input property "value".
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    in property <string> value: "";
    /// Input property "placeholder".
    /// property `placeholder`.
    /// property `placeholder`.
    /// property `placeholder`.
    /// property `placeholder`.
    /// property `placeholder`.
    /// property `placeholder`.
    /// property `placeholder`.
    in property <string> placeholder: "";
    /// Input property "error".
    /// property `error`.
    /// property `error`.
    /// property `error`.
    /// property `error`.
    /// property `error`.
    /// property `error`.
    /// property `error`.
    in property <string> error: "";
    /// Input property "rows".
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    in property <int>    rows: Sizes.four;
    /// Input property "enabled".
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    in property <bool>   enabled: true;
    /// Callback fired for c ha ng ed.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    callback changed(string);

    /// Private property "area-height" used internally.
    /// property `area-height`.
    /// property `area-height`.
    /// property `area-height`.
    /// property `area-height`.
    /// property `area-height`.
    /// property `area-height`.
    /// property `area-height`.
    private property <length> area-height: root.rows * (Type.body-size + Spacing.xs) + Spacing.sm * Sizes.two;

    height: root.label != "" ? root.area-height + Type.caption-size + Spacing.xs : root.area-height;
    opacity: root.enabled ? Sizes.fill : Sizes.half;

    VerticalLayout {
        spacing: Spacing.xs;

        if root.label != "": Text {
            text: root.label;
            font-size: Type.caption-size;
            font-weight: Type.weight-semibold;
            color: root.error != "" ? Colors.error : Colors.text-secondary;
        }

        field := Rectangle {
            height: root.area-height;
            border-radius: Spacing.xs;
            border-width: Sizes.border-w;
            border-color: root.error != "" ? Colors.error :
                          edit.has-focus ? Colors.border-focus : Colors.border;
            background: Colors.bg-elevated;
            clip: true;

            edit := TextEdit {
                x: Spacing.sm;
                y: Spacing.sm;
                width: parent.width - Spacing.sm * Sizes.two;
                height: parent.height - Spacing.sm * Sizes.two;
                text: root.value;
                font-size: Type.body-size;
                wrap: word-wrap;
                enabled: root.enabled;

                edited => { root.changed(self.text); }
            }

            // Placeholder
            if root.value == "": Text {
                x: Spacing.sm;
                y: Spacing.sm;
                text: root.placeholder;
                font-size: Type.body-size;
                color: Colors.text-disabled;
            }
        }

        if root.error != "": Text {
            text: root.error;
            font-size: Type.caption-size;
            color: Colors.error;
        }
    }
}
