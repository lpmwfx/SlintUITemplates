export component RadioGroup inherits VerticalLayout {
    /// Input property "options".
    /// property `options`.
    /// property `options`.
    /// property `options`.
    /// property `options`.
    /// property `options`.
    /// property `options`.
    /// property `options`.
    in property <[string]> options: [];
    /// Input property "value".
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    in property <string> value: "";
    /// Input property "enabled".
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    in property <bool> enabled: true;
    /// Callback fired for c ha ng ed.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    /// callback `changed`.
    callback changed(string);

    spacing: Spacing.sm;

    for opt in root.options: RadioButton {
        label: opt;
        checked: opt == root.value;
        enabled: root.enabled;
        clicked => { root.changed(opt); }
