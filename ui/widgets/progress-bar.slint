import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { FluentMotion } from "../globals/theme/fluent/motion.slint";

/// P ro gr es sb ar component.
/// component `ProgressBar`.
/// component `ProgressBar`.
/// component `ProgressBar`.
/// component `ProgressBar`.
/// component `ProgressBar`.
/// component `ProgressBar`.
/// component `ProgressBar`.
export component ProgressBar inherits Rectangle {
    /// Input property "value".
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    /// property `value`.
    in property <float> value: Sizes.no-fill;      // 0.0..1.0
    /// Input property "show-label".
    /// property `show-label`.
    /// property `show-label`.
    /// property `show-label`.
    /// property `show-label`.
    /// property `show-label`.
    /// property `show-label`.
    /// property `show-label`.
    in property <bool>  show-label: false;
    /// Input property "label-suffix".
    /// property `label-suffix`.
    /// property `label-suffix`.
    /// property `label-suffix`.
    /// property `label-suffix`.
    /// property `label-suffix`.
    /// property `label-suffix`.
    /// property `label-suffix`.
    in property <string> label-suffix: "%";

    height: Spacing.sm;

    // Track
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.height / Sizes.two;
        background: Colors.bg-surface;
        border-width: Sizes.border-w;
        border-color: Colors.border;

        // Fill
        Rectangle {
            x: Sizes.no-size;
            y: Sizes.no-size;
            width: parent.width * root.value;
            height: parent.height;
            border-radius: parent.height / Sizes.two;
            background: Colors.accent;

            animate width { duration: FluentMotion.medium; easing: ease-in-out; }
        }
    }

    if root.show-label: Text {
        x: (parent.width - self.width) / Sizes.two;
        y: -(self.height + Spacing.xs);
        text: Math.round(root.value * Sizes.hundred) + root.label-suffix;
        font-size: Type.caption-size;
        color: Colors.text-secondary;
    }
}
