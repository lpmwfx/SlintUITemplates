import { Colors, Spacing } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { CbfSecondaryRow }                   from "cbf-secondary-row.slint";
import { PrimaryBarContent, CbfAction }      from "PrimaryBarContent.slint";

export { CbfAction }

/// C om ma nd ba rf ly ou t component.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
/// component `CommandBarFlyout`.
export component CommandBarFlyout inherits Rectangle {
    /// Input property "primary".
    /// property `primary`.
    /// property `primary`.
    /// property `primary`.
    /// property `primary`.
    /// property `primary`.
    /// property `primary`.
    /// property `primary`.
    in property <[CbfAction]> primary: [];
    /// Input property "secondary".
    /// property `secondary`.
    /// property `secondary`.
    /// property `secondary`.
    /// property `secondary`.
    /// property `secondary`.
    /// property `secondary`.
    /// property `secondary`.
    in property <[CbfAction]> secondary: [];
    /// Input property "window-height".
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    in property <length>      window-height;
    /// Callback fired for a ct io n.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    callback action(string);

    /// Private property "pop-x" used internally.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    private property <length> pop-x:        Sizes.no-size;
    /// Private property "pop-y" used internally.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    private property <length> pop-y:        Sizes.no-size;
    /// Private property "border-px" used internally.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    private property <length> border-px:    Sizes.border-w;
    /// Private property "has-secondary" used internally.
    /// property `has-secondary`.
    /// property `has-secondary`.
    /// property `has-secondary`.
    /// property `has-secondary`.
    /// property `has-secondary`.
    /// property `has-secondary`.
    /// property `has-secondary`.
    private property <bool>   has-secondary: root.secondary.length > 0;
    /// Private property "sec-add" used internally.
    /// property `sec-add`.
    /// property `sec-add`.
    /// property `sec-add`.
    /// property `sec-add`.
    /// property `sec-add`.
    /// property `sec-add`.
    /// property `sec-add`.
    private property <length> sec-add:      root.has-secondary ? Spacing.xl : Sizes.no-size;
    /// Private property "primary-w" used internally.
    /// property `primary-w`.
    /// property `primary-w`.
    /// property `primary-w`.
    /// property `primary-w`.
    /// property `primary-w`.
    /// property `primary-w`.
    /// property `primary-w`.
    private property <length> primary-w:    root.primary.length * Spacing.xl + root.sec-add + Spacing.sm * 2;
    /// Private property "primary-h" used internally.
    /// property `primary-h`.
    /// property `primary-h`.
    /// property `primary-h`.
    /// property `primary-h`.
    /// property `primary-h`.
    /// property `primary-h`.
    /// property `primary-h`.
    private property <length> primary-h:    Spacing.xl + Spacing.sm * 2;
    /// Private property "secondary-w" used internally.
    /// property `secondary-w`.
    /// property `secondary-w`.
    /// property `secondary-w`.
    /// property `secondary-w`.
    /// property `secondary-w`.
    /// property `secondary-w`.
    /// property `secondary-w`.
    private property <length> secondary-w:  Sizes.panel-sm;
    /// Private property "secondary-h" used internally.
    /// property `secondary-h`.
    /// property `secondary-h`.
    /// property `secondary-h`.
    /// property `secondary-h`.
    /// property `secondary-h`.
    /// property `secondary-h`.
    /// property `secondary-h`.
    private property <length> secondary-h:  root.secondary.length * Spacing.xl + Spacing.sm * 2;

    background: transparent;

    primary-popup := PopupWindow {
        x: root.pop-x;
        y: root.pop-y;
        width: root.primary-w;
        height: root.primary-h;

        PrimaryBarContent {
            primary: root.primary;
            has-secondary: root.has-secondary;
            border-px: root.border-px;
            item-activated(id) => { primary-popup.close(); root.action(id); }
            show-secondary => { primary-popup.close(); secondary-popup.show(); }
        }
    }

    secondary-popup := PopupWindow {
        x: root.pop-x;
        y: root.pop-y;
        width: root.secondary-w;
        height: root.secondary-h;

        Rectangle {
            background: Colors.bg-elevated;
            border-radius: Spacing.sm;
            border-width: root.border-px;
            border-color: Colors.border;
            drop-shadow-blur: Spacing.sm;
            drop-shadow-color: Colors.shadow;

            VerticalLayout {
                padding: Spacing.xs;
                for item in root.secondary: CbfSecondaryRow {
                    item: item;
                    activated(id) => { secondary-popup.close(); root.action(id); }
                }
            }
        }
    }

    public function show-at(xp: length, yp: length) {
        root.pop-x = xp;
        if root.window-height > root.pop-x - root.pop-x
                && root.absolute-position.y + yp + root.primary-h > root.window-height {
            root.pop-y = yp - root.primary-h;
        } else {
            root.pop-y = yp;
        }
        primary-popup.show();
    }
}
