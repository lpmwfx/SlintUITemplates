import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";

/// C bf ac ti on struct.
/// struct `CbfAction`.
/// struct `CbfAction`.
/// struct `CbfAction`.
/// struct `CbfAction`.
/// struct `CbfAction`.
/// struct `CbfAction`.
/// struct `CbfAction`.
export struct CbfAction {
    id:      string,
    icon:    string,
    label:   string,
    enabled: bool,
}

/// C bf pr im ar yb tn component.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
/// component `CbfPrimaryBtn`.
export component CbfPrimaryBtn inherits Rectangle {
    /// Input property "item".
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    in property <CbfAction> item;
    /// Callback fired for a ct iv at ed.
    /// callback `activated`.
    /// callback `activated`.
    /// callback `activated`.
    /// callback `activated`.
    /// callback `activated`.
    /// callback `activated`.
    /// callback `activated`.
    callback activated(string);

    width: Spacing.xl;
    height: Spacing.xl;
    border-radius: Spacing.xs;
    background: !item.enabled ? transparent :
                ta.has-hover  ? Colors.bg-surface : transparent;

    Text {
        text: item.icon;
        font-family: FluentIcons.icon-font;
        font-size: Type.subtitle-size;
        color: item.enabled ? Colors.text-primary : Colors.text-disabled;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        enabled: item.enabled;
        clicked => { root.activated(root.item.id); }
    }
}
