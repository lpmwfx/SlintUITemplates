    /// property `dot-size`.
    /// property `dot-size`.
    /// property `dot-size`.
    /// property `dot-size`.
    /// property `dot-size`.
    /// property `dot-size`.
    private property <length> dot-size:    Spacing.sm + Spacing.xs;
