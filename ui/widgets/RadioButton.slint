    /// property `checked`.
    /// property `checked`.
    /// property `checked`.
    /// property `checked`.
    /// property `checked`.
    /// property `checked`.
    in property <bool>   checked: false;
    /// Input property "label".
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    /// property `label`.
    in property <string> label: "";
    /// Input property "enabled".
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    /// property `enabled`.
    in property <bool>   enabled: true;
    /// Callback fired for c li ck ed.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    callback clicked();

    /// Private property "circle-size" used internally.
