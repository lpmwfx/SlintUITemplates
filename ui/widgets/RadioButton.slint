    private property <length> ring-border: Sizes.border-w-2;

    height: Spacing.xl;
    background: transparent;
    opacity: root.enabled ? Sizes.fill : Sizes.half;

    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: start;
            spacing: Spacing.sm;

            Rectangle {
                width:  root.circle-size;
                height: root.circle-size;
                border-radius: root.circle-size / Sizes.two;
                border-width: root.ring-border;
                border-color: root.checked ? Colors.accent : Colors.border;
                background: transparent;

                if root.checked: Rectangle {
