    /// property `circle-size`.
    /// property `circle-size`.
    /// property `circle-size`.
    /// property `circle-size`.
    /// property `circle-size`.
    /// property `circle-size`.
    private property <length> circle-size: Spacing.md + Spacing.xs;
    /// Private property "dot-size" used internally.
