import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Sizes }       from "../state/sizes.slint";
import { SearchIcon }  from "SearchIcon.slint";
import { ClearButton } from "ClearButton.slint";

/// S ea rc hi np ut component.
/// component `SearchInput`.
export component SearchInput inherits Rectangle {
    /// Input property "value".
    /// property `value`.
    in property <string> value: "";
    /// Input property "placeholder".
    /// property `placeholder`.
    in property <string> placeholder: "Search...";
    /// Input property "enabled".
    /// property `enabled`.
    in property <bool>   enabled: true;
    /// Callback fired for c ha ng ed.
    /// callback `changed`.
    callback changed(string);
    /// Callback fired for s ub mi tt ed.
    /// callback `submitted`.
    callback submitted(string);
    /// Callback fired for c le ar ed.
    /// callback `cleared`.
    callback cleared();

    height: Spacing.xl;
    opacity: root.enabled ? Sizes.fill : Sizes.half;

    field := Rectangle {
        border-radius: Spacing.xs;
        border-width: Sizes.border-w;
        border-color: input.has-focus ? Colors.border-focus : Colors.border;
        background: Colors.bg-elevated;

        HorizontalLayout {
            // Search icon
            SearchIcon {
                icon: FluentIcons.search;
                font-name: FluentIcons.icon-font;
            }

            input := TextInput {
                text: root.value;
                font-size: Type.body-size;
                color: Colors.text-primary;
                vertical-alignment: center;
                enabled: root.enabled;
                horizontal-stretch: Sizes.one;

                edited => { root.changed(self.text); }
                accepted => { root.submitted(self.text); }
            }

            // Clear button
            if root.value != "": ClearButton {
                cleared => { input.text = ""; root.cleared(); }
            }
        }

        // Placeholder
        if input.text == "" && !input.has-focus: Text {
            x: Spacing.lg;
            text: root.placeholder;
            font-size: Type.body-size;
            color: Colors.text-disabled;
            vertical-alignment: center;
        }
    }
}
