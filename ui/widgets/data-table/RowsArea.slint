import { Sizes } from "../../globals/theme/sizes.slint";
import { TableRow, TableColumn } from "data-table-types.slint";
import { DataTableRow }          from "DataTableRow.slint";

export { TableRow, TableColumn }

/// R ow sa re a component.
/// component `RowsArea`.
///
/// ## Row Height Contract
/// RowsArea lets the Flickable auto-calculate viewport-height from the VerticalLayout
/// content. Each DataTableRow has a fixed height of Spacing.xl.
/// component `RowsArea`.
/// component `RowsArea`.
/// component `RowsArea`.
/// component `RowsArea`.
/// component `RowsArea`.
/// component `RowsArea`.
export component RowsArea inherits Rectangle {
    /// Input property "rows".
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    /// property `rows`.
    in property <[TableRow]>    rows;
    /// Input property "columns".
    /// property `columns`.
    /// property `columns`.
    /// property `columns`.
    /// property `columns`.
    /// property `columns`.
    /// property `columns`.
    /// property `columns`.
    in property <[TableColumn]> columns;
    /// Input property "selected".
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    /// property `selected`.
    in property <string>        selected;
    /// Callback fired for r ow s el ec te d.
    /// callback `row-selected`.
    /// callback `row-selected`.
    /// callback `row-selected`.
    /// callback `row-selected`.
    /// callback `row-selected`.
    /// callback `row-selected`.
    /// callback `row-selected`.
    callback row-selected(string);

    vertical-stretch: Sizes.one;
    clip: true;

    Flickable {
        width: parent.width;
        height: parent.height;

        VerticalLayout {
            for row[i] in root.rows: DataTableRow {
                cells: row.cells;
                columns: root.columns;
                is-selected: row.id == root.selected;
                is-alternate: Math.mod(i, Sizes.two) == Sizes.zero;
                clicked => { root.row-selected(row.id); }
            }
        }
    }
}
