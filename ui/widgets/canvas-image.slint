// CanvasImage — image slot for Rust-rendered frames (tiny-skia or any painter).
// Host sets `frame` each render tick. Placeholder shown when frame is empty.

import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";

/// C an va si ma ge component.
/// component `CanvasImage`.
export component CanvasImage inherits Rectangle {
    /// Input property "frame".
    /// property `frame`.
    in property <image>  frame;
    /// Input property "show-placeholder".
    /// property `show-placeholder`.
    in property <bool>   show-placeholder: true;
    /// Input property "placeholder-text".
    /// property `placeholder-text`.
    in property <string> placeholder-text: "No frame — wire canvas-frame from Rust";

    preferred-width:  Sizes.panel-xl;
    preferred-height: Sizes.panel-sm;
    background: Colors.bg-surface;
    border-width: Sizes.border-w;
    border-color: Colors.border;
    border-radius: Spacing.xs;
    clip: true;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.frame;
        image-fit: contain;
    }

    if root.show-placeholder && root.frame.width == Sizes.zero: Rectangle {
        background: Colors.bg-surface;
        VerticalLayout {
            alignment: center;
            spacing: Spacing.xs;
            Text {
                text: "\u{E91B}";
                font-family: FluentIcons.icon-font;
                font-size: Type.title-size;
                color: Colors.text-disabled;
                horizontal-alignment: center;
            }
            Text {
                text: root.placeholder-text;
                font-size: Type.caption-size;
                color: Colors.text-disabled;
                horizontal-alignment: center;
            }
        }
    }
}
