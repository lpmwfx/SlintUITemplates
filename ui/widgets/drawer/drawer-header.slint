import { Colors, Spacing, Type, FluentIcons } from "../../globals/theme.slint";
import { Sizes } from "../../globals/theme/sizes.slint";
import { Strings } from "../../globals/strings.slint";

/// D ra we rh ea de r component.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
/// component `DrawerHeader`.
export component DrawerHeader inherits Rectangle {
    /// Input property "title".
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    in property <string> title: "";
    /// Callback fired for c lo se r eq ue st ed.
    /// callback `close-requested`.
    /// callback `close-requested`.
    /// callback `close-requested`.
    /// callback `close-requested`.
    /// callback `close-requested`.
    /// callback `close-requested`.
    /// callback `close-requested`.
    callback close-requested();

    /// Private property "border-px" used internally.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    /// property `border-px`.
    private property <length> border-px:  Sizes.border-w;
    /// Private property "h-stretch" used internally.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    /// property `h-stretch`.
    private property <int>    h-stretch:  1;

    height: Spacing.xl;
    background: Colors.bg-surface;

    // Bottom border
    Rectangle {
        y: parent.height - root.border-px;
        width: parent.width;
        height: root.border-px;
        background: Colors.border;
    }

    HorizontalLayout {
        padding-left: Spacing.md;
        padding-right: Spacing.sm;

        if root.title != "": Text {
            text: root.title;
            font-size: Type.subtitle-size;
            font-weight: Type.weight-semibold;
            color: Colors.text-primary;
            vertical-alignment: center;
            horizontal-stretch: root.h-stretch;
        }

        Rectangle {
            width: Spacing.control-md;
            height: Spacing.control-md;
            border-radius: Spacing.xs;
            background: cls-ta.has-hover ? Colors.bg-elevated : transparent;

            Text { text: Strings.icon-close;
                font-family: FluentIcons.icon-font;
                font-size: Type.body-size;
                color: Colors.text-secondary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            cls-ta := TouchArea {
                clicked => { root.close-requested(); }
            }
        }
    }
}
