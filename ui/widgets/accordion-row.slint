import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";
import { Sizes } from "../state/sizes.slint";

/// A cc or di on it em struct.
/// struct `AccordionItem`.
export struct AccordionItem {
    id:      string,
    title:   string,
    content: string,
}

/// A cc or di on ro w component.
/// component `AccordionRow`.
export component AccordionRow inherits Rectangle {
    /// Input property "item".
    /// property `item`.
    in property <AccordionItem> item;
    /// Input property "expanded".
    /// property `expanded`.
    in property <bool>          expanded: false;
    /// Callback fired for t og gl ed.
    /// callback `toggled`.
    callback toggled(string);

    /// Private property "border-px" used internally.
    /// property `border-px`.
    private property <length>   border-px:    1px;
    /// Private property "content-h" used internally.
    /// property `content-h`.
    private property <length>   content-h:    Spacing.xl * Sizes.two;
    /// Private property "stretch-full" used internally.
    /// property `stretch-full`.
    private property <int>      stretch-full: 1;
    /// Private property "anim-dur" used internally.
    /// property `anim-dur`.
    private property <duration> anim-dur:     180ms;

    border-width: border-px;
    border-color: Colors.border;
    border-radius: Spacing.xs;
    background: Colors.bg-surface;
    clip: true;
    height: root.expanded
        ? Spacing.xl + root.content-h
        : Spacing.xl;

    animate height { duration: root.anim-dur; easing: ease-in-out; }

    VerticalLayout {
        spacing: Sizes.no-size;

        header := Rectangle {
            height: Spacing.xl;
            background: hdr-ta.has-hover ? Colors.bg-elevated : transparent;

            HorizontalLayout {
                padding-left: Spacing.sm;
                padding-right: Spacing.sm;
                spacing: Spacing.sm;

                Text {
                    text: root.expanded ? "\u{E70D}" : "\u{E76C}";
                    font-family: FluentIcons.icon-font;
                    font-size: Type.body-size;
                    color: Colors.text-secondary;
                    vertical-alignment: center;
                }

                Text {
                    text: item.title;
                    font-size: Type.body-size;
                    font-weight: Type.weight-semibold;
                    color: Colors.text-primary;
                    vertical-alignment: center;
                    horizontal-stretch: root.stretch-full;
                }
            }

            hdr-ta := TouchArea {
                clicked => { root.toggled(root.item.id); }
            }
        }

        if root.expanded: Rectangle {
            height: root.content-h;
            background: Colors.bg-primary;

            Text {
                x: Spacing.md;
                y: Spacing.sm;
                width: parent.width - Spacing.md * Sizes.two;
                text: item.content;
                font-size: Type.body-size;
                color: Colors.text-secondary;
                wrap: word-wrap;
            }
        }
    }
}
