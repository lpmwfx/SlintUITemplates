import { Colors, Spacing, Type, FluentIcons } from "../globals/theme.slint";

/// T oo lb ar it em struct.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
/// struct `ToolbarItem`.
export struct ToolbarItem {
    id:      string,
    icon:    string,
    tooltip: string,
    enabled: bool,
}

/// T oo lb ar bt n component.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
/// component `ToolbarBtn`.
export component ToolbarBtn inherits Rectangle {
    /// Input property "item".
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    /// property `item`.
    in property <ToolbarItem> item;
    /// Callback fired for c li ck ed.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    /// callback `clicked`.
    callback clicked(string);

    width: Spacing.xl;
    height: Spacing.xl;
    border-radius: Spacing.xs;
    background: !item.enabled ? transparent :
                ta.has-hover  ? Colors.bg-elevated : transparent;

    Text { text: item.icon;
        font-family: FluentIcons.icon-font;
        font-size: Type.subtitle-size;
        color: ta.has-hover ? Colors.accent : (item.enabled ? Colors.text-primary : Colors.text-secondary);
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        enabled: item.enabled;
        clicked => { root.clicked(root.item.id); }
    }
}
