// TeachingTip — popup with directional arrow for onboarding guidance.
//
// Place the trigger element as a child of TeachingTip via @children.
//
// Usage:
//   tip := TeachingTip {
//       window-height: root.height;
//       title: "New feature";
//       body: "Click here to get started.";
//       action-label: "Got it";
//       action => { tip.close(); }
//       Rectangle { TouchArea { clicked => { tip.show-at(self.mouse-x, self.mouse-y); } } }
//   }

import { Colors, Spacing, Type } from "../globals/theme.slint";
import { Sizes } from "../globals/theme/sizes.slint";
import { TeachingTipInner } from "teaching-tip-inner.slint";
import { Strings } from "../globals/strings.slint";

/// T ea ch in gt ip component.
/// component `TeachingTip`.
/// component `TeachingTip`.
/// component `TeachingTip`.
/// component `TeachingTip`.
/// component `TeachingTip`.
/// component `TeachingTip`.
/// component `TeachingTip`.
export component TeachingTip inherits Rectangle {
    /// Input property "window-height".
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    /// property `window-height`.
    in property <length> window-height;
    /// Input property "title".
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    /// property `title`.
    in property <string> title: "";
    /// Input property "body".
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    /// property `body`.
    in property <string> body: "";
    /// Input property "action-label".
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    /// property `action-label`.
    in property <string> action-label: "Got it";
    /// Input property "dismiss-label".
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    /// property `dismiss-label`.
    in property <string> dismiss-label: "";
    /// Callback fired for a ct io n.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    /// callback `action`.
    callback action();
    /// Callback fired for d is mi ss ed.
    /// callback `dismissed`.
    /// callback `dismissed`.
    /// callback `dismissed`.
    /// callback `dismissed`.
    /// callback `dismissed`.
    /// callback `dismissed`.
    /// callback `dismissed`.
    callback dismissed();

    /// Private property "pop-x" used internally.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    /// property `pop-x`.
    private property <length> pop-x:    Sizes.no-size;
    /// Private property "pop-y" used internally.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    /// property `pop-y`.
    private property <length> pop-y:    Sizes.no-size;
    /// Private property "popup-w" used internally.
    /// property `popup-w`.
    /// property `popup-w`.
    /// property `popup-w`.
    /// property `popup-w`.
    /// property `popup-w`.
    /// property `popup-w`.
    /// property `popup-w`.
    private property <length> popup-w:  Sizes.comp-260;
    /// Private property "popup-h" used internally.
    /// property `popup-h`.
    /// property `popup-h`.
    /// property `popup-h`.
    /// property `popup-h`.
    /// property `popup-h`.
    /// property `popup-h`.
    /// property `popup-h`.
    private property <length> popup-h:  Sizes.comp-180;
    /// Private property "arrow-sz" used internally.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    /// property `arrow-sz`.
    private property <length> arrow-sz: Sizes.glyph-sm;
    /// Private property "flip-up" used internally.
    /// property `flip-up`.
    /// property `flip-up`.
    /// property `flip-up`.
    /// property `flip-up`.
    /// property `flip-up`.
    /// property `flip-up`.
    /// property `flip-up`.
    private property <bool>   flip-up:  false;

    background: transparent;

    @children

    popup := PopupWindow {
        x: root.pop-x;
        y: root.pop-y;
        width: root.popup-w;
        height: root.popup-h + root.arrow-sz;

        VerticalLayout {
            // Arrow above (pointing up → tip appears below trigger)
            if !root.flip-up: Text { text: Strings.arrow-up;
                font-size: root.arrow-sz;
                color: Colors.bg-elevated;
                horizontal-alignment: center;
            }

            TeachingTipInner {
                height: root.popup-h;
                title:         root.title;
                body:          root.body;
                action-label:  root.action-label;
                dismiss-label: root.dismiss-label;
                popup-close => { popup.close(); }
                action    => { root.action(); }
                dismissed => { root.dismissed(); }
            }

            // Arrow below (pointing down → tip appears above trigger)
            if root.flip-up: Text { text: Strings.arrow-down;
                font-size: root.arrow-sz;
                color: Colors.bg-elevated;
                horizontal-alignment: center;
            }
        }
    }

    public function show-at(xp: length, yp: length) {
        root.pop-x = xp - root.popup-w / Sizes.two;
        if root.window-height > root.pop-x - root.pop-x
                && root.absolute-position.y + yp + root.popup-h + root.arrow-sz > root.window-height {
            root.flip-up = true;
            root.pop-y = yp - root.popup-h - root.arrow-sz;
        } else {
            root.flip-up = false;
            root.pop-y = yp;
        }
        popup.show();
    }

    public function close() {
        popup.close();
    }
}
