export component CbfOverflowBtn inherits Rectangle {
    /// Callback fired for s ho w s ec on da ry.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    /// callback `show-secondary`.
    callback show-secondary();

    width: Spacing.xl;
    height: Spacing.xl;
    border-radius: Spacing.xs;
    background: ta.has-hover ? Colors.bg-surface : transparent;

    Text {
        text: Strings.icon-more;
