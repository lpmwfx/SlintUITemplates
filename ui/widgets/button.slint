import { Colors, Spacing, Type } from "../tokens/theme.slint";
import { Sizes } from "../tokens/sizes.slint";
import { Variants } from "../globals/Variants.slint";

/// Generic action button with Fluent-style variants and hover feedback.
export component Button inherits Rectangle {
    /// Text rendered in the button body.
    in property <string> label: "Button";
    /// Visual style key: `primary`, `secondary`, `ghost`, or `danger`.
    in property <string> variant: Variants.primary;   // primary | secondary | ghost | danger
    /// Enables pointer interaction and active styling when `true`.
    in property <bool> enabled: true;
    /// Fired when the user activates the button.
    callback clicked();

    height: Spacing.xl;
    border-radius: Spacing.xs;
    clip: true;
    horizontal-stretch: 0;

    // Variant colors
    property <color> bg-normal:
        variant == Variants.primary   ? Colors.accent :
        variant == Variants.secondary ? Colors.bg-surface :
        variant == Variants.danger    ? Colors.error :
        transparent;

    property <color> bg-hover:
        variant == Variants.primary   ? Colors.accent-hover :
        variant == Variants.secondary ? Colors.bg-elevated :
        variant == Variants.danger    ? Colors.error :
        Colors.bg-surface;

    property <color> text-color:
        !enabled ? Colors.text-disabled :
        variant == Variants.primary   ? Colors.accent-text :
        variant == Variants.danger    ? Colors.accent-text :
        Colors.text-primary;

    background: !enabled ? Colors.bg-surface :
                ta.has-hover ? bg-hover : bg-normal;

    border-width: variant == Variants.secondary ? Sizes.border-w : Sizes.no-size;
    border-color: Colors.border;

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        alignment: center;
        padding-left: Spacing.md;
        padding-right: Spacing.md;

        Text {
            text: root.label;
            font-size: Type.body-size;
            font-weight: Type.weight-semibold;
            color: root.text-color;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}
